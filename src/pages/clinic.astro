---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Movement Clinic | Personalized Physical Therapy"
  description="Personalized physical therapy at Movement Clinic. Clear treatment plans, real availability, and direct support. Book your first appointment today."
  themeColor="#16302A"
  bodyClass="clinic"
  consent={{ bg: "#16302A", fg: "#F4EFE4", accent: "#E8A33D", accentFg: "#16302A", border: "rgba(244,239,228,0.16)" }}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head">
  <link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@400;500;700;900&family=Heebo:wght@300;400;500;700;900&display=swap" rel="stylesheet" slot="head">

  <!-- HERO -->
  <header class="relative bg-pine text-sand overflow-hidden">
    <svg class="absolute inset-0 w-full h-full opacity-25" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice">
      <path class="movement-line" d="M -50 600 Q 200 300, 450 500 T 900 350 T 1300 500" stroke="#E8A33D" stroke-width="3" fill="none" stroke-linecap="round"/>
      <path class="movement-line" d="M -50 200 Q 250 450, 550 250 T 1000 400 T 1300 200" stroke="#7C9C8F" stroke-width="2" fill="none" stroke-linecap="round" style="animation-delay:0.3s"/>
    </svg>

    <nav class="relative max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
      <span class="font-display text-2xl font-bold">Movement Clinic</span>
      <a href="#booking" class="hidden sm-inline-block bg-amber text-pine font-bold px-5 py-2 rounded-full text-sm hover-bg-sand transition">Book an Appointment</a>
    </nav>

    <div class="relative max-w-6xl mx-auto px-6 pt-10 pb-24 md-pt-16 md-pb-32">
      <p class="text-amber font-bold tracking-wide text-sm mb-4">Clinical Physical Therapy · Personalized Care · Movement Recovery</p>
      <h1 class="font-display text-4xl md-text-6xl font-bold leading-tight max-w-3xl">
        Pain doesn't have<br>to run your day
      </h1>
      <p class="mt-6 text-lg text-sand/80 max-w-xl leading-relaxed">
        Personalized physical therapy with a clear plan you actually understand from session one. No more "just keep coming in" without an explanation.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#booking" class="bg-amber text-pine font-bold px-7 py-3 rounded-full hover-bg-white transition">I want a first appointment</a>
        <a href="#services" class="text-sand border border-sand/40 px-7 py-3 rounded-full hover-bg-white/10 transition">What treatment includes</a>
      </div>
    </div>
  </header>

  <main id="main">
    <!-- WHY -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <p class="text-clay font-bold text-sm mb-2">Why patients stay</p>
      <h2 class="font-display text-3xl md-text-4xl font-bold mb-12 max-w-2xl">An approach that starts with understanding, not a fixed protocol</h2>
      <div class="grid md-grid-cols-3 gap-8">
        <div class="border-t-4 border-amber pt-5">
          <h3 class="font-display text-xl font-bold mb-2">Diagnosis before treatment</h3>
          <p class="text-pine/70 leading-relaxed">The first session is dedicated to understanding the source of your pain, not just treating the symptom.</p>
        </div>
        <div class="border-t-4 border-sage pt-5">
          <h3 class="font-display text-xl font-bold mb-2">A plan you can see</h3>
          <p class="text-pine/70 leading-relaxed">Clear goals set in advance, so you know when and why you're making progress.</p>
        </div>
        <div class="border-t-4 border-clay pt-5">
          <h3 class="font-display text-xl font-bold mb-2">Real availability</h3>
          <p class="text-pine/70 leading-relaxed">Questions between sessions? Direct answers on WhatsApp, not an appointment for an appointment.</p>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="bg-pinelight text-sand py-20">
      <div class="max-w-6xl mx-auto px-6">
        <p class="text-amber font-bold text-sm mb-2">Areas of treatment</p>
        <h2 class="font-display text-3xl md-text-4xl font-bold mb-12 max-w-2xl">Tailored to what you need right now</h2>
        <div class="grid sm-grid-cols-2 gap-5">
          <div class="bg-pine/60 rounded-2xl p-6">
            <h3 class="font-bold text-lg mb-1">Back and neck pain</h3>
            <p class="text-sand/70 text-sm leading-relaxed">Chronic or acute, from prolonged sitting or injury.</p>
          </div>
          <div class="bg-pine/60 rounded-2xl p-6">
            <h3 class="font-bold text-lg mb-1">Post-surgery rehab</h3>
            <p class="text-sand/70 text-sm leading-relaxed">A gradual program to restore full, safe function.</p>
          </div>
          <div class="bg-pine/60 rounded-2xl p-6">
            <h3 class="font-bold text-lg mb-1">Sports injuries</h3>
            <p class="text-sand/70 text-sm leading-relaxed">Return to activity without risking re-injury.</p>
          </div>
          <div class="bg-pine/60 rounded-2xl p-6">
            <h3 class="font-bold text-lg mb-1">Joint pain and inflammation</h3>
            <p class="text-sand/70 text-sm leading-relaxed">Long-term care to improve everyday mobility.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BOOKING -->
    <section id="booking" class="max-w-2xl mx-auto px-6 py-20">
      <p class="text-clay font-bold text-sm mb-2">First step</p>
      <h2 class="font-display text-3xl md-text-4xl font-bold mb-3">Let's book your first appointment</h2>
      <p class="text-pine/70 mb-8">Leave your details, and the message is sent straight to the clinic's WhatsApp. We'll get back to you within one business day.</p>

      <form id="leadForm" class="space-y-4 bg-white/60 rounded-2xl p-6 border border-pine/10">
        <div>
          <label class="block text-sm font-bold mb-1" for="name">Full name</label>
          <input required id="name" name="name" type="text" class="w-full rounded-lg border border-pine/20 px-4 py-3 bg-white" placeholder="e.g. Jane Cohen">
        </div>
        <div>
          <label class="block text-sm font-bold mb-1" for="phone">Phone</label>
          <input required id="phone" name="phone" type="tel" class="w-full rounded-lg border border-pine/20 px-4 py-3 bg-white" placeholder="+1 555 123 4567">
        </div>
        <div>
          <label class="block text-sm font-bold mb-1" for="reason">What's bothering you?</label>
          <select id="reason" name="reason" class="w-full rounded-lg border border-pine/20 px-4 py-3 bg-white">
            <option>Back and neck pain</option>
            <option>Post-surgery rehab</option>
            <option>Sports injury</option>
            <option>Joint pain</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold mb-1" for="time">When works for you?</label>
          <select id="time" name="time" class="w-full rounded-lg border border-pine/20 px-4 py-3 bg-white">
            <option>Morning</option>
            <option>Afternoon</option>
            <option>Evening</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-amber text-pine font-bold py-3 rounded-full hover-bg-clay hover-text-sand transition">
          Send via WhatsApp
        </button>
        <p class="text-xs text-pine/50 text-center">Clicking send will open a WhatsApp chat with your message ready to go.</p>
      </form>
    </section>
  </main>

  <footer class="bg-pine text-sand py-8 text-center text-sm">
    <p>Movement Clinic · [Address] · [Phone] · [Hours]</p>
    <p class="text-xs mt-2">Sample page only - does not represent an active business.</p>
  </footer>
</BaseLayout>

<style>
  :global(.clinic) {
    --clr-pine: #16302A;
    --clr-pinelight: #20463C;
    --clr-sand: #F4EFE4;
    --clr-amber: #E8A33D;
    --clr-sage: #7C9C8F;
    --clr-clay: #B5652E;
    font-family: "Heebo", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--clr-sand);
    color: var(--clr-pine);
    line-height: 1.6;
  }

  :global(.clinic) h1, :global(.clinic) h2, :global(.clinic) h3 { font-family: "Frank Ruhl Libre", Georgia, serif; }

  @keyframes moveLine {
    0% { d: path("M -50 600 Q 200 300, 450 500 T 900 350 T 1300 500"); }
    50% { d: path("M -50 500 Q 250 400, 500 450 T 850 300 T 1300 550"); }
    100% { d: path("M -50 550 Q 150 350, 400 550 T 950 400 T 1300 450"); }
  }

  .movement-line { animation: moveLine 8s ease-in-out infinite alternate; }

  .bg-pine { background: var(--clr-pine); }
  .bg-pinelight { background: var(--clr-pinelight); }
  .bg-sand { background: var(--clr-sand); }
  .bg-amber { background: var(--clr-amber); }
  .bg-white { background: #fff; }
  .bg-white\/60 { background: rgba(255,255,255,0.6); }
  .bg-pine\/60 { background: rgba(22,48,42,0.6); }
  .text-pine { color: var(--clr-pine); }
  .text-sand { color: var(--clr-sand); }
  .text-amber { color: var(--clr-amber); }
  .text-clay { color: #8B4513; }
  .text-sage { color: var(--clr-sage); }
  .text-pine\/70 { color: rgba(22,48,42,0.7); }
  .text-pine\/50 { color: rgba(22,48,42,0.5); }
  .text-sand\/70 { color: rgba(244,239,228,0.7); }
  .text-sand\/80 { color: rgba(244,239,228,0.8); }
  .text-xs { font-size: .75rem; }
  .text-sm { font-size: .875rem; }
  .text-lg { font-size: 1.125rem; }
  .text-xl { font-size: 1.25rem; }
  .text-2xl { font-size: 1.5rem; }
  .text-3xl { font-size: 1.875rem; }
  .text-4xl { font-size: 2.25rem; }
  .font-display { font-family: "Frank Ruhl Libre", Georgia, serif; }
  .font-bold { font-weight: 700; }
  .font-black { font-weight: 900; }
  .tracking-wide { letter-spacing: .025em; }
  .leading-tight { line-height: 1.25; }
  .leading-relaxed { line-height: 1.625; }
  .max-w-6xl { max-width: 72rem; }
  .max-w-3xl { max-width: 48rem; }
  .max-w-2xl { max-width: 42rem; }
  .max-w-xl { max-width: 36rem; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
  .px-5 { padding-left: 1.25rem; padding-right: 1.25rem; }
  .px-7 { padding-left: 1.75rem; padding-right: 1.75rem; }
  .px-4 { padding-left: 1rem; padding-right: 1rem; }
  .py-3 { padding-top: .75rem; padding-bottom: .75rem; }
  .py-6 { padding-top: 1.5rem; padding-bottom: 1.5rem; }
  .py-8 { padding-top: 2rem; padding-bottom: 2rem; }
  .py-20 { padding-top: 5rem; padding-bottom: 5rem; }
  .pt-10 { padding-top: 2.5rem; }
  .pb-24 { padding-bottom: 6rem; }
  .pt-5 { padding-top: 1.25rem; }
  .p-6 { padding: 1.5rem; }
  .mt-2 { margin-top: .5rem; }
  .mt-6 { margin-top: 1.5rem; }
  .mt-8 { margin-top: 2rem; }
  .mb-1 { margin-bottom: .25rem; }
  .mb-2 { margin-bottom: .5rem; }
  .mb-3 { margin-bottom: .75rem; }
  .mb-4 { margin-bottom: 1rem; }
  .mb-8 { margin-bottom: 2rem; }
  .mb-12 { margin-bottom: 3rem; }
  .space-y-4 > * + * { margin-top: 1rem; }
  .flex { display: flex; }
  .flex-wrap { flex-wrap: wrap; }
  .gap-4 { gap: 1rem; }
  .gap-5 { gap: 1.25rem; }
  .gap-8 { gap: 2rem; }
  .items-center { align-items: center; }
  .justify-between { justify-content: space-between; }
  .text-center { text-align: center; }
  .grid { display: grid; }
  .border { border: 1px solid currentColor; }
  .border-t-4 { border-top-width: 4px; border-top-style: solid; }
  .border-amber { border-color: var(--clr-amber); }
  .border-sage { border-color: var(--clr-sage); }
  .border-clay { border-color: var(--clr-clay); }
  .border-pine\/10 { border-color: rgba(22,48,42,0.1); }
  .border-pine\/20 { border-color: rgba(22,48,42,0.2); }
  .border-sand\/40 { border-color: rgba(244,239,228,0.4); }
  .rounded-full { border-radius: 9999px; }
  .rounded-2xl { border-radius: 1rem; }
  .rounded-lg { border-radius: .5rem; }
  .relative { position: relative; }
  .absolute { position: absolute; }
  .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
  .overflow-hidden { overflow: hidden; }
  .block { display: block; }
  .inline-block { display: inline-block; }
  .hidden { display: none; }
  .w-full { width: 100%; }
  .hover-bg-white:hover { background: #fff; }
  .hover-bg-white\/10:hover { background: rgba(255,255,255,0.1); }
  .hover-bg-clay:hover { background: var(--clr-clay); }
  .hover-text-sand:hover { color: var(--clr-sand); }
  .hover-bg-sand:hover { background: var(--clr-sand); }
  .transition { transition: all .2s; }
  .opacity-25 { opacity: .25; }

  @media (min-width: 640px) {
    .sm-inline-block { display: inline-block; }
    .sm-grid-cols-2 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .md-grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
    .md-pt-16 { padding-top: 4rem; }
    .md-pb-32 { padding-bottom: 8rem; }
    .md-text-4xl { font-size: 2.25rem; }
    .md-text-6xl { font-size: 3.75rem; }
  }
</style>

<script>
(function () {
  var form = document.getElementById('leadForm');
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = document.getElementById('name').value.trim();
      var phone = document.getElementById('phone').value.trim();
      var reason = document.getElementById('reason').value;
      var time = document.getElementById('time').value;
      if (!name || !phone) return;
      var message = 'New inquiry from the website:\nName: ' + name + '\nPhone: ' + phone + '\nReason: ' + reason + '\nPreferred time: ' + time;
      window.open('https://wa.me/972584433181?text=' + encodeURIComponent(message), '_blank');
    });
  }
})();
</script>
