---
import BaseLayout from "../layouts/BaseLayout.astro";
const services = [
  { title: "Emergency Lockout", desc: "Locked out of your home, car, or office? We respond within 30 minutes, 24/7, including weekends and holidays." },
  { title: "Residential Lock Changes", desc: "Re-key, replace, or upgrade locks on doors, windows, deadbolts, and garage entries. All brands serviced." },
  { title: "Commercial Security", desc: "Master key systems, access control, panic bars, high-security cylinders, and keyless entry for businesses and multi-tenant buildings." },
  { title: "Automotive", desc: "Car key duplication, transponder key programming, broken key extraction, and ignition repair for all makes and models." },
  { title: "Safe Services", desc: "Safe combination changes, lock repairs, and opening services for home safes, gun safes, and fire safes." },
  { title: "Key Duplication & Cutting", desc: "Standard keys, restricted keys, high-security keys, and bump-proof keys cut on-site while you wait." },
];
const badges = ["24/7 Emergency Service", "30-minute response time", "Licensed, bonded & insured", "Free estimate on repairs", "Senior & veteran discounts", "Family-owned since 1988"];
const reviews = [
  { text: "Locked myself out of my apartment at 11 PM on a Saturday. Called and they were there in 20 minutes. Professional, fast, and the price was exactly what they quoted on the phone. No surprises.", name: "Derek S." },
  { text: "Needed all the locks re-keyed in our new house. They did 8 locks in under an hour and the guy even tightened our sticky front door. Great service.", name: "Patricia M." },
];
---
<BaseLayout title="Rose City Locksmith | Portland Locksmith — 24/7 Emergency Services" description="Rose City Locksmith provides 24/7 emergency lockout service, lock changes, re-keying, commercial security, automotive keys, and safe services in Portland. Family-owned since 1988." themeColor="#2C1810" bodyClass="locksmith" consent={{ bg: "#2C1810", fg: "#FDF8F5", accent: "#D4A373", accentFg: "#2C1810", border: "rgba(253,248,245,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" /></noscript>
  </slot>
  <div class="emergency-bar"><span>🔑 24/7 Emergency Service &mdash; Call anytime</span><a href="tel:+15550123" class="em-phone">(555) 555-0123</a></div>
  <section class="hero"><div class="container"><h1>Locked out? We're on the way.</h1><p class="hero-sub">Rose City Locksmith &mdash; serving Portland since 1988. Emergency lockout, lock changes, commercial security, and automotive key service. Licensed, bonded, insured.</p><div class="hero-actions"><a href="tel:+15550123" class="btn-emergency">Call for Emergency</a><a href="#services" class="btn-outline">All Services</a></div></div></section>
  <section class="badges"><div class="container"><div class="badge-grid">{badges.map((b) => (<div class="badge-item"><span class="badge-icon">✦</span>{b}</div>))}</div></div></section>
  <section class="services-section" id="services"><div class="container"><h2>What we do.</h2><div class="svc-grid">{services.map((s) => (<div class="svc-card"><h3>{s.title}</h3><p>{s.desc}</p></div>))}</div></div></section>
  <section class="reviews"><div class="container"><div class="review-pair">{reviews.map((r) => (<div class="r-card"><p>"{r.text}"</p><strong>{r.name}</strong></div>))}</div></div></section>
  <section class="cta"><div class="container cta-inner"><h2>Stay unlocked <span style="font-style:italic">and</span> secure.</h2><a href="tel:+15550123" class="cta-tel">(555) 555-0123</a></div></section>
  <footer class="footer"><div class="container"><p>Rose City Locksmith &mdash; Portland, OR &middot; Licensed, Bonded &amp; Insured</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a></nav></div></footer>
</BaseLayout>
<style>:global(.locksmith){--brown:#2C1810;--sand:#D4A373;--cream:#FDF8F5;--font-h:'DM Serif Display',Georgia,serif;--font-b:'Inter',sans-serif}:global(.locksmith){font-family:var(--font-b);color:#444;background:var(--cream);line-height:1.6}:global(.locksmith) :focus-visible{outline:3px solid var(--sand);outline-offset:2px}.container{max-width:1000px;margin:0 auto;padding:0 24px}h1{font-family:var(--font-h);font-size:clamp(2.2rem,5.5vw,3.6rem);font-weight:400;color:var(--brown);line-height:1;max-width:650px;letter-spacing:-0.01em}h2{font-family:var(--font-h);font-size:clamp(1.4rem,3vw,2rem);color:var(--brown);margin-bottom:28px}
  .emergency-bar{background:var(--brown);color:#fff;text-align:center;padding:12px;display:flex;justify-content:center;gap:16px;align-items:center;font-size:.9rem;font-weight:600}.em-phone{color:var(--sand);text-decoration:none;font-weight:700;font-size:1rem}.em-phone:hover{color:#fff}
  .hero{padding:80px 0 60px}.hero-sub{color:#888;font-size:1.05rem;max-width:550px;margin:20px 0 32px}.hero-actions{display:flex;gap:16px;align-items:center}.btn-emergency{display:inline-block;padding:14px 32px;background:var(--brown);color:#fff;text-decoration:none;font-weight:700;transition:background .25s}.btn-emergency:hover{background:#3d2216}.btn-outline{display:inline-block;padding:14px 32px;border:2px solid var(--brown);color:var(--brown);text-decoration:none;font-weight:600;transition:all .25s}.btn-outline:hover{background:var(--brown);color:#fff}
  .badges{padding:20px 0 40px}.badge-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.badge-item{display:flex;align-items:center;gap:10px;color:#666;font-size:.82rem}.badge-icon{color:var(--sand);font-size:.7rem}
  .services-section{padding:60px 0;border-top:1px solid rgba(0,0,0,.06)}.svc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}.svc-card{padding:24px;background:#fff;border:1px solid rgba(44,24,16,.08)}.svc-card h3{font-family:var(--font-h);font-size:1.05rem;color:var(--brown);margin-bottom:4px}.svc-card p{color:#888;font-size:.85rem;line-height:1.6}
  .reviews{padding:60px 0}.review-pair{display:grid;grid-template-columns:1fr 1fr;gap:24px}.r-card{padding:24px;background:#fff;border-left:3px solid var(--sand)}.r-card p{font-style:italic;color:#666;font-size:.9rem;margin-bottom:8px}.r-card strong{font-size:.85rem;color:var(--brown)}
  .cta{padding:80px 0;background:var(--brown);text-align:center}.cta h2{color:#fff;margin-bottom:16px}.cta-tel{font-family:var(--font-h);font-size:2.5rem;color:var(--sand);text-decoration:none}.cta-tel:hover{color:#fff}
  .footer{padding:40px 0;text-align:center;color:#bbb;font-size:.8rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:6px}.footer a{color:#bbb;text-decoration:underline}
  @media(max-width:800px){.svc-grid{grid-template-columns:1fr}.badge-grid{grid-template-columns:1fr}.review-pair{grid-template-columns:1fr}}
</style>
