---
import BaseLayout from "../layouts/BaseLayout.astro";
const modalities = [
  { title: "Swedish Massage", desc: "Long, flowing strokes that promote relaxation, improve circulation, and ease general muscle tension. The foundation of therapeutic massage." },
  { title: "Deep Tissue", desc: "Targeted work on chronic tension patterns using slow, deliberate pressure across muscle fibers. Effective for persistent knots and postural strain." },
  { title: "Prenatal Massage", desc: "Side-lying positioning and modified techniques designed for the changing body during pregnancy. Reduces swelling, relieves back pain, and supports rest." },
  { title: "Sports Massage", desc: "Pre-event activation, inter-event recovery, and post-event restoration for active clients. Includes stretching, compression, and targeted trigger point work." },
];
const rituals = ["Begin with breath. We set an intention together.", "Warm towels and a foot soak to signal your nervous system it's safe.", "The session — your pace, your pressure preference, zero conversation if you prefer.", "Integration time with tea, quiet, and a take-home stretch recommendation."];
---
<BaseLayout title="Stillwater Massage | Portland Therapeutic & Relaxation Massage" description="Stillwater Massage offers therapeutic and relaxation massage in a calm, private studio in Southeast Portland. Swedish, deep tissue, prenatal, and sports massage." themeColor="#9AAF8C" bodyClass="massage" consent={{ bg: "#4A5C44", fg: "#F4F7F1", accent: "#C4B5D0", accentFg: "#2C3A28", border: "rgba(244,247,241,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap" /></noscript>
  </slot>
  <main id="main" class="snap-container">
    <section class="snap snap--hero"><div class="hero-bg"></div><div class="hero-inner"><p class="hero-small">Stillwater Massage</p><h1>Stillness is medicine.</h1><p class="hero-p">A private studio in Southeast Portland. One client at a time. Therapeutic massage in complete quiet, at your pace.</p><a href="#modalities" class="btn-ghost">Explore modalities</a></div></section>
    <section class="snap snap--about"><div><p class="section-num">01</p><h2>A room designed for your nervous system to downshift.</h2><p>Low lighting, warm linens, curated playlists or silence — your choice. Every session includes undivided attention from a licensed therapist with 12 years of experience and a commitment to continuing education in myofascial release, craniosacral therapy, and lymphatic drainage.</p></div></section>
    <section class="snap snap--modalities" id="modalities"><div><p class="section-num">02</p><h2>Modalities.</h2><div class="mod-grid">{modalities.map((m) => (<div class="mod-card"><h3>{m.title}</h3><p>{m.desc}</p></div>))}</div></div></section>
    <section class="snap snap--ritual"><div><p class="section-num">03</p><h2>Every session follows the same ritual.</h2><div class="ritual-strip">{rituals.map((r,i) => (<div class="ritual-step"><span class="ritual-num">{String(i+1).padStart(2,'0')}</span><p>{r}</p></div>))}</div></div></section>
    <section class="snap snap--book" id="book"><div><h2>Book a session.</h2><p>New clients welcome. Gift certificates available.</p><a href="mailto:hello@stillwatermassage.com" class="book-link">hello@stillwatermassage.com</a><span class="book-phone">503.555.0133</span><p class="book-small">60-min $120 &middot; 90-min $170 &middot; 120-min $220</p></div></section>
  </main>
  <footer class="footer"><div class="container"><p>Stillwater Massage &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>:global(.massage){--sage:#9AAF8C;--sage-dark:#4A5C44;--lavender:#C4B5D0;--cream:#F4F7F1;--font-h:'Sora',sans-serif;--font-b:'Inter',sans-serif}:global(.massage){font-family:var(--font-b);font-weight:300;color:#444;background:var(--cream);line-height:1.7;-webkit-font-smoothing:antialiased}:global(.massage) :focus-visible{outline:3px solid var(--lavender);outline-offset:2px}.container{max-width:900px;margin:0 auto;padding:0 24px}h1,h2{font-family:var(--font-h);font-weight:300;color:var(--sage-dark);line-height:1.15}h1{font-size:clamp(2.8rem,7vw,5rem);letter-spacing:-0.03em}h2{font-size:clamp(1.6rem,3.5vw,2.4rem);margin-bottom:24px;font-weight:400}
  .snap-container{scroll-snap-type:y mandatory;overflow-y:scroll;height:100vh}.snap{scroll-snap-align:start;height:100vh;display:flex;align-items:center;justify-content:center;padding:60px 40px;max-width:800px;margin:0 auto}
  .snap--hero{flex-direction:column;text-align:center;position:relative}.hero-bg{position:absolute;inset:0;background:linear-gradient(160deg,var(--cream) 0%,var(--sage) 100%);opacity:.15}.hero-inner{position:relative;z-index:1}.hero-small{font-size:.8rem;text-transform:uppercase;letter-spacing:5px;color:var(--sage-dark);margin-bottom:24px;font-weight:400}.hero-p{color:#888;font-size:1.05rem;margin:24px auto 40px;max-width:500px}.btn-ghost{padding:12px 32px;border:1px solid var(--sage-dark);color:var(--sage-dark);text-decoration:none;font-weight:400;font-size:.9rem;transition:all .25s}.btn-ghost:hover{background:var(--sage-dark);color:var(--cream)}
  .snap--about{text-align:center}.snap--about p{color:#777;font-size:1rem;line-height:1.8;max-width:580px;margin:0 auto}.section-num{font-family:var(--font-h);font-size:3rem;font-weight:200;color:var(--sage);display:block;margin-bottom:8px;line-height:1}
  .snap--modalities{display:block;overflow-y:auto;padding-top:80px;scroll-snap-align:none}.mod-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}.mod-card h3{font-family:var(--font-h);font-size:1rem;font-weight:600;color:var(--sage-dark);margin-bottom:4px}.mod-card p{color:#888;font-size:.85rem;line-height:1.6}
  .ritual-strip{display:flex;gap:24px}.ritual-step{flex:1;padding:24px;background:rgba(154,175,140,.1)}.ritual-num{font-family:var(--font-h);font-size:2rem;font-weight:200;color:var(--sage);display:block;margin-bottom:8px;line-height:1}.ritual-step p{color:#888;font-size:.9rem;line-height:1.6}
  .snap--book{text-align:center}.snap--book p{color:#888;margin-bottom:24px}.book-link{font-family:var(--font-h);font-size:1.5rem;color:var(--sage-dark);text-decoration:none;border-bottom:1px solid var(--sage-dark);padding-bottom:4px}.book-link:hover{color:var(--lavender);border-color:var(--lavender)}.book-phone{display:block;margin-top:8px;color:#aaa;font-size:.9rem}.book-small{margin-top:24px;font-size:.85rem;color:#bbb}
  .footer{padding:24px 0;text-align:center;color:#ccc;font-size:.8rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:4px}.footer a{color:#ccc;text-decoration:underline}
  @media(max-width:800px){.mod-grid{grid-template-columns:1fr}.ritual-strip{flex-direction:column}.snap{padding:40px 24px}}
</style>
