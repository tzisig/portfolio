---
import BaseLayout from "../layouts/BaseLayout.astro";
const plans = [
  { name: "Auto", badge: " Liability + Comprehensive", items: ["Bodily injury & property damage", "Collision & comprehensive", "Rental car coverage", "Roadside assistance", "Uninsured motorist"], price: "from $98/mo" },
  { name: "Home", badge: " HO-3 Special Form", items: ["Dwelling & other structures", "Personal property replacement", "Loss of use coverage", "Personal liability", "Medical payments"], price: "from $124/mo" },
  { name: "Life", badge: " Term + Whole Life", items: ["Term life 10-30 year terms", "Whole life cash value", "Accelerated death benefit", "Waiver of premium", "Child rider available"], price: "from $32/mo" },
  { name: "Business", badge: " BOP + Professional", items: ["General liability", "Property coverage", "Business interruption", "Professional liability", "Workers' comp"], price: "from $89/mo" },
];
const ratings = ["A+ AM Best Rating", "4.9 Google Reviews", "5-Star Service Since 2009", "Licensed in OR & WA"];
---
<BaseLayout title="Pinnacle Insurance | Portland Auto, Home, Life & Business Insurance" description="Pinnacle Insurance provides personalized auto, home, life, and business insurance across Oregon and Washington. Independent agency, multiple carriers." themeColor="#1B2A4A" bodyClass="insurance" consent={{ bg: "#1B2A4A", fg: "#F4F2ED", accent: "#D4A843", accentFg: "#1B2A4A", border: "rgba(244,242,237,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="top-nav"><div class="container nav-inner"><a href="#" class="top-logo">Pinnacle Insurance</a><ul class="top-links"><li><a href="#plans">Plans</a></li><li><a href="#compare">Compare</a></li><li><a href="#quote" class="top-cta">Get a Quote</a></li></ul></div></nav>
  <main>
    <section class="hero"><div class="container hero-inner"><div class="hero-text"><p class="hero-badge">Independent Agency &middot; 30+ Carriers</p><h1>Insurance that actually covers what matters to you.</h1><p>We compare policies across multiple carriers to find coverage that fits your life and your budget — without the fine-print surprises.</p><a href="#quote" class="btn-primary">Compare Plans</a></div><div class="hero-rating"><div class="rating-grid">{ratings.map((r) => (<div class="rating-pill">{r}</div>))}</div></div></div></section>
    <section class="plans" id="plans"><div class="container"><h2>Coverage you can count on.</h2><div class="plan-grid">{plans.map((p) => (<div class="plan-card"><div class="plan-head"><h3>{p.name}</h3><span class="plan-badge">{p.badge}</span></div><ul>{p.items.map((i) => (<li>{i}</li>))}</ul><span class="plan-price">{p.price}</span></div>))}</div></div></section>
    <section class="compare-section" id="compare"><div class="container"><h2>Why an independent agent?</h2><div class="compare-table"><div class="table-row table-header"><span></span><span>Big Box Carrier</span><span class="highlight">Pinnacle Insurance</span></div><div class="table-row"><span>Policies compared</span><span>1 carrier</span><span class="highlight">30+ carriers</span></div><div class="table-row"><span>Claims support</span><span>Call center</span><span class="highlight">Dedicated agent</span></div><div class="table-row"><span>Annual review</span><span>Automated</span><span class="highlight">In-person</span></div><div class="table-row"><span>Policy bundling</span><span>Limited</span><span class="highlight">Custom packages</span></div></div></div></section>
    <section class="quote-section" id="quote"><div class="container quote-inner"><h2>Get a quote in 10 minutes.</h2><p>No obligation. No spam. Just clear options from someone who actually reads the policies.</p><a href="tel:+15550115" class="quote-tel">(555) 555-0115</a><span class="quote-mail">quotes@pinnacleins.com</span></div></section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Pinnacle Insurance Agency &mdash; Portland, OR &middot; Licensed in OR &amp; WA</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>:global(.insurance){--navy:#1B2A4A;--gold:#D4A843;--cream:#F4F2ED;--font-h:'Space Grotesk',sans-serif;--font-b:'IBM Plex Sans',sans-serif}:global(.insurance){font-family:var(--font-b);color:#333;background:var(--cream);line-height:1.6}:global(.insurance) :focus-visible{outline:3px solid var(--gold);outline-offset:2px}.container{max-width:1100px;margin:0 auto;padding:0 24px}h1,h2{font-family:var(--font-h);font-weight:700;color:var(--navy);line-height:1.15}h1{font-size:clamp(2rem,4.5vw,3.2rem)}h2{font-size:clamp(1.5rem,3vw,2.2rem);margin-bottom:32px}
  .top-nav{background:var(--navy);padding:12px 0;position:sticky;top:0;z-index:100}.nav-inner{display:flex;justify-content:space-between;align-items:center}.top-logo{font-family:var(--font-h);font-weight:700;color:#fff;text-decoration:none;font-size:1.1rem}.top-links{display:flex;list-style:none;gap:24px;align-items:center}.top-links a{color:rgba(255,255,255,.7);text-decoration:none;font-size:.85rem}.top-links a:hover{color:#fff}.top-cta{padding:8px 20px;background:var(--gold);color:var(--navy)!important;font-weight:600}.top-cta:hover{background:#e0b84f!important;color:var(--navy)!important}
  .hero{padding:80px 0}.hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.hero-badge{font-size:.8rem;text-transform:uppercase;letter-spacing:2px;color:var(--gold);font-weight:600;margin-bottom:12px}.hero p{color:#888;font-size:1.05rem;margin-bottom:28px}.btn-primary{display:inline-block;padding:14px 32px;background:var(--navy);color:#fff;text-decoration:none;font-weight:600;transition:background .25s}.btn-primary:hover{background:#2A3F66}.rating-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.rating-pill{background:#fff;border:1px solid rgba(27,42,74,.1);padding:16px;text-align:center;font-weight:600;font-size:.9rem;color:var(--navy)}
  .plans{padding:80px 0;background:#fff}.plan-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}.plan-card{background:var(--cream);padding:28px 24px;display:flex;flex-direction:column}.plan-head{margin-bottom:16px}.plan-card h3{font-family:var(--font-h);font-size:1.1rem;color:var(--navy);margin-bottom:2px}.plan-badge{font-size:.75rem;color:var(--gold);font-weight:600;text-transform:uppercase;letter-spacing:.5px}.plan-card ul{list-style:none;padding:0;margin:0 0 20px;flex:1}.plan-card li{padding:4px 0;font-size:.85rem;color:#666;border-bottom:1px solid rgba(0,0,0,.04)}.plan-price{font-family:var(--font-h);font-weight:700;font-size:1.1rem;color:var(--navy)}
  .compare-section{padding:80px 0}.compare-table{max-width:700px;margin:0 auto}.table-row{display:grid;grid-template-columns:1.5fr 1fr 1fr;padding:14px 16px;border-bottom:1px solid rgba(0,0,0,.06);font-size:.9rem;align-items:center}.table-header{font-weight:700;color:var(--navy);border-bottom:2px solid var(--navy)}.highlight{color:var(--gold);font-weight:600}
  .quote-section{padding:80px 0;background:var(--navy)}.quote-inner{text-align:center}.quote-section h2{color:#fff}.quote-section p{color:rgba(255,255,255,.6);margin-bottom:24px}.quote-tel{display:inline-block;font-family:var(--font-h);font-size:2rem;font-weight:700;color:var(--gold);text-decoration:none}.quote-tel:hover{color:#fff}.quote-mail{display:block;margin-top:6px;color:rgba(255,255,255,.4);font-size:.9rem}
  .footer{padding:40px 0;text-align:center;color:#999;font-size:.8rem}.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}.footer a{color:#999;text-decoration:underline}
  @media(max-width:800px){.hero-inner{grid-template-columns:1fr}.plan-grid{grid-template-columns:1fr}.top-links{display:none}}
</style>
