---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Ryan Ashford | Real Estate Agent"
  description="Looking for the right home in Chicago? Get expert real estate advice and investment guidance tailored to your needs."
  themeColor="#12293D"
  bodyClass="realestate"
  consent={{ bg: "#12293D", fg: "#FAFAF8", accent: "#C1592A", accentFg: "#000000", border: "rgba(250,250,248,0.16)" }}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head">
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@500;700;900&family=Assistant:wght@300;400;600;700&display=swap" rel="stylesheet" slot="head">

  <header class="hero">
    <div class="hero-grid"></div>
    <div class="corner corner-tl"></div>
    <div class="corner corner-br"></div>

    <nav class="container nav">
      <span class="brand">Ryan Ashford</span>
      <a href="#booking" class="btn btn-cta">Schedule a Showing</a>
    </nav>

    <div class="container hero-inner">
      <p class="hero-tag">Home Sales · Investment Properties · Fast Closings</p>
      <h1 class="hero-title">The right home,<br>not just the first one you see</h1>
      <p class="hero-sub">Full support from search to keys in hand — with real data on every property, not just nice photos.</p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num">120+</span>
          <span class="hero-stat-label">Properties sold</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">14</span>
          <span class="hero-stat-label">Avg. days to close</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">0%</span>
          <span class="hero-stat-label">Hidden fees</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href="#booking" class="btn btn-primary">Let's talk about what you're looking for</a>
        <a href="#services" class="btn btn-outline">How it works</a>
      </div>
    </div>
  </header>

  <main id="main">
    <section class="why">
      <div class="container">
        <p class="section-label">Why work with me</p>
        <h2 class="section-title">Guidance without pressure, backed by real data</h2>
        <div class="why-grid">
          <div class="why-card why-card--copper">
            <h3>Real valuation, not guesswork</h3>
            <p>Price comparisons based on actual recent sales in the area, not a rough estimate.</p>
          </div>
          <div class="why-card why-card--blueprint">
            <h3>Support through closing</h3>
            <p>Negotiation, legal coordination, and support all the way to keys in hand.</p>
          </div>
          <div class="why-card why-card--steel">
            <h3>No pressure to buy</h3>
            <p>If a property isn't right, I'll tell you. Even if it means not closing a deal.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="services">
      <div class="services-grid-bg"></div>
      <div class="container services-inner">
        <p class="section-label">How it works</p>
        <h2 class="section-title">From our first call to the keys in your hand</h2>
        <div class="services-grid">
          <div class="service-card">
            <h3>Needs-based search</h3>
            <p>A short intro call to understand budget, area, and timeline.</p>
          </div>
          <div class="service-card">
            <h3>Curated shortlist</h3>
            <p>Only properties that genuinely fit, not an endless list to sift through.</p>
          </div>
          <div class="service-card">
            <h3>Scheduled showings</h3>
            <p>Showings scheduled around your time, with guidance on-site.</p>
          </div>
          <div class="service-card">
            <h3>Negotiation and closing</h3>
            <p>Support all the way through contract signing and key handover.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="booking" class="booking">
      <div class="container booking-inner">
        <p class="section-label">First step</p>
        <h2 class="section-title">Let's talk about what you're looking for</h2>
        <p class="booking-sub">Leave your details, and the message is sent straight to my WhatsApp. I'll get back to you the same day.</p>
        <form id="leadForm" class="form">
          <div class="form-group">
            <label for="name">Full name</label>
            <input required id="name" name="name" type="text" placeholder="e.g. Michelle Turner">
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <input required id="phone" name="phone" type="tel" placeholder="+1 555 123 4567">
          </div>
          <div class="form-group">
            <label for="reason">I'm looking to</label>
            <select id="reason" name="reason">
              <option>Buy a home to live in</option>
              <option>Buy an investment property</option>
              <option>Sell my current property</option>
              <option>Get a property valuation</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="area">Preferred area</label>
            <input id="area" name="area" type="text" placeholder="e.g. Downtown, West Side">
          </div>
          <button type="submit" class="btn btn-primary btn-full">Send via WhatsApp</button>
          <p class="form-note">Clicking send will open a WhatsApp chat with your message ready to go.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p>Ryan Ashford · Real Estate Agent · [License number] · [Phone]</p>
      <p class="footer-note">Sample page only — does not represent an active agent or business.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  :global(.realestate) {
    --blueprint: #12293D;
    --blueprint2: #1B3A54;
    --paper: #FAFAF8;
    --copper: #C1592A;
    --steel: #8FA6B8;
    --font-display: 'Rubik', sans-serif;
    --font-body: 'Assistant', 'Segoe UI', system-ui, sans-serif;
    font-family: var(--font-body);
    background: var(--paper);
    color: var(--blueprint);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  .container { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

  .section-label { color: var(--copper); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem; }
  .section-title { font-family: var(--font-display); font-size: 1.875rem; font-weight: 900; line-height: 1.1; margin-bottom: 3rem; max-width: 42rem; }

  .btn { display: inline-block; font-weight: 700; font-size: 0.9rem; padding: 12px 28px; transition: all 0.2s; text-align: center; }
  .btn-primary { background: var(--copper); color: #000; }
  .btn-primary:hover { background: var(--paper); color: var(--blueprint); }
  .btn-cta { background: var(--copper); color: #000; padding: 10px 20px; font-size: 0.85rem; }
  .btn-cta:hover { background: var(--paper); color: var(--blueprint); }
  .btn-outline { border: 1px solid var(--paper); color: var(--paper); }
  .btn-outline:hover { background: rgba(255,255,255,0.1); }
  .btn-full { width: 100%; }

  .hero { position: relative; background: var(--blueprint); color: var(--paper); overflow: hidden; }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(143,166,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(143,166,184,0.08) 1px, transparent 1px); background-size: 40px 40px; }
  .corner { position: absolute; width: 40px; height: 40px; border-color: var(--copper); border-style: solid; }
  .corner-tl { top: 1rem; left: 1rem; border-width: 2px 0 0 2px; }
  .corner-br { bottom: 1rem; right: 1rem; border-width: 0 2px 2px 0; }

  .nav { position: relative; display: flex; align-items: center; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 1.5rem; }
  .brand { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; }

  .hero-inner { position: relative; padding-top: 3rem; padding-bottom: 6rem; }
  .hero-tag { color: var(--copper); font-weight: 700; letter-spacing: 0.1em; font-size: 0.875rem; text-transform: uppercase; margin-bottom: 1rem; }
  .hero-title { font-family: var(--font-display); font-size: 2.25rem; font-weight: 900; line-height: 1.1; max-width: 48rem; }
  .hero-sub { margin-top: 1.5rem; font-size: 1.125rem; max-width: 36rem; line-height: 1.625; }

  .hero-stats { display: flex; gap: 0.75rem; margin-top: 2.5rem; flex-wrap: wrap; }
  .hero-stat { background: var(--blueprint2); border: 1px solid rgba(143,166,184,0.3); padding: 12px 20px; }
  .hero-stat-num { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; display: block; }
  .hero-stat-label { font-size: 0.75rem; color: var(--paper); }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.5rem; }

  .why { padding: 5rem 0; }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .why-card { padding-left: 1.25rem; border-left-width: 4px; border-left-style: solid; }
  .why-card--copper { border-color: var(--copper); }
  .why-card--blueprint { border-color: var(--blueprint); }
  .why-card--steel { border-color: var(--steel); }
  .why-card h3 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
  .why-card p { line-height: 1.625; }

  .services { position: relative; background: var(--blueprint); color: var(--paper); padding: 5rem 0; overflow: hidden; }
  .services-grid-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(143,166,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(143,166,184,0.08) 1px, transparent 1px); background-size: 40px 40px; opacity: 0.5; }
  .services-inner { position: relative; }
  .services .section-title { color: var(--paper); }
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .service-card { background: rgba(27,58,84,0.6); border: 1px solid rgba(143,166,184,0.2); padding: 1.5rem; }
  .service-card h3 { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; margin-bottom: 0.25rem; }
  .service-card p { font-size: 0.875rem; color: var(--steel); line-height: 1.625; }

  .booking { padding: 5rem 0; }
  .booking-inner { max-width: 42rem; }
  .booking-sub { margin-bottom: 2rem; }

  .form { background: #fff; padding: 1.5rem; border: 1px solid rgba(143,166,184,0.4); display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-group label { font-size: 0.875rem; font-weight: 700; margin-bottom: 0.25rem; }
  .form-group input, .form-group select { width: 100%; padding: 12px 16px; border: 1px solid rgba(143,166,184,0.4); font-family: var(--font-body); font-size: 1rem; }
  .form-group input:focus, .form-group select:focus { outline: 2px solid var(--copper); outline-offset: -2px; }
  .form-note { font-size: 0.75rem; text-align: center; }

  .footer { background: var(--blueprint); color: var(--paper); padding: 2rem 0; text-align: center; font-size: 0.875rem; }
  .footer-inner { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-note { font-size: 0.75rem; opacity: 0.6; }

  @media (min-width: 768px) {
    .hero-inner { padding-top: 4rem; padding-bottom: 8rem; }
    .hero-title { font-size: 3.75rem; }
    .corner-tl { top: 1.5rem; left: 1.5rem; }
    .corner-br { bottom: 1.5rem; right: 1.5rem; }
    .section-title { font-size: 2.25rem; }
  }

  @media (max-width: 640px) {
    .why-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .hero-stats { flex-direction: column; }
  }
</style>

<script>
(function () {
  var form = document.getElementById('leadForm');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var name = document.getElementById('name').value.trim();
    var phone = document.getElementById('phone').value.trim();
    var reason = document.getElementById('reason').value;
    var area = document.getElementById('area').value.trim();
    var msg = 'New inquiry from the website:\nName: ' + name + '\nPhone: ' + phone + '\nLooking to: ' + reason + '\nPreferred area: ' + (area || 'Not specified');
    window.open('https://wa.me/972584433181?text=' + encodeURIComponent(msg), '_blank');
  });
})();
</script>
