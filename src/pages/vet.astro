      gap: 14px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .nav-links.open { display: flex; }
    .nav-links a, .nav.scrolled .nav-links a { color: var(--brown); }
    .nav.scrolled .nav-cta { border-color: var(--sage-dark); color: var(--sage-dark) !important; }
