---
import BaseLayout from "../layouts/BaseLayout.astro";

const classes = [
  { name: "Slow Flow", level: "All levels", desc: "A grounded, breath-led practice — the class most people start with." },
  { name: "Vinyasa", level: "Intermediate", desc: "Dynamic, sweat-building sequences linked to breath." },
  { name: "Restorative", level: "All levels", desc: "Long-held, supported poses. Props provided, phones optional off." },
  { name: "Prenatal", level: "All trimesters", desc: "Small group, taught by a certified prenatal instructor." },
];

const schedule = [
  { day: "Mon", time: "6:30 AM", cls: "Vinyasa" },
  { day: "Mon", time: "6:00 PM", cls: "Slow Flow" },
  { day: "Wed", time: "9:00 AM", cls: "Restorative" },
  { day: "Fri", time: "6:30 AM", cls: "Vinyasa" },
  { day: "Sat", time: "10:00 AM", cls: "Prenatal" },
];

const pricing = [
  { name: "Drop-in", price: "$24", note: "single class" },
  { name: "Monthly", price: "$118", note: "unlimited classes" },
  { name: "10-Class Pass", price: "$195", note: "never expires" },
];
---
<BaseLayout title="Still Water Yoga | Studio Classes & Teacher-Led Practice" description="Still Water Yoga — a small studio offering vinyasa, restorative, and prenatal classes taught by a single dedicated instructor." themeColor="#EDEEE4" bodyClass="yoga" consent={{ bg: "#2F3E2E", fg: "#EDEEE4", accent: "#C68B59", accentFg: "#fff", border: "rgba(47,62,46,0.2)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500;0,600&family=Mulish:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500;0,600&family=Mulish:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500;0,600&family=Mulish:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">Still Water</a><ul class="nav-links"><li><a href="#classes">Classes</a></li><li><a href="#schedule">Schedule</a></li><li><a href="#pricing">Pricing</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <img src="https://images.pexels.com/photos/4057534/pexels-photo-4057534.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80" alt="Woman practicing a calm yoga stretch in a sunlit room" width="1600" height="1067" class="hero-bg-img" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-bg-overlay" aria-hidden="true"></div>
      <div class="ring" aria-hidden="true"></div>
      <div class="container hero-inner">
        <p class="hero-eyebrow">A one-room studio in Sellwood</p>
        <h1>Practice, <em>not</em> performance.</h1>
        <p class="hero-sub">No mirrors. No music competing with your breath. Just a quiet room and a teacher who remembers your name.</p>
        <a href="#schedule" class="btn-primary">See this week's schedule</a>
      </div>
    </section>

    <section class="philosophy">
      <div class="container">
        <blockquote>"The pose was never the point. It's what softens on the way there."</blockquote>
        <p class="philosophy-attr">— Maren Ostlund, founder & sole instructor</p>
      </div>
    </section>

    <section class="classes" id="classes">
      <div class="container">
        <p class="section-label">Classes</p>
        <div class="class-grid">
          {classes.map((c) => (
            <div class="class-card"><h3>{c.name}</h3><span class="class-level">{c.level}</span><p>{c.desc}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="schedule" id="schedule">
      <div class="container">
        <p class="section-label">This week</p>
        <h2>Five classes, one teacher.</h2>
        <table class="schedule-table">
          <thead><tr><th>Day</th><th>Time</th><th>Class</th></tr></thead>
          <tbody>{schedule.map((s) => (<tr><td>{s.day}</td><td>{s.time}</td><td>{s.cls}</td></tr>))}</tbody>
        </table>
      </div>
    </section>

    <section class="teacher">
      <div class="container teacher-inner">
        <div class="teacher-photo" aria-hidden="true"></div>
        <div>
          <p class="section-label">Your teacher</p>
          <h2>Maren Ostlund</h2>
          <p>500-hr RYT, teaching in Portland since 2016. Started this studio after ten years teaching in gyms where the classes felt more like cardio than practice — this room is the opposite of that.</p>
        </div>
      </div>
    </section>

    <section class="pricing" id="pricing">
      <div class="container">
        <p class="section-label">Pricing</p>
        <div class="price-grid">
          {pricing.map((p) => (
            <div class="price-card"><h3>{p.name}</h3><span class="price-amt">{p.price}</span><span class="price-note">{p.note}</span></div>
          ))}
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container cta-inner"><h2>First class is on us.</h2><p>New students practice free, once.</p><a href="mailto:hello@stillwateryoga.studio" class="cta-link">hello@stillwateryoga.studio</a></div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Still Water Yoga &mdash; Sellwood, Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.yoga){--sage:#EDEEE4;--forest:#2F3E2E;--clay:#C68B59;--paper:#F7F6F0;--font-h:'Cormorant Garamond',serif;--font-b:'Mulish',sans-serif}
:global(.yoga){font-family:var(--font-b);color:var(--forest);background:var(--paper);line-height:1.7}
:global(.yoga) :focus-visible{outline:2px solid var(--clay);outline-offset:2px}
.container{max-width:920px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--forest);font-weight:600}
.section-label{font-family:var(--font-h);font-style:italic;font-size:1rem;color:var(--clay);margin-bottom:8px}
h2{font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:34px}
.topnav{padding:22px 0}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);font-size:1.2rem;color:var(--forest);text-decoration:none;font-weight:600}
.nav-links{display:flex;gap:30px;list-style:none;font-size:.9rem}
.nav-links a{color:var(--forest);text-decoration:none}
.hero{position:relative;padding:60px 0 110px;text-align:center;overflow:hidden}
.hero-bg-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.3}
.hero-bg-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(247,246,240,.55),var(--paper) 90%)}
.ring{position:absolute;top:-120px;left:50%;transform:translateX(-50%);width:520px;height:520px;border:1px solid rgba(47,62,46,.14);border-radius:50%}
.hero-inner{position:relative;max-width:600px;margin:0 auto;z-index:1}
.hero-eyebrow{font-size:.8rem;text-transform:uppercase;letter-spacing:.14em;color:var(--clay);margin-bottom:26px}
h1{font-size:clamp(2.6rem,6vw,4rem);font-weight:500;line-height:1.05;margin-bottom:24px}
h1 em{color:var(--clay);font-style:italic}
.hero-sub{color:#5B5F53;font-size:1.05rem;margin-bottom:34px}
.btn-primary{display:inline-block;background:var(--forest);color:var(--sage);padding:13px 30px;text-decoration:none;font-size:.92rem;border-radius:2px}
.philosophy{padding:70px 0;background:var(--forest);text-align:center}
.philosophy blockquote{font-family:var(--font-h);font-style:italic;font-size:clamp(1.3rem,2.6vw,1.8rem);color:var(--sage);max-width:640px;margin:0 auto 18px;line-height:1.4}
.philosophy-attr{color:rgba(237,238,228,.6);font-size:.85rem}
.classes{padding:88px 0}
.class-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.class-card{background:#fff;padding:26px 20px;border:1px solid rgba(47,62,46,.08)}
.class-card h3{font-size:1.15rem;margin-bottom:4px}
.class-level{font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:var(--clay);display:block;margin-bottom:12px}
.class-card p{font-size:.85rem;color:#5B5F53}
.schedule{padding:80px 0;background:#fff}
.schedule-table{width:100%;border-collapse:collapse;max-width:520px;margin-top:10px}
.schedule-table th{text-align:left;font-family:var(--font-h);font-weight:600;color:var(--forest);padding:10px 14px;border-bottom:2px solid var(--forest);font-size:.9rem}
.schedule-table td{padding:12px 14px;border-bottom:1px solid rgba(47,62,46,.1);font-size:.92rem}
.teacher{padding:88px 0}
.teacher-inner{display:grid;grid-template-columns:200px 1fr;gap:44px;align-items:center}
.teacher-photo{width:200px;height:240px;background:linear-gradient(160deg,var(--clay),var(--forest));border-radius:2px}
.teacher-inner p{color:#5B5F53;font-size:.95rem;max-width:440px}
.pricing{padding:88px 0;background:#fff}
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.price-card{text-align:center;padding:34px 20px;border:1px solid rgba(47,62,46,.1)}
.price-card h3{font-size:1.05rem;margin-bottom:10px}
.price-amt{display:block;font-family:var(--font-h);font-size:2rem;color:var(--clay);font-weight:600}
.price-note{font-size:.8rem;color:#8A8D80}
.cta{padding:90px 0;text-align:center}
.cta p{color:#5B5F53;margin-bottom:22px}
.cta-link{font-family:var(--font-h);font-size:1.3rem;color:var(--clay);text-decoration:none}
.footer{padding:38px 0;text-align:center;color:#8A8D80;font-size:.8rem;border-top:1px solid rgba(47,62,46,.1)}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#8A8D80;text-decoration:underline}
@media(max-width:800px){.class-grid{grid-template-columns:1fr 1fr}.price-grid{grid-template-columns:1fr}.teacher-inner{grid-template-columns:1fr;text-align:center}.teacher-photo{margin:0 auto}}
</style>
