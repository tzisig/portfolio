---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  { name: "Eye Exams", desc: "Comprehensive vision and eye health exams, all ages." },
  { name: "Glasses", desc: "In-house lab, frames from $79, most orders ready in 1 hour." },
  { name: "Contact Lenses", desc: "Fittings for daily, extended wear, and specialty lenses." },
  { name: "Pediatric Care", desc: "Vision screening and exams for kids starting at age 3." },
];

const process = [
  { n: "1", t: "Book online", d: "Same-week appointments, most insurance accepted." },
  { n: "2", t: "Pre-testing", d: "Digital retinal imaging and visual field screening." },
  { n: "3", t: "Exam with doctor", d: "A full exam and conversation about your vision and eye health." },
  { n: "4", t: "Glasses or contacts", d: "Pick frames on-site or take your prescription with you." },
];

const insurance = ["VSP", "EyeMed", "Aetna", "Cigna", "Regence BlueShield", "Medicare"];
---
<BaseLayout title="Clearview Eye Care | Optometrist — Exams, Glasses & Contacts" description="Clearview Eye Care provides comprehensive eye exams, glasses, and contact lens fittings for the whole family." themeColor="#F3F8F9" bodyClass="optometrist" consent={{ bg: "#0E7C86", fg: "#F3F8F9", accent: "#16323F", accentFg: "#fff", border: "rgba(22,50,63,0.18)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">Clearview Eye Care</a><ul class="nav-links"><li><a href="#services">Services</a></li><li><a href="#insurance">Insurance</a></li><li><a href="#book" class="nav-cta">Book exam</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <div>
          <p class="hero-eyebrow">Same-week appointments &middot; Most insurance accepted</p>
          <h1>Clear vision starts with a real exam.</h1>
          <p class="hero-sub">Comprehensive eye exams, glasses, and contacts for the whole family — one visit, most of the time.</p>
          <a href="#book" class="btn-primary">Book your exam</a>
        </div>
        <div class="eye-chart" aria-hidden="true">
          <p class="chart-line l1">E</p><p class="chart-line l2">F P</p><p class="chart-line l3">T O Z</p>
          <p class="chart-line l4">L P E D</p><p class="chart-line l5">P E C F D</p>
        </div>
      </div>
    </section>

    <section class="services" id="services">
      <div class="container">
        <p class="section-label">Services</p>
        <div class="svc-grid">{services.map((s) => (<div class="svc-card"><h3>{s.name}</h3><p>{s.desc}</p></div>))}</div>
      </div>
    </section>

    <section class="process">
      <div class="container">
        <p class="section-label">Your visit</p>
        <h2>What to expect.</h2>
        <div class="step-grid">{process.map((p) => (<div class="step"><span class="step-num">{p.n}</span><h3>{p.t}</h3><p>{p.d}</p></div>))}</div>
      </div>
    </section>

    <section class="doctor">
      <div class="container doctor-inner">
        <div class="doctor-photo" aria-hidden="true"></div>
        <div>
          <p class="section-label">Your doctor</p>
          <h2>Dr. Alicia Munroe, OD</h2>
          <p>Doctor of Optometry, Pacific University. Practicing since 2011, with a focus on pediatric vision and specialty contact lens fittings for keratoconus and post-surgical patients.</p>
        </div>
      </div>
    </section>

    <section class="insurance" id="insurance">
      <div class="container">
        <p class="section-label">Insurance accepted</p>
        <div class="insurance-row">{insurance.map((i) => (<span class="insurance-chip">{i}</span>))}</div>
      </div>
    </section>

    <section class="book" id="book">
      <div class="container book-inner"><h2>Book your exam today.</h2><p>Most appointments available within the same week.</p><a href="tel:+15550177" class="book-tel">(555) 555-0177</a></div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Clearview Eye Care &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.optometrist){--teal:#0E7C86;--navy:#16323F;--bg:#F3F8F9;--white:#fff;--font-h:'Sora',sans-serif;--font-b:'IBM Plex Sans',sans-serif}
:global(.optometrist){font-family:var(--font-b);color:var(--navy);background:var(--bg);line-height:1.65}
:global(.optometrist) :focus-visible{outline:2px solid var(--teal);outline-offset:2px}
.container{max-width:1040px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--navy)}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--teal);font-weight:700;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2rem);font-weight:700;margin-bottom:32px}
.topnav{padding:18px 0;background:var(--white);border-bottom:1px solid rgba(22,50,63,.08)}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);color:var(--navy);text-decoration:none;font-weight:700}
.nav-links{display:flex;gap:24px;list-style:none;align-items:center;font-size:.88rem}
.nav-links a{color:var(--navy);text-decoration:none}
.nav-cta{background:var(--teal);color:#fff!important;padding:8px 18px;border-radius:4px;font-weight:600}
.hero{padding:70px 0 90px}
.hero-inner{display:grid;grid-template-columns:1.1fr .9fr;gap:50px;align-items:center}
.hero-eyebrow{font-size:.8rem;color:var(--teal);letter-spacing:.06em;margin-bottom:20px;font-weight:600}
h1{font-size:clamp(2.2rem,4.6vw,3.2rem);line-height:1.12;font-weight:700;margin-bottom:20px}
.hero-sub{color:#4A6570;font-size:1rem;max-width:440px;margin-bottom:30px}
.btn-primary{display:inline-block;background:var(--teal);color:#fff;padding:13px 30px;text-decoration:none;border-radius:4px;font-weight:600}
.eye-chart{background:var(--white);border-radius:8px;padding:36px 20px;text-align:center;box-shadow:0 8px 24px rgba(22,50,63,.08)}
.chart-line{font-family:var(--font-h);font-weight:700;color:var(--navy);letter-spacing:.3em}
.l1{font-size:3rem}.l2{font-size:2.2rem}.l3{font-size:1.6rem}.l4{font-size:1.2rem}.l5{font-size:.95rem;margin-bottom:0}
.services{padding:70px 0;background:var(--white)}
.svc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.svc-card{background:var(--bg);padding:24px 20px;border-radius:6px}
.svc-card h3{font-size:1rem;margin-bottom:8px}
.svc-card p{color:#4A6570;font-size:.85rem}
.process{padding:80px 0}
.step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.step-num{font-family:var(--font-h);color:var(--teal);font-size:1.5rem;font-weight:700;display:block;margin-bottom:10px}
.step h3{font-size:1rem;margin-bottom:6px}
.step p{color:#4A6570;font-size:.85rem}
.doctor{padding:80px 0;background:var(--white)}
.doctor-inner{display:grid;grid-template-columns:200px 1fr;gap:44px;align-items:center}
.doctor-photo{width:200px;height:240px;background:linear-gradient(160deg,var(--teal),var(--navy));border-radius:6px}
.doctor-inner p{color:#4A6570;font-size:.95rem;max-width:480px}
.insurance{padding:60px 0}
.insurance-row{display:flex;flex-wrap:wrap;gap:12px}
.insurance-chip{background:var(--white);border:1px solid rgba(22,50,63,.12);padding:8px 18px;border-radius:20px;font-size:.85rem;color:var(--navy)}
.book{padding:90px 0;text-align:center;background:var(--teal);color:#fff}
.book h2{color:#fff}
.book p{color:rgba(255,255,255,.8);margin-bottom:26px}
.book-tel{font-family:var(--font-h);font-size:2.2rem;font-weight:700;color:#fff;text-decoration:none}
.footer{padding:38px 0;text-align:center;color:#5C7680;font-size:.8rem;background:var(--white)}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#5C7680;text-decoration:underline}
@media(max-width:800px){.hero-inner{grid-template-columns:1fr}.svc-grid{grid-template-columns:1fr 1fr}.step-grid{grid-template-columns:1fr 1fr}.doctor-inner{grid-template-columns:1fr;text-align:center}.doctor-photo{margin:0 auto}}
</style>
