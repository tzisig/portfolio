---
import BaseLayout from "../layouts/BaseLayout.astro";
const rates = { "30yr": "6.125%", "15yr": "5.375%", "ARM": "5.875%" };
const products = [
  { title: "Conventional", desc: "Fixed-rate and adjustable-rate mortgages for primary residences, second homes, and investment properties. 3% down options available." },
  { title: "FHA Loans", desc: "Government-backed loans with 3.5% minimum down payment and flexible credit requirements. Ideal for first-time homebuyers." },
  { title: "VA Loans", desc: "Zero down payment, no PMI, and competitive rates for eligible veterans, active-duty service members, and surviving spouses." },
  { title: "Jumbo Loans", desc: "Non-conforming loans for high-balance properties exceeding conventional limits. Competitive rates and flexible underwriting." },
];
const steps = [
  { title: "Pre-Approval", desc: "We review your financial picture and issue a pre-approval letter within 24 hours so you can shop with confidence." },
  { title: "Rate Lock", desc: "We lock your rate when rates are favorable and advise on float-down options if the market moves in your direction." },
  { title: "Processing", desc: "Our in-house processing team handles the paperwork, appraisal coordination, and underwriting submission." },
  { title: "Closing", desc: "Clear, transparent closing disclosures. We sit with you at the table so there are no last-minute surprises." },
];
---
<BaseLayout title="BridgePoint Lending | Portland Mortgage Broker & Home Loans" description="BridgePoint Lending helps Oregon homebuyers find the right mortgage with access to 40+ lenders, transparent pricing, and a stress-free process." themeColor="#1A3C34" bodyClass="mortgage" consent={{ bg: "#1A3C34", fg: "#F0F4EB", accent: "#D4A843", accentFg: "#1A3C34", border: "rgba(240,244,235,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=DM+Sans:wght@400;500;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=DM+Sans:wght@400;500;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=DM+Sans:wght@400;500;700&display=swap" /></noscript>
  </slot>
  <div class="ticker" id="ticker"><div class="ticker-inner"><span class="ticker-item">Rates as of today</span><span class="ticker-item">30yr Fixed: <strong>{rates["30yr"]}</strong></span><span class="ticker-item">15yr Fixed: <strong>{rates["15yr"]}</strong></span><span class="ticker-item">7/6 ARM: <strong>{rates["ARM"]}</strong></span><span class="ticker-item">Zero points pricing &middot; No origination fees</span></div></div>
  <nav class="nav"><div class="container nav-inner"><a href="#" class="nav-logo">BridgePoint</a><ul class="nav-links"><li><a href="#products">Products</a></li><li><a href="#process">Process</a></li><li><a href="#apply" class="nav-cta">Apply Now</a></li></ul></div></nav>
  <main>
    <section class="hero"><div class="container hero-inner"><h1>Find your rate. Find your home.</h1><p>Independent mortgage broker with access to 40+ lenders. We shop your rate so you don't have to.</p><div class="hero-stats"><div class="stat-big"><span class="stat-val">40+</span><span class="stat-lbl">Lenders</span></div><div class="stat-big"><span class="stat-val">$2.1B</span><span class="stat-lbl">Funded</span></div><div class="stat-big"><span class="stat-val">4.9</span><span class="stat-lbl">Rating</span></div></div><a href="#apply" class="btn-primary">Check Your Rate</a></div></section>
    <section class="products" id="products"><div class="container"><h2>Loan products.</h2><div class="prod-grid">{products.map((p) => (<div class="prod-card"><h3>{p.title}</h3><p>{p.desc}</p></div>))}</div></div></section>
    <section class="process-section" id="process"><div class="container"><h2>From application to keys.</h2><div class="proc-flow">{steps.map((s,i) => (<div class="proc-node"><span class="proc-num">{i+1}</span><h3>{s.title}</h3><p>{s.desc}</p></div>))}</div></div></section>
    <section class="apply" id="apply"><div class="container apply-inner"><h2>Ready to get started?</h2><p>Pre-approval in 24 hours or less. No cost, no commitment.</p><a href="tel:+15550116" class="apply-tel">(555) 555-0116</a><span class="apply-mail">apply@bridgepointlending.com</span></div></section>
  </main>
  <footer class="footer"><div class="container"><p>BridgePoint Lending &mdash; NMLS #2345678 &middot; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a></nav></div></footer>
</BaseLayout>
<style>:global(.mortgage){--green:#1A3C34;--gold:#D4A843;--cream:#F0F4EB;--font-h:'Archivo',sans-serif;--font-b:'DM Sans',sans-serif}:global(.mortgage){font-family:var(--font-b);color:#333;background:#fff;line-height:1.6}:global(.mortgage) :focus-visible{outline:3px solid var(--gold);outline-offset:2px}.container{max-width:1100px;margin:0 auto;padding:0 24px}h1,h2{font-family:var(--font-h);font-weight:800;color:var(--green);line-height:1.05}h1{font-size:clamp(2.5rem,6vw,4rem);letter-spacing:-0.03em}h2{font-size:clamp(1.6rem,3.5vw,2.4rem);margin-bottom:32px}
  .ticker{background:var(--green);padding:8px 0;overflow:hidden;position:relative}.ticker-inner{display:flex;gap:40px;animation:tick 22s linear infinite;white-space:nowrap;width:max-content}@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}.ticker-item{color:rgba(255,255,255,.8);font-size:.85rem;font-weight:500;flex-shrink:0}.ticker-item strong{color:var(--gold)}
  .nav{background:var(--cream);padding:14px 0;border-bottom:1px solid rgba(26,60,52,.1)}.nav-inner{display:flex;justify-content:space-between;align-items:center}.nav-logo{font-family:var(--font-h);font-weight:800;font-size:1.2rem;color:var(--green);text-decoration:none}.nav-links{display:flex;list-style:none;gap:24px;align-items:center}.nav-links a{text-decoration:none;font-size:.85rem;color:#666;font-weight:500}.nav-links a:hover{color:var(--green)}.nav-cta{padding:8px 20px;background:var(--green);color:#fff!important;font-weight:600}.nav-cta:hover{background:#265C50!important}
  .hero{padding:80px 0;background:linear-gradient(180deg,var(--cream) 0%,#fff 100%)}.hero-inner{text-align:center;max-width:700px;margin:0 auto}.hero p{color:#888;font-size:1.1rem;margin:24px auto 40px}.hero-stats{display:flex;justify-content:center;gap:48px;margin-bottom:40px}.stat-val{display:block;font-family:var(--font-h);font-size:2.5rem;font-weight:800;color:var(--gold);line-height:1}.stat-lbl{font-size:.8rem;color:#aaa;text-transform:uppercase;letter-spacing:1px}.btn-primary{display:inline-block;padding:16px 40px;background:var(--green);color:#fff;text-decoration:none;font-weight:700;font-size:1rem;transition:background .25s}.btn-primary:hover{background:#265C50}
  .products{padding:80px 0}.prod-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}.prod-card{padding:28px 24px;border-left:4px solid var(--gold)}.prod-card h3{font-family:var(--font-h);font-size:1.1rem;font-weight:700;color:var(--green);margin-bottom:6px}.prod-card p{color:#888;font-size:.9rem;line-height:1.65}
  .process-section{padding:80px 0;background:var(--cream)}.proc-flow{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}.proc-node{text-align:center;padding:24px}.proc-num{display:flex;align-items:center;justify-content:center;width:40px;height:40px;margin:0 auto 12px;background:var(--gold);color:var(--green);font-family:var(--font-h);font-weight:800;font-size:1.1rem}.proc-node h3{font-family:var(--font-h);font-size:1rem;font-weight:700;color:var(--green);margin-bottom:4px}.proc-node p{color:#888;font-size:.85rem;line-height:1.6}
  .apply{padding:80px 0;background:var(--green)}.apply-inner{text-align:center}.apply h2{color:#fff}.apply p{color:rgba(255,255,255,.6);margin-bottom:24px}.apply-tel{font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--gold);text-decoration:none}.apply-tel:hover{color:#fff}.apply-mail{display:block;margin-top:6px;color:rgba(255,255,255,.4);font-size:.9rem}
  .footer{padding:40px 0;text-align:center;color:#999;font-size:.8rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:6px}.footer a{color:#999;text-decoration:underline}
  @media(max-width:800px){.prod-grid{grid-template-columns:1fr}.proc-flow{grid-template-columns:1fr}.hero-stats{flex-direction:column;gap:24px}}
</style>
