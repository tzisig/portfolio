---
import BaseLayout from "../layouts/BaseLayout.astro";

const stats = [
  { n: "$1,840", l: "avg. annual savings" },
  { n: "25-yr", l: "panel warranty" },
  { n: "6–9 mo", l: "typical install wait: 3 weeks" },
  { n: "30%", l: "federal tax credit" },
];

const steps = [
  { n: "1", t: "Free assessment", d: "We pull satellite data and your last 12 months of bills to size a system." },
  { n: "2", t: "Design & permits", d: "Custom layout, engineering stamp, and utility interconnection paperwork — handled for you." },
  { n: "3", t: "Install", d: "Most residential installs take 1–2 days on the roof." },
  { n: "4", t: "Activation", d: "Utility inspection, then your system goes live and starts offsetting your bill." },
];

const financing = [
  { name: "Cash purchase", desc: "Full ownership, maximum lifetime savings, eligible for the full tax credit." },
  { name: "Solar loan", desc: "$0 down options, fixed rate, you own the system from day one." },
  { name: "Lease / PPA", desc: "$0 down, fixed monthly rate, we own and maintain the system." },
];
---
<BaseLayout title="Cascade Solar | Residential Solar Installation" description="Cascade Solar designs and installs residential solar systems — free assessment, transparent financing, 25-year warranty." themeColor="#0B2545" bodyClass="solar" consent={{ bg: "#0B2545", fg: "#F5F8FC", accent: "#F4B400", accentFg: "#0B2545", border: "rgba(245,248,252,0.18)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">Cascade Solar</a><ul class="nav-links"><li><a href="#how">How it works</a></li><li><a href="#financing">Financing</a></li><li><a href="#quote" class="nav-cta">Free assessment</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-eyebrow">Serving the Pacific Northwest since 2015</p>
        <h1>Cut your power bill. Not corners.</h1>
        <p class="hero-sub">A free, no-pressure assessment tells you exactly what solar would save on your actual roof and your actual bill.</p>
        <a href="#quote" class="btn-primary">Get your free assessment</a>
      </div>
      <div class="stats-bar"><div class="container stats-inner">{stats.map((s) => (<div class="stat"><span class="stat-num">{s.n}</span><span class="stat-label">{s.l}</span></div>))}</div></div>
    </section>

    <section class="how" id="how">
      <div class="container">
        <p class="section-label">How it works</p>
        <h2>From assessment to activation.</h2>
        <div class="step-grid">
          {steps.map((s) => (<div class="step"><span class="step-num">{s.n}</span><h3>{s.t}</h3><p>{s.d}</p></div>))}
        </div>
      </div>
    </section>

    <section class="financing" id="financing">
      <div class="container">
        <p class="section-label">Financing</p>
        <h2>Three ways to go solar.</h2>
        <div class="fin-grid">
          {financing.map((f) => (<div class="fin-card"><h3>{f.name}</h3><p>{f.desc}</p></div>))}
        </div>
      </div>
    </section>

    <section class="warranty">
      <div class="container warranty-inner">
        <div>
          <p class="section-label">Backed, not just sold</p>
          <h2>25-year warranty on panels and workmanship.</h2>
          <p>If a panel underperforms or a roof penetration ever leaks, it's covered — no fine print carve-outs for "acts of installer error."</p>
        </div>
      </div>
    </section>

    <section class="quote" id="quote">
      <div class="container quote-inner">
        <h2>See your savings.</h2>
        <p>Free assessment, no obligation, usually ready within 2 business days.</p>
        <a href="tel:+15550163" class="quote-tel">(555) 555-0163</a>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Cascade Solar — NABCEP certified installers, licensed &amp; bonded</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.solar){--navy:#0B2545;--yellow:#F4B400;--white:#F5F8FC;--panel:#12335F;--font-h:'Space Grotesk',sans-serif;--font-b:'Inter',sans-serif}
:global(.solar){font-family:var(--font-b);color:var(--white);background:var(--navy);line-height:1.65}
:global(.solar) :focus-visible{outline:2px solid var(--yellow);outline-offset:2px}
.container{max-width:1080px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:#fff}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--yellow);font-weight:600;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2.1rem);font-weight:700;margin-bottom:34px}
.topnav{position:sticky;top:0;background:rgba(11,37,69,.94);backdrop-filter:blur(6px);z-index:100;padding:16px 0;border-bottom:1px solid rgba(245,248,252,.1)}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);font-weight:700;color:#fff;text-decoration:none}
.nav-links{display:flex;gap:26px;list-style:none;align-items:center;font-size:.85rem}
.nav-links a{color:var(--white);text-decoration:none}
.nav-cta{background:var(--yellow);color:var(--navy)!important;padding:8px 18px;border-radius:4px;font-weight:700}
.hero{padding:80px 0 0}
.hero-inner{max-width:620px}
.hero-eyebrow{font-size:.8rem;color:var(--yellow);letter-spacing:.06em;margin-bottom:20px}
h1{font-size:clamp(2.4rem,5.4vw,3.6rem);line-height:1.08;font-weight:700;margin-bottom:22px}
.hero-sub{color:#AAB9CC;font-size:1.02rem;margin-bottom:30px}
.btn-primary{background:var(--yellow);color:var(--navy);padding:14px 30px;text-decoration:none;font-weight:700;border-radius:4px;display:inline-block}
.stats-bar{margin-top:56px;background:var(--panel);padding:26px 0}
.stats-inner{display:grid;grid-template-columns:repeat(4,1fr);text-align:center}
.stat-num{display:block;font-family:var(--font-h);font-size:1.5rem;font-weight:700;color:var(--yellow)}
.stat-label{color:#AAB9CC;font-size:.78rem}
.how{padding:88px 0}
.step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.step-num{font-family:var(--font-h);color:var(--yellow);font-size:1.5rem;font-weight:700;display:block;margin-bottom:10px}
.step h3{font-size:1.02rem;margin-bottom:8px}
.step p{color:#AAB9CC;font-size:.85rem}
.financing{padding:80px 0;background:var(--panel)}
.fin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.fin-card{background:var(--navy);padding:26px 22px;border-radius:6px;border:1px solid rgba(245,248,252,.08)}
.fin-card h3{font-size:1.05rem;margin-bottom:10px}
.fin-card p{color:#AAB9CC;font-size:.88rem}
.warranty{padding:80px 0}
.warranty-inner p{color:#AAB9CC;max-width:520px;font-size:.95rem}
.quote{padding:90px 0;text-align:center;background:var(--panel)}
.quote p{color:#AAB9CC;margin-bottom:26px}
.quote-tel{font-family:var(--font-h);font-size:2.2rem;font-weight:700;color:var(--yellow);text-decoration:none}
.footer{padding:38px 0;text-align:center;color:#7C8CA0;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#7C8CA0;text-decoration:underline}
@media(max-width:800px){.step-grid{grid-template-columns:1fr 1fr}.fin-grid{grid-template-columns:1fr}.stats-inner{grid-template-columns:1fr 1fr}}
</style>
