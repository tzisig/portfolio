  @media (max-width: 768px) {
    .section-title { font-size: 2rem; }
    .nav-links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--black); flex-direction: column; padding: 24px; gap: 16px; border-bottom: 1px solid var(--gray-800); }
    .nav-links.active { display: flex; }
    .nav-toggle { display: flex; }
    .hero { padding: 120px 0 64px; }
    .hero-inner { grid-template-columns: 1fr; gap: 32px; }
    .hero-headline { font-size: 2rem; }
    .hero-visual { height: 240px; }
    .mobile-sticky { display: block; }
    .goals-grid { grid-template-columns: 1fr 1fr; }
    .programs-grid { grid-template-columns: 1fr; }
    .philosophy-content { grid-template-columns: 1fr; gap: 32px; }
    .progress-grid { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr; }
    .coach-inner { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }

  @media (max-width: 480px) {
    .goals-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; }
  }
</style>

<script>
(function () {
  var toggle = document.querySelector('.nav-toggle');
  var navLinks = document.querySelector('.nav-links');
  if (toggle && navLinks) {
    toggle.addEventListener('click', function () { navLinks.classList.toggle('active'); });
    document.querySelectorAll('.nav-link').forEach(function (link) {
      link.addEventListener('click', function () { navLinks.classList.remove('active'); });
    });
  }

  var goalCards = document.querySelectorAll('.goal-card');
  if (goalCards.length) {
    goalCards.forEach(function (card) {
      card.addEventListener('click', function () {
        goalCards.forEach(function (c) { c.classList.remove('selected'); });
        this.classList.add('selected');
      });
    });
  }

  var sticky = document.querySelector('.mobile-sticky');
  var contactSection = document.getElementById('contact');
  if (sticky && contactSection) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        sticky.style.display = entry.isIntersecting ? 'none' : 'block';
      });
    }, { threshold: 0.1 });
    observer.observe(contactSection);
  }

  var form = document.getElementById('consultForm');
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = document.getElementById('name').value.trim();
      var email = document.getElementById('email').value.trim();
      var phone = document.getElementById('phone').value.trim();
      var goal = document.getElementById('goal') ? document.getElementById('goal').value : '';
      var experience = document.getElementById('experience') ? document.getElementById('experience').value : '';
      var msg = document.getElementById('message') ? document.getElementById('message').value.trim() : '';

      var waMessage = 'New consultation request from the website:\nName: ' + name + '\nEmail: ' + email + '\nPhone: ' + phone + '\nGoal: ' + goal + '\nExperience level: ' + experience + '\nNotes: ' + (msg || 'None');

      window.open('https://wa.me/972584433181?text=' + encodeURIComponent(waMessage), '_blank');

      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.textContent = 'Request Sent!';
      btn.style.background = '#65a30d';
      btn.style.borderColor = '#65a30d';
      setTimeout(function () {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.style.borderColor = '';
        form.reset();
      }, 3000);
    });
  }
})();
</script>
