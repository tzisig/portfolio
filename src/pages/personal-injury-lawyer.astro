  .faq-answer p { font-size: 0.9rem; color: var(--gray-600); line-height: 1.8; margin-bottom: 0; }

  .legal-disclaimer { background: #f5f0eb; border-top: 1px solid var(--border); padding: 40px 0; }
  .disclaimer-content h3 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; color: var(--gray-500); margin-bottom: 12px; }
  .disclaimer-content p { font-size: 0.8rem; color: var(--gray-500); line-height: 1.7; margin-bottom: 0; }

  .contact-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
