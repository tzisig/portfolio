  .contact-detail-label { font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; color: var(--burgundy); }
  .contact-detail span:last-child { font-family: var(--font-body); font-size: 0.95rem; color: var(--gray-300); }
