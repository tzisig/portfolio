---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  { name: "Bath & Brush", desc: "Shampoo, blow-dry, brush-out, nail trim, ear cleaning.", price: "from $45", size: "md" },
  { name: "Full Groom", desc: "Everything in Bath & Brush plus a breed-specific cut.", price: "from $70", size: "lg" },
  { name: "Nail Trim Only", desc: "Quick in-and-out, no appointment needed most days.", price: "$18", size: "sm" },
  { name: "De-shedding Treatment", desc: "Undercoat rake and deep brush-out for heavy shedders.", price: "from $35", size: "sm" },
  { name: "Puppy's First Groom", desc: "Gentle, slow-paced introduction to the tub and dryer.", price: "from $40", size: "md" },
  { name: "Teeth Brushing", desc: "Add-on to any service.", price: "$12", size: "sm" },
];

const breeds = [
  { name: "Doodles & curly coats", note: "Specialty de-matting and scissor work" },
  { name: "Double-coated breeds", note: "Husky, Shepherd, Corgi — proper de-shedding, never shaved" },
  { name: "Small & senior dogs", note: "Extra-gentle handling, more breaks" },
];

const steps = [
  { n: "1", t: "Book online", d: "Pick a groomer, pick a time — most weeks have next-day openings." },
  { n: "2", t: "Meet & greet", d: "First-time dogs get a few extra minutes to sniff around before we start." },
  { n: "3", t: "Groom day", d: "Text updates sent partway through, plus a photo when they're done." },
  { n: "4", t: "Pickup", d: "A run-down of their coat and skin, and what to watch for before next visit." },
];

const reviews = [
  { text: "My rescue used to shake through every groom. Here, she actually wags her tail walking in now.", name: "Dana K., owner of Biscuit" },
  { text: "First groomer who's ever gotten our husky's undercoat out properly. No more shaving suggestions.", name: "Marcus T., owner of Loki" },
];
---
<BaseLayout title="Wag & Wash | Dog Grooming Studio" description="Wag & Wash is a calm, appointment-based dog grooming studio — baths, full grooms, and breed-specific care for every coat type." themeColor="#FFF7ED" bodyClass="groomer" consent={{ bg: "#2A6F63", fg: "#FFF7ED", accent: "#F2994A", accentFg: "#2A2118", border: "rgba(255,247,237,0.2)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;500;600;700&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">🐾 Wag &amp; Wash</a><ul class="nav-links"><li><a href="#services">Services</a></li><li><a href="#breeds">Coat Types</a></li><li><a href="#book" class="nav-cta">Book now</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-eyebrow">Appointment-only &middot; One dog at a time, no cage dryers</p>
        <h1>Grooming your dog<br />actually looks forward to.</h1>
        <p class="hero-sub">A calm, low-stress studio — no crowded kennels, no all-day drop-offs. In and out in one visit, with you nearby if they need you.</p>
        <a href="#book" class="btn-primary">Book an appointment</a>
      </div>
    </section>

    <section class="services" id="services">
      <div class="container">
        <p class="section-label">Services</p>
        <h2>Something for every coat.</h2>
        <div class="bento">
          {services.map((s) => (
            <div class={`bento-card size-${s.size}`}>
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
              <span class="bento-price">{s.price}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="breeds" id="breeds">
      <div class="container">
        <p class="section-label">Coat expertise</p>
        <h2>We groom the coat you actually have.</h2>
        <div class="breed-grid">
          {breeds.map((b) => (<div class="breed-card"><h3>{b.name}</h3><p>{b.note}</p></div>))}
        </div>
      </div>
    </section>

    <section class="process">
      <div class="container">
        <p class="section-label">How a visit works</p>
        <div class="step-grid">
          {steps.map((s) => (<div class="step"><span class="step-num">{s.n}</span><h3>{s.t}</h3><p>{s.d}</p></div>))}
        </div>
      </div>
    </section>

    <section class="reviews">
      <div class="container">
        <p class="section-label">From nervous dogs' owners</p>
        <div class="review-grid">
          {reviews.map((r) => (<div class="review"><p>&ldquo;{r.text}&rdquo;</p><span>— {r.name}</span></div>))}
        </div>
      </div>
    </section>

    <section class="book" id="book">
      <div class="container book-inner">
        <h2>Book your dog's next groom.</h2>
        <p>Most weeks have next-day openings.</p>
        <a href="tel:+15550212" class="book-tel">(555) 555-0212</a>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Wag &amp; Wash — Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.groomer){--teal:#2A6F63;--cream:#FFF7ED;--orange:#F2994A;--ink:#2A2118;--panel:#F0E4D3;--font-h:'Baloo 2',sans-serif;--font-b:'Nunito',sans-serif}
:global(.groomer){font-family:var(--font-b);color:var(--ink);background:var(--cream);line-height:1.65}
:global(.groomer) :focus-visible{outline:2px solid var(--orange);outline-offset:2px}
.container{max-width:1040px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--teal)}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--orange);font-weight:700;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2.1rem);font-weight:700;margin-bottom:32px}
.topnav{padding:18px 0;background:var(--teal)}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);color:var(--cream);text-decoration:none;font-weight:700;font-size:1.15rem}
.nav-links{display:flex;gap:24px;list-style:none;align-items:center;font-size:.88rem}
.nav-links a{color:var(--cream);text-decoration:none}
.nav-cta{background:var(--orange);color:var(--ink)!important;padding:8px 18px;border-radius:20px;font-weight:700}
.hero{padding:80px 0 70px;text-align:center;background:var(--teal)}
.hero-inner{max-width:640px;margin:0 auto}
.hero-eyebrow{font-size:.82rem;color:#FFD9A8;letter-spacing:.04em;margin-bottom:22px;font-weight:600}
h1{color:var(--cream);font-size:clamp(2.2rem,5vw,3.4rem);line-height:1.12;font-weight:800;margin-bottom:22px}
.hero-sub{color:rgba(255,247,237,.8);font-size:1.02rem;margin-bottom:30px}
.btn-primary{display:inline-block;background:var(--orange);color:var(--ink);padding:14px 32px;text-decoration:none;border-radius:30px;font-weight:700;font-family:var(--font-h)}
.services{padding:80px 0}
.bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:160px;gap:14px}
.bento-card{background:#fff;padding:24px;display:flex;flex-direction:column;justify-content:flex-end;border-radius:14px;box-shadow:0 2px 10px rgba(42,111,99,.08)}
.bento-card h3{font-size:1.1rem;margin-bottom:6px}
.bento-card p{color:#5C6E4E;font-size:.85rem;margin-bottom:10px}
.bento-price{font-family:var(--font-h);color:var(--orange);font-weight:700;font-size:.95rem}
.size-lg{grid-column:span 2;grid-row:span 2;background:var(--teal)}
.size-lg h3,.size-lg p{color:var(--cream)}
.size-lg p{color:rgba(255,247,237,.75)}
.size-md{grid-column:span 2;grid-row:span 1}
.size-sm{grid-column:span 1;grid-row:span 1}
.breeds{padding:80px 0;background:var(--panel)}
.breed-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.breed-card{background:#fff;padding:26px 22px;border-radius:14px}
.breed-card h3{font-size:1.05rem;margin-bottom:8px}
.breed-card p{color:#5C6E4E;font-size:.85rem}
.process{padding:80px 0}
.step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.step-num{display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:var(--orange);color:var(--ink);font-family:var(--font-h);font-weight:700;margin-bottom:12px}
.step h3{font-size:1rem;margin-bottom:6px}
.step p{color:#5C6E4E;font-size:.85rem}
.reviews{padding:80px 0;background:var(--teal)}
.reviews .section-label{color:#FFD9A8}
.review-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px}
.review p{color:var(--cream);font-size:1rem;line-height:1.6;margin-bottom:12px}
.review span{color:rgba(255,247,237,.6);font-size:.85rem}
.book{padding:90px 0;text-align:center}
.book p{color:#5C6E4E;margin-bottom:24px}
.book-tel{font-family:var(--font-h);font-size:2.1rem;font-weight:700;color:var(--orange);text-decoration:none}
.footer{padding:38px 0;text-align:center;color:#5C6E4E;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#5C6E4E;text-decoration:underline}
@media(max-width:800px){.bento{grid-template-columns:1fr 1fr}.size-lg,.size-md,.size-sm{grid-column:span 1;grid-row:span 1}.breed-grid{grid-template-columns:1fr}.step-grid{grid-template-columns:1fr 1fr}.review-grid{grid-template-columns:1fr}}
</style>
