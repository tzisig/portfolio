---
import BaseLayout from "../layouts/BaseLayout.astro";
const services = [
  { icon: "♣", title: "Garden Design", desc: "Custom planting plans, hardscape layouts, and seasonal color schemes tailored to your property's light, soil, and microclimate." },
  { icon: "♠", title: "Lawn & Turf", desc: "Sod installation, aeration, seeding, drainage correction, and organic lawn care programs for thick, healthy turf year-round." },
  { icon: "♦", title: "Hardscaping", desc: "Flagstone patios, retaining walls, gravel pathways, permeable pavers, and natural stone features that define outdoor rooms." },
  { icon: "♥", title: "Tree & Shrub Care", desc: "Pruning, planting, transplanting, and disease management for ornamental and native trees and shrubs." },
];
const process = [
  { title: "Consult", desc: "We walk your property, take measurements and photos, and discuss how you want to use your outdoor space." },
  { title: "Design", desc: "A 3D concept plan with plant selections, material samples, and a detailed timeline and cost breakdown." },
  { title: "Install", desc: "Our crew transforms your yard with minimal disruption, clean daily wrap-up, and respectful communication." },
  { title: "Grow", desc: "We provide a care calendar, first-season follow-up visits, and ongoing maintenance options so your landscape thrives." },
];
const projects = [
  { label: "Before", image: "https://images.unsplash.com/photo-1558618666-fcd25c85f82e?auto=format&fit=crop&w=800&q=80" },
  { label: "After", image: "https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?auto=format&fit=crop&w=800&q=80" },
];
---
<BaseLayout title="TerraNova Landscaping | Portland Landscape Design & Installation" description="TerraNova Landscaping designs and builds outdoor spaces that belong. Garden design, hardscaping, lawn care, and tree services in Portland." themeColor="#5B7B5A" bodyClass="landscaper" consent={{ bg: "#2D3D2C", fg: "#F5F0E8", accent: "#8B6F4E", accentFg: "#F5F0E8", border: "rgba(245,240,232,0.16)" }}>
  <slot name="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cabin:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cabin:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cabin:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <div class="topbar"><a href="#contact" class="topbar-btn">Get a Free Quote</a></div>
  <nav class="nav" id="nav">
    <div class="nav-inner"><a href="#" class="nav-logo">TerraNova</a>
      <button class="nav-toggle" id="navToggle" aria-label="Menu"><span></span><span></span><span></span></button>
      <ul class="nav-links" id="navLinks">
        <li><a href="#services">Services</a></li><li><a href="#process">Process</a></li><li><a href="#portfolio">Portfolio</a></li><li><a href="#contact" class="nav-cta">Free Quote</a></li>
      </ul>
    </div>
  </nav>
  <main id="main">
    <section class="hero">
      <div class="hero-text">
        <p class="hero-eyebrow">TerraNova Landscaping</p>
        <h1>Outdoor spaces that belong.</h1>
        <p>From bare dirt to a garden you never want to leave — we design, build, and nurture landscapes that thrive in Portland's climate.</p>
        <a href="#contact" class="btn btn-primary">Start Your Design</a>
      </div>
      <div class="hero-image"><img src="https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?auto=format&fit=crop&w=1200&q=80" alt="Lush garden landscape with native plants and stone pathway" width="1200" height="800" loading="eager" fetchpriority="high" decoding="async" /></div>
    </section>
    <section class="compare" id="portfolio">
      <div class="compare-container">
        <div class="compare-col"><span class="compare-label">Before</span><div class="compare-image"><img src={projects[0].image} alt="Overgrown yard before landscaping" loading="lazy" decoding="async" /></div></div>
        <div class="compare-divider"><span class="compare-arrow">→</span></div>
        <div class="compare-col"><span class="compare-label after">After</span><div class="compare-image"><img src={projects[1].image} alt="Same yard after landscaping transformation" loading="lazy" decoding="async" /></div></div>
      </div>
    </section>
    <section class="services" id="services">
      <div class="container">
        <h2>What we do.</h2>
        <div class="services-scroll">
          {services.map((s) => (<div class="service-pill"><span class="service-icon">{s.icon}</span><div><h3>{s.title}</h3><p>{s.desc}</p></div></div>))}
        </div>
      </div>
    </section>
    <section class="process" id="process">
      <div class="container"><h2>How we get there.</h2>
        <div class="process-strip">
          {process.map((s,i) => (<div class="process-node"><span class="process-dot">{i+1}</span><h3>{s.title}</h3><p>{s.desc}</p></div>))}
        </div>
      </div>
    </section>
    <section class="cta" id="contact">
      <div class="container cta-inner"><h2>Ready to transform your yard?</h2><p>Free on-site consultation with a detailed proposal — no obligation.</p><a href="mailto:hello@terranova-pdx.com" class="cta-btn">hello@terranova-pdx.com</a><span class="cta-phone">503.555.0140</span></div>
    </section>
  </main>
  <footer class="footer"><div class="container"><p>TerraNova Landscaping &mdash; Portland, Oregon</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>:global(.landscaper){--sage:#5B7B5A;--sage-dark:#2D3D2C;--brown:#6B5344;--cream:#F5F0E8;--font-h:'Cabin',sans-serif;--font-b:'Inter',sans-serif}:global(.landscaper){font-family:var(--font-b);color:var(--brown);background:var(--cream);line-height:1.6;font-size:1rem}:global(.landscaper) :focus-visible{outline:3px solid var(--sage);outline-offset:2px}.container{max-width:1100px;margin:0 auto;padding:0 24px}h1,h2,h3{font-family:var(--font-h);font-weight:700;color:var(--sage-dark);line-height:1.15}h1{font-size:clamp(2.5rem,6vw,4rem);letter-spacing:-0.02em}h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:20px}h3{font-size:1.15rem}.topbar{background:var(--sage-dark);text-align:center;padding:8px}.topbar-btn{color:var(--cream);text-decoration:none;font-size:.85rem;font-weight:600}.nav{position:sticky;top:0;z-index:1000;background:var(--cream);border-bottom:1px solid rgba(43,61,44,0.1)}.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;max-width:1100px;margin:0 auto}.nav-logo{font-family:var(--font-h);font-size:1.3rem;font-weight:700;color:var(--sage-dark);text-decoration:none}.nav-links{display:flex;list-style:none;gap:24px;align-items:center}.nav-links a{font-size:.9rem;font-weight:500;color:var(--brown);text-decoration:none}.nav-links a:hover{color:var(--sage)}.nav-cta{padding:8px 20px;background:var(--sage);color:var(--cream)!important;font-weight:600}.nav-cta:hover{background:var(--sage-dark)!important}.nav-toggle{display:none;background:none;border:none;cursor:pointer}.nav-toggle span{display:block;width:22px;height:2px;background:var(--brown);margin:4px 0}
  .hero{display:grid;grid-template-columns:1fr 1fr;min-height:80vh}.hero-text{padding:80px 40px;display:flex;flex-direction:column;justify-content:center}.hero-eyebrow{font-size:.8rem;text-transform:uppercase;letter-spacing:3px;color:var(--sage);margin-bottom:16px;font-weight:600}.hero p{color:#777;font-size:1.1rem;margin-bottom:32px;line-height:1.7}.hero-image{overflow:hidden}.hero-image img{width:100%;height:100%;object-fit:cover}.btn-primary{display:inline-block;padding:14px 32px;background:var(--sage-dark);color:var(--cream);text-decoration:none;font-weight:600;font-size:.95rem;transition:background .25s ease}.btn-primary:hover{background:var(--sage)}.compare{padding:80px 24px;background:var(--sage-dark)}.compare-container{display:grid;grid-template-columns:1fr auto 1fr;gap:24px;align-items:center;max-width:1000px;margin:0 auto}.compare-label{display:block;font-size:.8rem;text-transform:uppercase;letter-spacing:3px;color:rgba(245,240,232,.5);margin-bottom:12px}.compare-label.after{text-align:right}.compare-image{overflow:hidden}.compare-image img{width:100%;height:300px;object-fit:cover;display:block;filter:grayscale(.3)}.compare-arrow{font-size:2rem;color:var(--cream)}
  .services{padding:80px 0}.services-scroll{display:flex;gap:16px;overflow-x:auto;padding-bottom:16px;-webkit-overflow-scrolling:touch}.service-pill{flex-shrink:0;width:320px;background:var(--cream);border:1px solid rgba(43,61,44,.12);padding:24px;display:flex;gap:16px;align-items:flex-start}.service-icon{font-size:1.8rem;color:var(--sage);flex-shrink:0;margin-top:4px}.service-pill h3{margin-bottom:4px;font-size:1rem}.service-pill p{color:#777;font-size:.85rem;line-height:1.6}
  .process{padding:80px 0;background:#EDE8DE}.process-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}.process-dot{display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:var(--sage);color:var(--cream);font-weight:700;margin-bottom:12px}.process-node h3{margin-bottom:4px;font-size:1rem}.process-node p{color:#777;font-size:.85rem;line-height:1.6}
  .cta{padding:100px 0;background:var(--sage-dark)}.cta-inner{text-align:center}.cta h2{color:var(--cream)}.cta p{color:rgba(245,240,232,.7);font-size:1.05rem;margin-bottom:32px}.cta-btn{display:inline-block;font-family:var(--font-h);font-size:1.4rem;color:var(--cream);text-decoration:none;border-bottom:1px solid var(--cream);padding-bottom:4px}.cta-btn:hover{color:var(--sage)}.cta-phone{display:block;margin-top:12px;color:rgba(245,240,232,.4);font-size:.85rem}
  .footer{padding:40px 0;text-align:center;color:#999;font-size:.85rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:8px}.footer a{color:#999;text-decoration:underline}
  @media(max-width:800px){.hero{grid-template-columns:1fr}.hero-text{padding:60px 24px}.hero-image{height:40vh}.compare-container{grid-template-columns:1fr;gap:32px}.compare-arrow{display:none}.process-strip{grid-template-columns:1fr}.nav-links{display:none;position:absolute;top:100%;left:0;right:0;background:var(--cream);flex-direction:column;padding:16px 24px;gap:12px;box-shadow:0 4px 16px rgba(0,0,0,.08)}.nav-links.open{display:flex}.nav-toggle{display:block}}
</style>
<script>(function(){var t=document.getElementById('navToggle'),l=document.getElementById('navLinks');if(t&&l){t.addEventListener('click',function(){l.classList.toggle('open')});l.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){l.classList.remove('open')})})}})();</script>
