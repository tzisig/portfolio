  .calc-group select { font-family: var(--font-sans); font-size: 1rem; padding: 12px 16px; background: var(--gray-50); border: 2px solid var(--gray-200); color: var(--gray-800); border-radius: var(--radius-sm); transition: border-color 0.2s; cursor: pointer; }
  .calc-group select:focus { outline: none; border-color: var(--sage); }
  .calc-result { background: var(--sage-light); border-radius: var(--radius-sm); padding: 24px; text-align: center; margin-bottom: 24px; }
  .calc-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--sage); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em; }
  .calc-price { display: block; font-size: 2rem; font-weight: var(--font-bold); color: var(--gray-900); }

  .services { padding: 100px 0; background: var(--white); }
