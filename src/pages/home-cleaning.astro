  .service-icon { font-size: 1.5rem; color: var(--sage); margin-bottom: 16px; width: 48px; height: 48px; background: var(--sage-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .service-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; color: var(--gray-900); }
  .service-price { display: inline-block; font-size: 0.8rem; font-weight: 700; color: var(--sage); background: var(--sage-light); padding: 4px 12px; border-radius: 20px; margin-bottom: 16px; }
  .service-desc { font-size: 0.85rem; color: var(--gray-600); line-height: 1.6; margin-bottom: 20px; flex: 1; }
  .service-features { list-style: none; margin-bottom: 24px; }
  .service-features li { font-size: 0.8rem; color: var(--gray-700); padding: 4px 0; padding-left: 20px; position: relative; }
  .service-features li::before { content: ''; position: absolute; left: 0; top: 10px; width: 10px; height: 10px; background: var(--sage); border-radius: 50%; }

  .checklist { padding: 100px 0; background: var(--gray-50); }
  .checklist-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .checklist-item { display: flex; align-items: flex-start; gap: 16px; background: var(--white); padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow); }
  .check-icon { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: var(--sage); color: var(--white); border-radius: 50%; font-size: 0.85rem; flex-shrink: 0; }
  .checklist-item h4 { font-size: 1rem; font-weight: 700; margin-bottom: 4px; color: var(--gray-900); }
  .checklist-item p { font-size: 0.85rem; color: var(--gray-600); line-height: 1.5; }

  .how-it-works { padding: 100px 0; background: var(--white); }
  .steps { display: flex; align-items: center; gap: 32px; }
  .step { flex: 1; text-align: center; }
  .step-circle { width: 56px; height: 56px; background: var(--sage); color: var(--white); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 700; margin: 0 auto 20px; }
  .step-title { font-size: 1.15rem; font-weight: 700; margin-bottom: 12px; color: var(--gray-900); }
  .step-desc { font-size: 0.9rem; color: var(--gray-600); line-height: 1.6; max-width: 280px; margin: 0 auto; }
  .step-arrow { font-size: 1.5rem; color: var(--sage); margin-bottom: 40px; }

  .trust { padding: 100px 0; background: var(--gray-50); }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .trust-card { background: var(--white); border-radius: var(--radius); padding: 32px 24px; text-align: center; box-shadow: var(--shadow); transition: all 0.3s ease; }
  .trust-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .trust-icon { font-size: 2rem; display: block; margin-bottom: 16px; }
  .trust-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 12px; color: var(--gray-900); }
  .trust-card p { font-size: 0.85rem; color: var(--gray-600); line-height: 1.6; }

  .testimonials { padding: 100px 0; background: var(--white); }
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .testimonial-card { background: var(--gray-50); border-radius: var(--radius); padding: 32px; display: flex; flex-direction: column; box-shadow: var(--shadow); transition: box-shadow 0.3s; }
  .testimonial-card:hover { box-shadow: var(--shadow-hover); }
  .testimonial-text { font-size: 0.95rem; color: var(--gray-700); line-height: 1.7; flex: 1; margin-bottom: 24px; font-style: italic; }
  .testimonial-author { border-top: 1px solid var(--gray-200); padding-top: 16px; }
  .testimonial-name { display: block; font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; color: var(--gray-900); }
  .testimonial-role { display: block; font-size: 0.8rem; color: var(--gray-600); }

  .faq { padding: 100px 0; background: var(--gray-50); }
  .faq-list { max-width: 800px; }
  .faq-item { background: var(--white); border-radius: var(--radius-sm); margin-bottom: 12px; padding: 0 24px; box-shadow: var(--shadow); }
  .faq-question { font-size: 1rem; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; transition: color 0.2s; color: var(--gray-900); }
  .faq-question:hover { color: var(--sage); }
  .faq-question::after { content: '+'; font-size: 1.3rem; color: var(--sage); font-weight: 300; transition: transform 0.3s; }
  .faq-item[open] .faq-question::after { content: '-'; }
  .faq-answer { font-size: 0.9rem; color: var(--gray-600); line-height: 1.7; padding-bottom: 20px; max-width: 680px; }

  .quote { padding: 100px 0; background: var(--white); }
  .quote-form { max-width: 720px; margin: 0 auto; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
  .form-group { display: flex; flex-direction: column; }
  .form-group label { font-size: 0.85rem; font-weight: 600; margin-bottom: 8px; color: var(--gray-700); }
  .form-group input, .form-group select, .form-group textarea { font-family: var(--font-sans); font-size: 1rem; padding: 12px 16px; background: var(--gray-50); border: 2px solid var(--gray-200); color: var(--gray-800); border-radius: var(--radius-sm); transition: border-color 0.2s; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--sage); }
  .form-group select { cursor: pointer; }
  .form-group textarea { resize: vertical; min-height: 100px; }

  .footer { padding: 64px 0 0; background: var(--gray-50); border-top: 1px solid var(--gray-200); }
  .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; }
  .footer-brand { font-size: 1.2rem; color: var(--sage); margin-bottom: 12px; }
  .footer-col h4 { font-size: 0.9rem; font-weight: 700; margin-bottom: 16px; color: var(--gray-900); }
  .footer-col p, .footer-col a { font-size: 0.85rem; color: var(--gray-600); line-height: 1.8; display: block; text-decoration: none; }
  .footer-col a:hover { color: var(--sage); }
  .footer-bottom { border-top: 1px solid var(--gray-200); padding: 24px 0; }
  .footer-bottom p { font-size: 0.8rem; color: var(--gray-600); }

  @media (max-width: 1024px) {
    .hero-headline { font-size: 2.25rem; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .steps { flex-direction: column; gap: 16px; }
    .step-arrow { transform: rotate(90deg); margin: 0; }
  }

  @media (max-width: 768px) {
    .section-title { font-size: 1.8rem; }
    .nav-links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--white); flex-direction: column; padding: 24px; gap: 16px; border-bottom: 1px solid var(--gray-200); box-shadow: var(--shadow); }
    .nav-links.active { display: flex; }
    .nav-toggle { display: flex; }
    .hero { padding: 120px 0 64px; }
    .hero-inner { grid-template-columns: 1fr; gap: 32px; }
    .hero-headline { font-size: 2rem; }
    .hero-visual { height: 200px; }
    .mobile-sticky { display: block; }
    .calc-row { grid-template-columns: 1fr; }
    .calculator-box { padding: 32px 24px; }
    .services-grid { grid-template-columns: 1fr; }
    .checklist-grid { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .trust-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }

  @media (max-width: 480px) {
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; }
  }
</style>

<script>
(function () {
  var toggle = document.querySelector('.nav-toggle');
  var navLinks = document.querySelector('.nav-links');
  if (toggle && navLinks) {
    toggle.addEventListener('click', function () { navLinks.classList.toggle('active'); });
    document.querySelectorAll('.nav-link').forEach(function (link) {
      link.addEventListener('click', function () { navLinks.classList.remove('active'); });
    });
  }

  var homeSize = document.getElementById('homeSize');
  var serviceType = document.getElementById('serviceType');
  var calcPrice = document.getElementById('calcPrice');
  if (homeSize && serviceType && calcPrice) {
    var prices = {
      studio: { weekly: [80, 120], deep: [130, 190], movein: [150, 200], moveout: [150, 200] },
      '1br': { weekly: [100, 160], deep: [160, 240], movein: [180, 250], moveout: [180, 250] },
      '2br': { weekly: [130, 200], deep: [210, 310], movein: [230, 320], moveout: [230, 320] },
      '3br': { weekly: [170, 260], deep: [270, 400], movein: [290, 380], moveout: [290, 380] },
      '4brplus': { weekly: [210, 320], deep: [340, 480], movein: [350, 450], moveout: [350, 450] }
    };
    function updatePrice() {
      var size = homeSize.value;
      var service = serviceType.value;
      var range = prices[size] && prices[size][service];
      if (range) calcPrice.textContent = '$' + range[0] + ' \u2014 $' + range[1];
    }
    homeSize.addEventListener('change', updatePrice);
    serviceType.addEventListener('change', updatePrice);
    updatePrice();
  }

  var sticky = document.querySelector('.mobile-sticky');
  var quoteSection = document.getElementById('quote');
  if (sticky && quoteSection) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) { sticky.style.display = entry.isIntersecting ? 'none' : 'block'; });
    }, { threshold: 0.1 });
    observer.observe(quoteSection);
  }

  var form = document.getElementById('quoteForm');
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = document.getElementById('q-name').value.trim();
      var email = document.getElementById('q-email').value.trim();
      var phone = document.getElementById('q-phone').value.trim();
      var size = document.getElementById('q-size') ? document.getElementById('q-size').value : '';
      var service = document.getElementById('q-service') ? document.getElementById('q-service').value : '';
      var address = document.getElementById('q-address') ? document.getElementById('q-address').value.trim() : '';
      var notes = document.getElementById('q-notes') ? document.getElementById('q-notes').value.trim() : '';
      var waMessage = 'New quote request from the website:\nName: ' + name + '\nEmail: ' + email + '\nPhone: ' + phone + '\nHome size: ' + size + '\nService type: ' + service + '\nAddress: ' + address + '\nNotes: ' + (notes || 'None');
      window.open('https://wa.me/972584433181?text=' + encodeURIComponent(waMessage), '_blank');
      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.textContent = 'Quote Request Sent!';
      btn.style.background = '#eab308';
      btn.style.borderColor = '#eab308';
      setTimeout(function () {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.style.borderColor = '';
        form.reset();
      }, 3000);
    });
  }
})();
</script>
