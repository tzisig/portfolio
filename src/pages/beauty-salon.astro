---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Luna & Sage Studio | Hair and Beauty Salon Portland"
  description="Luna & Sage Studio offers haircuts, coloring, styling, bridal hair, and beauty treatments in Portland. Book your appointment online or visit our salon."
  themeColor="#fdf8f3"
  bodyClass="beauty-salon"
  consent={{ bg: "#3b1f2b", fg: "#dcc8d2", accent: "#a83a30", accentFg: "#FFFFFF", border: "rgba(255,255,255,0.16)" }}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" slot="head">

  <nav class="navbar">
    <div class="container nav-inner">
      <a href="#" class="nav-logo">Luna &amp; Sage Studio</a>
      <button class="nav-toggle" aria-label="Toggle navigation">&#9776;</button>
      <ul class="nav-links">
        <li><a href="#services">Services</a></li>
        <li><a href="#stylists">Stylists</a></li>
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#contact">Contact</a></li>
        <li><a href="#contact" class="nav-cta">Book Now</a></li>
      </ul>
    </div>
  </nav>

  <main id="main">
    <section class="hero">
      <div class="container hero-inner">
        <h1 class="hero-title">Hair and Beauty Services Designed Around Your Style.</h1>
        <p class="hero-subtitle">We believe every appointment should begin with a conversation. Our consultation-first approach ensures your haircut, color, or treatment is tailored exactly to your preferences, hair type, and lifestyle.</p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-terracotta">Book Your Appointment</a>
          <a href="#services" class="btn btn-outline-dark">View Services and Prices</a>
        </div>
      </div>
    </section>

    <section id="services" class="section">
      <div class="container">
        <h2 class="section-title">Services and Prices</h2>
        <p class="section-subtitle">Browse our full menu of hair and beauty services. Use the categories below to find exactly what you are looking for.</p>

        <div class="service-categories">
          <button class="cat-btn active" data-category="haircuts">Haircuts</button>
          <button class="cat-btn" data-category="coloring">Coloring</button>
          <button class="cat-btn" data-category="styling">Styling</button>
          <button class="cat-btn" data-category="bridal">Bridal</button>
          <button class="cat-btn" data-category="treatments">Treatments</button>
        </div>

        <div class="service-menu" id="service-menu">
          <div class="service-item">
            <div class="service-info">
              <h3 class="service-name">Women's Haircut</h3>
              <p class="service-desc">A precision cut tailored to your face shape, hair texture, and desired style. Includes consultation, shampoo, and blow-dry finish.</p>
            </div>
            <span class="service-price">$65+</span>
          </div>
          <div class="service-item">
            <div class="service-info">
              <h3 class="service-name">Men's Haircut</h3>
              <p class="service-desc">Classic and modern cuts for men including scissor and clipper work, neckline shaping, and style consultation.</p>
            </div>
            <span class="service-price">$55+</span>
          </div>
          <div class="service-item">
            <div class="service-info">
              <h3 class="service-name">Children's Haircut</h3>
              <p class="service-desc">Patient, gentle haircuts for children ages twelve and under in a calm and welcoming environment.</p>
            </div>
            <span class="service-price">$55+</span>
          </div>
          <div class="service-item">
            <div class="service-info">
              <h3 class="service-name">Bang Trim</h3>
              <p class="service-desc">Quick bang or fringe refresh between full haircuts.</p>
            </div>
            <span class="service-price">$18</span>
          </div>
        </div>
      </div>
    </section>

    <section id="stylists" class="section section-cream">
      <div class="container">
        <h2 class="section-title">Meet Our Stylists</h2>
        <p class="section-subtitle">Talented professionals dedicated to helping you look and feel your best.</p>
        <div class="stylists-grid">
          <div class="stylist-card">
            <div class="stylist-photo"></div>
            <h3 class="stylist-name">Sage Moreno</h3>
            <span class="stylist-role">Owner &amp; Lead Stylist</span>
            <p class="stylist-bio">With over fifteen years in the industry, Sage founded Luna &amp; Sage Studio to create a salon experience centered on genuine connection and exceptional craftsmanship. She specializes in precision haircuts, lived-in color, and textured styles that move with you.</p>
          </div>
          <div class="stylist-card">
            <div class="stylist-photo"></div>
            <h3 class="stylist-name">Luna Park</h3>
            <span class="stylist-role">Color Specialist</span>
            <p class="stylist-bio">Luna brings a decade of color expertise to every appointment. Her work ranges from subtle balayage and sun-kissed highlights to vivid fashion colors and corrective color. She is known for her meticulous technique and ability to translate inspiration photos into wearable results.</p>
          </div>
          <div class="stylist-card">
            <div class="stylist-photo"></div>
            <h3 class="stylist-name">Jordan Bell</h3>
            <span class="stylist-role">Bridal &amp; Beauty Specialist</span>
            <p class="stylist-bio">Jordan heads our bridal and occasion styling services. She is skilled in updos, curls, braiding, and formal styling for weddings, proms, and special events. Her calm presence and attention to detail make her a favorite among brides and their parties.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="gallery" class="section">
      <div class="container">
        <h2 class="section-title">Before and After</h2>
        <p class="section-subtitle">Real transformations from our studio. Every client brings their own vision, and we bring it to life.</p>
        <div class="gallery-grid">
          <div class="gallery-item">
            <img src="/beauty-salon/beauty1.webp" alt="Before and after haircut transformation" width="400" height="500" loading="lazy">
            <span class="gallery-label">Classic Bob</span>
          </div>
          <div class="gallery-item">
            <img src="/beauty-salon/beauty2.webp" alt="Before and after balayage transformation" width="400" height="500" loading="lazy">
            <span class="gallery-label">Balayage</span>
          </div>
          <div class="gallery-item">
            <img src="/beauty-salon/beauty3.webp" alt="Before and after bridal updo transformation" width="400" height="500" loading="lazy">
            <span class="gallery-label">Bridal Updo</span>
          </div>
          <div class="gallery-item">
            <img src="/beauty-salon/beauty4.webp" alt="Before and after color correction transformation" width="400" height="500" loading="lazy">
            <span class="gallery-label">Color Correction</span>
          </div>
        </div>
      </div>
    </section>

    <section id="process" class="section section-cream">
      <div class="container">
        <h2 class="section-title">What to Expect</h2>
        <p class="section-subtitle">Your experience at Luna &amp; Sage Studio is crafted from start to finish.</p>
        <div class="process-grid">
          <div class="process-card">
            <span class="process-icon">&#x1f4ad;</span>
            <h3>Consultation</h3>
            <p>We begin every appointment with a thorough consultation. We listen to your ideas, assess your hair, and discuss what is achievable. No appointment starts without us being on the same page.</p>
          </div>
          <div class="process-card">
            <span class="process-icon">&#x2728;</span>
            <h3>The Experience</h3>
            <p>Sit back and enjoy the process. Our studio is designed for relaxation with comfortable seating, good music, and products that smell as good as they feel. We take our time so you leave feeling renewed.</p>
          </div>
          <div class="process-card">
            <span class="process-icon">&#x1f9f4;</span>
            <h3>Aftercare</h3>
            <p>Before you leave, we walk you through how to maintain your look at home. We recommend products suited to your hair type and show you styling techniques so your results last as long as possible.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="atmosphere" class="section">
      <div class="container">
        <h2 class="section-title">Our Studio</h2>
        <p class="section-subtitle">A space designed for creativity and comfort.</p>
        <div class="atmosphere-content">
          <p>Luna &amp; Sage Studio is located in the heart of Portland, housed in a light-filled space with exposed brick, warm wood tones, and curated greenery. Every station is set up for both stylist comfort and client relaxation.</p>
          <p>We use professional-grade products from Oribe, Davines, and KEVIN.MURPHY, chosen for their performance, ingredient quality, and commitment to sustainability. Our commitment extends to eco-friendly practices including low-waste color services and recyclable packaging.</p>
          <p>Whether you are visiting for a quick trim or a full transformation, you will find a salon that values your time, your vision, and your trust.</p>
        </div>
      </div>
    </section>

    <section id="testimonials" class="section section-cream">
      <div class="container">
        <h2 class="section-title">What Our Guests Say</h2>
        <div class="testimonials-grid">
          <div class="testimonial-card">
            <p class="testimonial-text">"Sage gave me the best haircut I have ever had. She listened to exactly what I wanted and offered suggestions I never would have considered. The space is gorgeous and the whole experience felt luxurious without being pretentious."</p>
            <p class="testimonial-author">— Elena R.</p>
          </div>
          <div class="testimonial-card">
            <p class="testimonial-text">"I was nervous about going blonde after years of dark hair, but Luna walked me through every step. My color turned out beautifully natural and my hair actually feels healthier than before. I am a client for life."</p>
            <p class="testimonial-author">— Dani S.</p>
          </div>
          <div class="testimonial-card">
            <p class="testimonial-text">"Jordan styled my entire wedding party and handled everything with such grace. My bridal updo stayed perfect through photos, dinner, and dancing. Every single person in my group looked and felt amazing."</p>
            <p class="testimonial-author">— Maya T.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question">Do I need to book in advance?</button>
            <div class="faq-answer">We recommend booking at least one week in advance, especially for color services and weekend appointments. Bridal consultations should be scheduled four to six weeks before your event. We do accept walk-ins when availability allows, but appointments receive priority.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question">What if I do not know what style I want?</button>
            <div class="faq-answer">That is completely normal. We specialize in helping clients discover what works for them. Bring photos of styles you are drawn to, or simply describe how you want to feel. Our stylists will guide the consultation with professional recommendations based on your face shape, hair type, and maintenance preferences.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question">Do you carry specific product lines?</button>
            <div class="faq-answer">Yes. We carry Oribe, Davines, and KEVIN.MURPHY products in the studio. Our stylists will recommend the best products for your specific hair needs after your service. We also offer take-home travel sizes so you can try products before committing to full sizes.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question">Can I bring photos for reference?</button>
            <div class="faq-answer">Absolutely. We encourage clients to bring reference photos. They are incredibly helpful for communicating what you are envisioning. We review photos together during the consultation and discuss what elements will work best for your hair type and how to adapt the look to suit you.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question">What is your cancellation policy?</button>
            <div class="faq-answer">We require 24 hours notice for cancellations or rescheduling. Appointments canceled with less than 24 hours notice or missed entirely are subject to a fifty percent service charge. We understand that emergencies happen and handle these situations on a case-by-case basis.</div>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="section section-cream">
      <div class="container">
        <h2 class="section-title">Book Your Appointment</h2>
        <p class="section-subtitle">Fill out the form below and we will confirm your appointment within 24 hours. Walk-ins are also welcome based on availability.</p>
        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="form-name">Name</label>
              <input type="text" id="form-name" name="name" required>
            </div>
            <div class="form-group">
              <label for="form-email">Email</label>
              <input type="email" id="form-email" name="email" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="form-phone">Phone</label>
              <input type="tel" id="form-phone" name="phone" required>
            </div>
            <div class="form-group">
              <label for="form-category">Service Category</label>
              <select id="form-category" name="category">
                <option value="haircuts">Haircuts</option>
                <option value="coloring">Coloring</option>
                <option value="styling">Styling</option>
                <option value="bridal">Bridal Hair</option>
                <option value="treatments">Beauty Treatments</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="form-service">Specific Service</label>
              <select id="form-service" name="service">
                <option value="womens-cut">Women's Haircut</option>
                <option value="mens-cut">Men's Haircut</option>
                <option value="color-full">Full Color</option>
                <option value="color-highlights">Highlights</option>
                <option value="color-balayage">Balayage</option>
                <option value="styling-blowout">Blowout</option>
                <option value="styling-updo">Updo</option>
                <option value="bridal-consult">Bridal Consultation</option>
                <option value="bridal-day">Wedding Day Styling</option>
                <option value="treatment-deep">Deep Conditioning</option>
                <option value="treatment-facial">Facial</option>
              </select>
            </div>
            <div class="form-group">
              <label for="form-stylist">Preferred Stylist</label>
              <select id="form-stylist" name="stylist">
                <option value="any">No Preference</option>
                <option value="sage">Sage Moreno</option>
                <option value="luna">Luna Park</option>
                <option value="jordan">Jordan Bell</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="form-date">Preferred Date</label>
              <input type="date" id="form-date" name="date">
            </div>
            <div class="form-group">
              <label for="form-time">Preferred Time</label>
              <input type="time" id="form-time" name="time">
            </div>
          </div>
          <div class="form-group">
            <label for="form-notes">Notes</label>
            <textarea id="form-notes" name="notes" rows="4" placeholder="Tell us about what you are looking for, any inspiration ideas, or special requests."></textarea>
          </div>
          <button type="submit" class="btn btn-terracotta">Submit and Book</button>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-col">
        <h3>Luna &amp; Sage Studio</h3>
        <p>120 Style Avenue<br>Portland, OR 97201</p>
      </div>
      <div class="footer-col">
        <h3>Contact</h3>
        <p>Phone: 555-0191<br>Email: hello@lunaandsage.com</p>
      </div>
      <div class="footer-col">
        <h3>Hours</h3>
        <p>Tue–Sat: 10:00 AM – 7:00 PM<br>Sun: 11:00 AM – 5:00 PM<br>Closed Monday</p>
      </div>
    </div>
  </footer>

  <a href="#contact" class="mobile-sticky">Book Now</a>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "HairSalon", "BeautySalon"],
    "name": "Luna & Sage Studio",
    "image": "",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "120 Style Avenue",
      "addressLocality": "Portland",
      "addressRegion": "OR",
      "postalCode": "97201",
      "addressCountry": "US"
    },
    "telephone": "555-0191",
    "email": "hello@lunaandsage.com",
    "openingHoursSpecification": [
      {"@type": "OpeningHoursSpecification", "dayOfWeek": ["Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "10:00", "closes": "19:00"},
      {"@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "11:00", "closes": "17:00"}
    ],
    "areaServed": "Portland",
    "priceRange": "$$$"
  }
  </script>
</BaseLayout>

<style>
  :global(.beauty-salon) {
    --plum: #3b1f2b;
    --plum-rgb: 59, 31, 43;
    --terracotta: #a83a30;
    --terracotta-hover: #963127;
    --cream: #fdf8f3;
    --muted-pink: #6b4a5a;
    --text-body: #4a3340;
    --border-pink: #dcc8d2;
    --border-light: #e8dce2;
    --card-border: #f0e6eb;
    --white: #ffffff;
    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    font-family: var(--font-body);
    color: var(--plum);
    line-height: 1.7;
    background: var(--white);
    -webkit-font-smoothing: antialiased;
  }

  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  h1, h2, h3, h4 { font-family: var(--font-heading); }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .section { padding: 80px 0; }
  .section-cream { background: var(--cream); }
  .section-title {
    font-family: var(--font-heading); font-size: 2.6rem; font-weight: 700; color: var(--plum);
    text-align: center; margin-bottom: 12px; letter-spacing: -0.01em;
  }
  .section-subtitle {
    font-size: 1.05rem; color: var(--muted-pink);
    text-align: center; max-width: 640px; margin: 0 auto 48px; line-height: 1.7;
  }

  .btn {
    display: inline-block; padding: 14px 32px; font-size: 1rem;
    font-weight: 600; border-radius: 50px; transition: all 0.25s ease;
    cursor: pointer; border: none; text-align: center;
  }
  .btn-terracotta { background: var(--terracotta); color: #fff; }
  .btn-terracotta:hover { background: var(--terracotta-hover); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(168,58,48,0.25); }
  .btn-outline-dark { background: transparent; color: var(--plum); border: 2px solid var(--plum); }
  .btn-outline-dark:hover { background: var(--plum); color: #fff; }

  .navbar { background: var(--cream); padding: 16px 0; position: sticky; top: 0; z-index: 100; border-bottom: 1px solid rgba(59,31,43,0.06); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: var(--font-heading); font-size: 1.55rem; font-weight: 700; color: var(--plum); letter-spacing: -0.01em; }
  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-links a { color: var(--plum); font-size: 0.92rem; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--terracotta); }
  .nav-cta { background: var(--terracotta); color: #fff !important; padding: 8px 20px; border-radius: 50px; font-weight: 600; font-size: 0.9rem; }
  .nav-cta:hover { background: #b8453a !important; }
  .nav-toggle { display: none; background: none; border: none; color: var(--plum); font-size: 1.5rem; cursor: pointer; }

  .hero { background: var(--cream); padding: 210px 0 200px; }
  .hero-inner { text-align: center; max-width: 780px; }
  .hero-title { font-size: 3rem; font-weight: 700; color: var(--plum); line-height: 1.15; margin-bottom: 20px; letter-spacing: -0.02em; }
  .hero-subtitle { font-size: 1.1rem; color: var(--muted-pink); line-height: 1.7; margin-bottom: 36px; }
  .hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  .service-categories { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
  .cat-btn { padding: 10px 28px; border: 1px solid var(--border-pink); border-radius: 50px; background: #fff; font-size: 0.92rem; font-weight: 500; color: var(--plum); cursor: pointer; transition: all 0.2s; }
  .cat-btn:hover { border-color: var(--terracotta); color: var(--terracotta); }
  .cat-btn.active { background: var(--terracotta); color: #fff; border-color: var(--terracotta); }
  .service-menu { max-width: 700px; margin: 0 auto; }
  .service-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 20px 0; border-bottom: 1px solid var(--border-light); }
  .service-item:last-child { border-bottom: none; }
  .service-info { flex: 1; padding-right: 24px; }
  .service-name { font-size: 1.25rem; font-weight: 600; color: var(--plum); margin-bottom: 4px; }
  .service-desc { font-size: 0.9rem; color: var(--muted-pink); line-height: 1.6; }
  .service-price { font-size: 1.2rem; font-weight: 700; color: var(--terracotta); white-space: nowrap; padding-top: 2px; }

  .stylists-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 28px; }
  .stylist-card { background: #fff; border-radius: 16px; padding: 36px 24px 32px; text-align: center; box-shadow: 0 4px 20px rgba(var(--plum-rgb),0.04); border: 1px solid var(--card-border); transition: transform 0.25s, box-shadow 0.25s; }
  .stylist-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(var(--plum-rgb),0.06); }
  .stylist-photo { width: 120px; height: 120px; border-radius: 60px; background: var(--border-light); margin: 0 auto 20px; }
  .stylist-name { font-size: 1.4rem; font-weight: 700; color: var(--plum); margin-bottom: 4px; }
  .stylist-role { font-size: 0.85rem; color: var(--terracotta); font-weight: 600; display: block; margin-bottom: 14px; text-transform: uppercase; letter-spacing: 0.04em; }
  .stylist-bio { font-size: 0.92rem; color: var(--muted-pink); line-height: 1.7; }

  .gallery-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16px; }
  .gallery-item { position: relative; border-radius: 12px; overflow: hidden; }
  .gallery-item img { width: 100%; height: 320px; object-fit: cover; transition: transform 0.4s ease; }
  .gallery-item:hover img { transform: scale(1.05); }
  .gallery-label { position: absolute; bottom: 0; left: 0; right: 0; padding: 12px 16px; background: linear-gradient(transparent, rgba(var(--plum-rgb),0.7)); color: #fff; font-size: 0.9rem; font-weight: 600; }

  .process-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 28px; }
  .process-card { text-align: center; padding: 28px 20px; }
  .process-icon { font-size: 2.2rem; display: block; margin-bottom: 16px; }
  .process-card h3 { font-size: 1.35rem; font-weight: 700; color: var(--plum); margin-bottom: 10px; }
  .process-card p { font-size: 0.93rem; color: var(--muted-pink); line-height: 1.7; }

  .atmosphere-content { max-width: 760px; margin: 0 auto; }
  .atmosphere-content p { font-size: 1.02rem; color: var(--text-body); line-height: 1.8; margin-bottom: 20px; }

  .testimonials-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
  .testimonial-card { background: #fff; border-radius: 16px; padding: 28px 24px; border: 1px solid var(--card-border); }
  .testimonial-text { font-size: 0.95rem; color: var(--text-body); line-height: 1.7; font-style: italic; margin-bottom: 16px; }
  .testimonial-author { font-size: 0.9rem; color: var(--terracotta); font-weight: 600; }

  .faq-list { max-width: 760px; margin: 0 auto; }
  .faq-item { border-bottom: 1px solid var(--border-light); }
  .faq-question { width: 100%; background: none; border: none; padding: 20px 0; font-size: 1.05rem; font-weight: 600; color: var(--plum); text-align: left; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 1.3rem; color: var(--terracotta); transition: transform 0.2s; }
  .faq-item.open .faq-question::after { content: '\2212'; }
  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; padding: 0; color: var(--muted-pink); line-height: 1.7; }
  .faq-item.open .faq-answer { max-height: 400px; padding: 0 0 20px; }

  .contact-form { max-width: 700px; margin: 0 auto; background: #fff; padding: 40px 36px; border-radius: 16px; box-shadow: 0 4px 24px rgba(var(--plum-rgb),0.04); border: 1px solid var(--card-border); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; font-size: 0.88rem; font-weight: 600; color: var(--plum); margin-bottom: 6px; }
  .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px 14px; border: 1px solid var(--border-pink); border-radius: 8px; font-size: 0.95rem; font-family: inherit; color: var(--plum); background: #fff; transition: border-color 0.2s; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--terracotta); box-shadow: 0 0 0 3px rgba(168,58,48,0.1); }
  .contact-form .btn { width: 100%; margin-top: 8px; }

  .footer { background: var(--plum); color: var(--border-pink); padding: 48px 0 40px; }
  .footer-inner { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px; }
  .footer-col h3 { color: var(--cream); font-size: 1.15rem; margin-bottom: 12px; font-weight: 700; }
  .footer-col p { font-size: 0.9rem; line-height: 1.7; }

  .mobile-sticky { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--terracotta); color: #fff; text-align: center; padding: 14px; font-weight: 700; font-size: 1rem; z-index: 200; }

  @media (max-width: 900px) {
    .stylists-grid, .testimonials-grid, .process-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    .footer-inner { grid-template-columns: 1fr; text-align: center; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; flex-direction: column; background: var(--cream); position: absolute; top: 60px; left: 0; right: 0; padding: 16px 24px; gap: 16px; border-bottom: 1px solid rgba(59,31,43,0.06); }
    .nav-links.open { display: flex; }
    .nav-toggle { display: block; }
    .hero-title { font-size: 2.2rem; }
    .form-row { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-item img { height: 260px; }
    .mobile-sticky { display: block; }
  }
</style>

<script>
(function () {
  var serviceData = {
    haircuts: [
      { name: "Women's Haircut", desc: 'A precision cut tailored to your face shape, hair texture, and desired style. Includes consultation, shampoo, and blow-dry finish.', price: '$65+' },
      { name: "Men's Haircut", desc: 'Classic and modern cuts for men including scissor and clipper work, neckline shaping, and style consultation.', price: '$55+' },
      { name: "Children's Haircut", desc: 'Patient, gentle haircuts for children ages twelve and under in a calm and welcoming environment.', price: '$55+' },
      { name: 'Bang Trim', desc: 'Quick bang or fringe refresh between full haircuts.', price: '$18' }
    ],
    coloring: [
      { name: 'Full Color', desc: 'Single-process permanent or demi-permanent color applied from root to tip for rich, even coverage.', price: '$85+' },
      { name: 'Highlights', desc: 'Hand-painted or foil highlights for natural dimension and brightness. Customizable to any level of coverage.', price: '$110+' },
      { name: 'Balayage', desc: 'Freehand painting technique that creates soft, sun-kissed highlights with a natural grow-out.', price: '$150+' },
      { name: 'Color Correction', desc: 'Corrective color service for previous dye mishaps, uneven color, or unwanted tones. Consultation required.', price: '$180+' },
      { name: 'Root Touch-Up', desc: 'Quick root coverage between full color appointments. Matches your existing formula.', price: '$75+' }
    ],
    styling: [
      { name: 'Blowout', desc: 'Professional blow-dry and style using round brushes and product for a smooth, voluminous finish.', price: '$45+' },
      { name: 'Updo', desc: 'Elegant updo styling for special occasions including weddings, proms, and formal events.', price: '$75+' },
      { name: 'Curls and Waves', desc: 'Heat-styled curls or soft waves created with professional tools and techniques.', price: '$55+' },
      { name: 'Braiding', desc: 'Custom braided styles from simple French braids to intricate fishtail and Dutch braid designs.', price: '$50+' }
    ],
    bridal: [
      { name: 'Bridal Consultation', desc: 'A dedicated appointment to discuss your wedding hair vision, trial styles, and create a plan for your big day.', price: '$50' },
      { name: 'Bridal Hair Trial', desc: 'Full trial run of your wedding hairstyle so you can see the look before the day. Includes one revision appointment.', price: '$85' },
      { name: 'Wedding Day Styling', desc: 'On-location or in-salon styling for the bride. Includes trial and final styling on your wedding day.', price: '$250+' },
      { name: 'Bridal Party Package', desc: 'Hair styling for the bride plus up to four bridal party members. Includes trial for the bride.', price: '$500+' },
      { name: 'Mother of the Bride/Groom', desc: 'Styling for mothers of the couple. Consultation included to coordinate with the bridal look.', price: '$75+' }
    ],
    treatments: [
      { name: 'Deep Conditioning Treatment', desc: 'Intensive moisture treatment with steam and professional-grade masque to restore softness and shine.', price: '$35+' },
      { name: 'Keratin Smoothing Treatment', desc: 'Smoothing treatment that reduces frizz and curl for up to three months. Leaves hair silky and manageable.', price: '$150+' },
      { name: 'Scalp Therapy', desc: 'Soothing scalp treatment for dryness, flaking, or sensitivity. Includes exfoliation and nourishing serum.', price: '$45+' },
      { name: 'Express Facial', desc: 'Quick cleansing facial with gentle exfoliation, mask, and moisturizer for a fresh, glowing complexion.', price: '$55+' }
    ]
  };

  var menu = document.getElementById('service-menu');
  var catBtns = document.querySelectorAll('.cat-btn');

  function renderCategory(category) {
    var items = serviceData[category] || [];
    menu.innerHTML = items.map(function (item) {
      return '<div class="service-item"><div class="service-info"><h3 class="service-name">' + item.name + '</h3><p class="service-desc">' + item.desc + '</p></div><span class="service-price">' + item.price + '</span></div>';
    }).join('');
  }

  catBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var category = btn.getAttribute('data-category');
      catBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      requestAnimationFrame(function () { renderCategory(category); });
    });
  });

  var toggleBtn = document.querySelector('.nav-toggle');
  var navLinks = document.querySelector('.nav-links');
  if (toggleBtn && navLinks) {
    toggleBtn.addEventListener('click', function () { navLinks.classList.toggle('open'); });
    navLinks.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () { navLinks.classList.remove('open'); });
    });
  }

  document.querySelectorAll('.faq-question').forEach(function (q) {
    q.addEventListener('click', function () { this.parentElement.classList.toggle('open'); });
  });

  var form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = document.getElementById('form-name').value.trim();
      var email = document.getElementById('form-email').value.trim();
      var phone = document.getElementById('form-phone').value.trim();
      var category = document.getElementById('form-category') ? document.getElementById('form-category').value : '';
      var service = document.getElementById('form-service') ? document.getElementById('form-service').value : '';
      var stylist = document.getElementById('form-stylist') ? document.getElementById('form-stylist').value : '';
      var date = document.getElementById('form-date') ? document.getElementById('form-date').value : '';
      var time = document.getElementById('form-time') ? document.getElementById('form-time').value : '';
      var notes = document.getElementById('form-notes') ? document.getElementById('form-notes').value.trim() : '';

      var message = 'New booking request from the website:\nName: ' + name + '\nEmail: ' + email + '\nPhone: ' + phone + '\nCategory: ' + category + '\nService: ' + service + '\nPreferred stylist: ' + stylist + '\nDate: ' + date + '\nTime: ' + time + '\nNotes: ' + (notes || 'None');

      window.open('https://wa.me/972584433181?text=' + encodeURIComponent(message), '_blank');
      alert('Thank you for booking with Luna & Sage Studio. We will confirm your appointment within 24 hours. We look forward to seeing you!');
      form.reset();
    });
  }
})();
</script>
