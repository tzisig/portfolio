---
import BaseLayout from "../layouts/BaseLayout.astro";

const process = [
  { n: "01", t: "Book", d: "Get a flat quote online in under 2 minutes — no in-home visit required for most moves." },
  { n: "02", t: "Pack", d: "Optional full-pack service, or we bring boxes and you pack at your own pace." },
  { n: "03", t: "Load", d: "A trained 2–4 person crew arrives on time, wraps furniture, and loads with a plan." },
  { n: "04", t: "Deliver", d: "Same-day for local moves. Everything placed exactly where you tell the crew." },
];

const services = [
  { name: "Local moves", desc: "Same-day moves within the metro area, flat hourly rate." },
  { name: "Long-distance", desc: "Interstate moves with binding not-to-exceed quotes." },
  { name: "Packing", desc: "Full or partial packing service, all materials included." },
  { name: "Storage", desc: "Climate-controlled storage, month-to-month, no long lease." },
];

const stats = [
  { n: "14,000+", l: "moves completed" },
  { n: "4.9★", l: "average rating, 2,100+ reviews" },
  { n: "0", l: "hidden fees — flat quotes, always" },
];
---
<BaseLayout title="Steadfast Movers | Local & Long-Distance Moving Company" description="Steadfast Movers — local and long-distance moving, packing, and storage. Flat quotes, trained crews, no hidden fees." themeColor="#1F2933" bodyClass="moving" consent={{ bg: "#1F2933", fg: "#F5F5F5", accent: "#FF6B35", accentFg: "#fff", border: "rgba(245,245,245,0.18)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">STEADFAST</a><ul class="nav-links"><li><a href="#services">Services</a></li><li><a href="#process">How it works</a></li><li><a href="#quote" class="nav-cta">Get a quote</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <h1>Moving, without<br />the moving-day chaos.</h1>
        <p class="hero-sub">Flat-rate local and long-distance moves. Trained crews, real quotes, zero surprise fees on the invoice.</p>
        <div class="hero-actions"><a href="#quote" class="btn-primary">Get a flat quote</a><a href="tel:+15550156" class="btn-ghost">or call (555) 555-0156</a></div>
      </div>
      <div class="stats-bar"><div class="container stats-inner">{stats.map((s) => (<div class="stat"><span class="stat-num">{s.n}</span><span class="stat-label">{s.l}</span></div>))}</div></div>
    </section>

    <section class="process" id="process">
      <div class="container">
        <p class="section-label">How it works</p>
        <h2>Four steps, no guesswork.</h2>
        <div class="process-track">
          {process.map((p, i) => (
            <div class="process-node">
              <span class="node-num">{p.n}</span>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
              {i < process.length - 1 && <span class="node-line" aria-hidden="true"></span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="services" id="services">
      <div class="container">
        <p class="section-label">Services</p>
        <div class="svc-grid">
          {services.map((s) => (<div class="svc-card"><h3>{s.name}</h3><p>{s.desc}</p></div>))}
        </div>
      </div>
    </section>

    <section class="area">
      <div class="container area-inner">
        <div>
          <p class="section-label">Service area</p>
          <h2>Based in Portland, moving up and down the coast.</h2>
          <p>Local moves anywhere in the metro area. Long-distance runs cover OR, WA, and CA on a regular schedule — ask about your route.</p>
        </div>
      </div>
    </section>

    <section class="quote" id="quote">
      <div class="container quote-inner">
        <h2>Get your flat quote.</h2>
        <p>Takes under 2 minutes. No in-home visit needed for most local moves.</p>
        <a href="tel:+15550156" class="quote-tel">(555) 555-0156</a>
        <span class="quote-mail">quotes@steadfastmovers.com</span>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Steadfast Movers — Licensed &amp; insured, DOT #883421</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.moving){--charcoal:#1F2933;--orange:#FF6B35;--white:#F5F5F5;--panel:#28333F;--font-h:'Archivo',sans-serif;--font-b:'Inter',sans-serif}
:global(.moving){font-family:var(--font-b);color:var(--white);background:var(--charcoal);line-height:1.65}
:global(.moving) :focus-visible{outline:2px solid var(--orange);outline-offset:2px}
.container{max-width:1080px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:#fff}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--orange);font-weight:700;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2.1rem);font-weight:800;margin-bottom:34px}
.topnav{position:sticky;top:0;background:rgba(31,41,51,.94);backdrop-filter:blur(6px);z-index:100;padding:16px 0;border-bottom:1px solid rgba(245,245,245,.1)}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);font-weight:900;letter-spacing:.05em;color:#fff;text-decoration:none}
.nav-links{display:flex;gap:26px;list-style:none;align-items:center;font-size:.85rem}
.nav-links a{color:var(--white);text-decoration:none}
.nav-cta{background:var(--orange);color:#fff!important;padding:8px 18px;border-radius:4px;font-weight:700}
.hero{padding:80px 0 0}
.hero-inner{max-width:640px}
h1{font-size:clamp(2.4rem,5.6vw,3.8rem);line-height:1.05;font-weight:900;margin-bottom:22px}
.hero-sub{color:#B0B8BF;font-size:1.05rem;margin-bottom:32px}
.hero-actions{display:flex;align-items:center;gap:22px;flex-wrap:wrap}
.btn-primary{background:var(--orange);color:#fff;padding:14px 30px;text-decoration:none;font-weight:700;border-radius:4px}
.btn-ghost{color:var(--white);text-decoration:none;border-bottom:1px solid rgba(245,245,245,.3);padding-bottom:2px;font-size:.92rem}
.stats-bar{margin-top:56px;background:var(--panel);padding:26px 0}
.stats-inner{display:grid;grid-template-columns:repeat(3,1fr);text-align:center}
.stat-num{display:block;font-family:var(--font-h);font-size:1.8rem;font-weight:900;color:var(--orange)}
.stat-label{color:#B0B8BF;font-size:.8rem}
.process{padding:88px 0}
.process-track{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
.process-node{position:relative}
.node-num{font-family:var(--font-h);font-size:1.3rem;font-weight:900;color:var(--orange);display:block;margin-bottom:12px}
.process-node h3{font-size:1.05rem;margin-bottom:8px}
.process-node p{color:#B0B8BF;font-size:.85rem}
.node-line{position:absolute;top:12px;left:calc(100% + 2px);width:calc(24px - 4px);height:2px;background:rgba(255,107,53,.4)}
.services{padding:80px 0;background:var(--panel)}
.svc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.svc-card{background:var(--charcoal);padding:24px 20px;border-radius:6px}
.svc-card h3{font-size:1rem;margin-bottom:8px}
.svc-card p{color:#B0B8BF;font-size:.85rem}
.area{padding:80px 0}
.area-inner p{color:#B0B8BF;max-width:520px;font-size:.95rem}
.quote{padding:90px 0;text-align:center;background:var(--panel)}
.quote p{color:#B0B8BF;margin-bottom:26px}
.quote-tel{display:block;font-family:var(--font-h);font-size:2.4rem;font-weight:900;color:var(--orange);text-decoration:none}
.quote-mail{color:#B0B8BF;font-size:.85rem}
.footer{padding:38px 0;text-align:center;color:#8A939B;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#8A939B;text-decoration:underline}
@media(max-width:800px){.process-track{grid-template-columns:1fr 1fr}.node-line{display:none}.svc-grid{grid-template-columns:1fr 1fr}.stats-inner{grid-template-columns:1fr}}
</style>
