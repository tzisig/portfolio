---
import BaseLayout from "../layouts/BaseLayout.astro";

const occasions = [
  { name: "Weddings", desc: "Bridal bouquets, arches, and reception centerpieces designed around your palette.", size: "lg" },
  { name: "Everyday", desc: "Grab-and-go bouquets, restocked daily.", size: "sm" },
  { name: "Sympathy", desc: "Same-day delivery for arrangements and standing sprays.", size: "md" },
  { name: "Corporate", desc: "Weekly lobby arrangements and event florals for offices.", size: "sm" },
  { name: "Proposals", desc: "Custom installations for the big ask.", size: "sm" },
];

const plans = [
  { name: "Weekly", price: "$45/wk", desc: "A fresh small arrangement every week, delivered." },
  { name: "Bi-weekly", price: "$55/2wk", desc: "Slightly larger arrangement, every other week." },
  { name: "Monthly", price: "$85/mo", desc: "One statement arrangement, once a month." },
];

const process = [
  { t: "Order", d: "Online, by phone, or in the shop — occasion, budget, and any color notes." },
  { t: "Design", d: "Cut and arranged the same day, using what's freshest from that morning's market run." },
  { t: "Deliver", d: "Local delivery by 2pm for same-day orders placed before 11am." },
];
---
<BaseLayout title="Marigold & Fern | Florist — Weddings, Everyday & Same-Day Delivery" description="Marigold & Fern is a full-service florist offering wedding florals, everyday bouquets, sympathy arrangements, and flower subscriptions." themeColor="#F7F1EC" bodyClass="florist" consent={{ bg: "#5C6E4E", fg: "#F7F1EC", accent: "#C98A96", accentFg: "#2F3A28", border: "rgba(247,241,236,0.2)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Work+Sans:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Work+Sans:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Work+Sans:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">Marigold &amp; Fern</a><ul class="nav-links"><li><a href="#occasions">Shop</a></li><li><a href="#subscriptions">Subscriptions</a></li><li><a href="#order" class="nav-cta">Order flowers</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <img src="https://images.pexels.com/photos/6912873/pexels-photo-6912873.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80" alt="Florist in an apron arranging a fresh sunflower bouquet" width="1600" height="1067" class="hero-bg-img" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-bg-overlay" aria-hidden="true"></div>
      <div class="container hero-inner">
        <span class="season-badge">In season now: dahlias &amp; ranunculus</span>
        <h1>Flowers, cut this morning.</h1>
        <p class="hero-sub">A neighborhood flower shop doing weddings, everyday bouquets, and same-day delivery across the city.</p>
        <a href="#occasions" class="btn-primary">Shop by occasion</a>
      </div>
    </section>

    <section class="occasions" id="occasions">
      <div class="container">
        <p class="section-label">Shop by occasion</p>
        <div class="bento">
          {occasions.map((o) => (
            <div class={`bento-card size-${o.size}`}><h3>{o.name}</h3><p>{o.desc}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="process">
      <div class="container">
        <p class="section-label">How it works</p>
        <div class="process-row">
          {process.map((p, idx) => (
            <div class="process-step"><span class="process-dot">{idx + 1}</span><h3>{p.t}</h3><p>{p.d}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="subscriptions" id="subscriptions">
      <div class="container">
        <p class="section-label">Subscriptions</p>
        <h2>Standing fresh flowers, no reordering.</h2>
        <div class="plan-grid">
          {plans.map((p) => (
            <div class="plan-card"><h3>{p.name}</h3><span class="plan-price">{p.price}</span><p>{p.desc}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="quote">
      <div class="container">
        <blockquote>"They read the room every single time — the arrangement always matches exactly what the day needed."</blockquote>
        <p class="quote-attr">— Renata P., wedding client</p>
      </div>
    </section>

    <section class="order" id="order">
      <div class="container order-inner"><h2>Order flowers today.</h2><p>Same-day delivery for orders placed before 11am.</p><a href="tel:+15550199" class="order-tel">(555) 555-0199</a></div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Marigold &amp; Fern &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.florist){--blush:#F7F1EC;--moss:#5C6E4E;--rose:#C98A96;--ink:#2F3A28;--font-h:'Cormorant Garamond',serif;--font-b:'Work Sans',sans-serif}
:global(.florist){font-family:var(--font-b);color:var(--ink);background:var(--blush);line-height:1.65}
:global(.florist) :focus-visible{outline:2px solid var(--rose);outline-offset:2px}
.container{max-width:1040px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--moss)}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--rose);font-weight:600;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2rem);font-weight:600;margin-bottom:30px}
.topnav{padding:20px 0}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);font-size:1.3rem;color:var(--moss);text-decoration:none;font-weight:600}
.nav-links{display:flex;gap:24px;list-style:none;align-items:center;font-size:.88rem}
.nav-links a{color:var(--ink);text-decoration:none}
.nav-cta{background:var(--moss);color:var(--blush)!important;padding:8px 18px;border-radius:20px}
.hero{padding:60px 0 90px;text-align:center;position:relative;overflow:hidden}
.hero-bg-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.32}
.hero-bg-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(247,241,236,.5),var(--blush) 88%)}
.hero-inner{max-width:620px;margin:0 auto;position:relative;z-index:1}
.season-badge{display:inline-block;background:var(--rose);color:#3A2229;font-size:.78rem;padding:6px 16px;border-radius:20px;margin-bottom:24px;font-weight:600}
h1{font-size:clamp(2.6rem,6vw,4rem);font-weight:600;line-height:1.05;margin-bottom:20px}
.hero-sub{color:#6B7660;font-size:1.02rem;margin-bottom:30px}
.btn-primary{background:var(--moss);color:var(--blush);padding:13px 30px;text-decoration:none;border-radius:30px;font-weight:600}
.occasions{padding:70px 0}
.bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:150px;gap:14px}
.bento-card{background:#fff;padding:24px;display:flex;flex-direction:column;justify-content:flex-end;border-radius:4px}
.bento-card h3{font-size:1.15rem;margin-bottom:6px}
.bento-card p{color:#6B7660;font-size:.85rem}
.size-lg{grid-column:span 2;grid-row:span 2;background:linear-gradient(160deg,var(--rose),var(--moss));}
.size-lg h3,.size-lg p{color:#fff}
.size-md{grid-column:span 2;grid-row:span 1}
.size-sm{grid-column:span 1;grid-row:span 1}
.process{padding:70px 0;background:#fff}
.process-row{display:grid;grid-template-columns:repeat(3,1fr);gap:30px}
.process-dot{display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:var(--rose);color:#3A2229;font-family:var(--font-h);font-weight:600;margin-bottom:14px}
.process-step h3{font-size:1.05rem;margin-bottom:8px}
.process-step p{color:#6B7660;font-size:.88rem}
.subscriptions{padding:80px 0}
.plan-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.plan-card{background:#fff;padding:30px 24px;text-align:center;border-radius:4px}
.plan-card h3{font-size:1.1rem;margin-bottom:8px}
.plan-price{display:block;font-family:var(--font-h);font-size:1.6rem;color:var(--rose);font-weight:600;margin-bottom:12px}
.plan-card p{color:#6B7660;font-size:.85rem}
.quote{padding:70px 0;text-align:center;background:var(--moss)}
.quote blockquote{font-family:var(--font-h);font-style:italic;font-size:clamp(1.2rem,2.4vw,1.6rem);color:var(--blush);max-width:640px;margin:0 auto 16px}
.quote-attr{color:rgba(247,241,236,.6);font-size:.85rem}
.order{padding:90px 0;text-align:center}
.order p{color:#6B7660;margin-bottom:22px}
.order-tel{font-family:var(--font-h);font-size:2rem;color:var(--rose);font-weight:600;text-decoration:none}
.footer{padding:38px 0;text-align:center;color:#6B7660;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#6B7660;text-decoration:underline}
@media(max-width:800px){.bento{grid-template-columns:1fr 1fr}.size-lg,.size-md,.size-sm{grid-column:span 1;grid-row:span 1}.process-row{grid-template-columns:1fr}.plan-grid{grid-template-columns:1fr}}
</style>
