---
import BaseLayout from "../layouts/BaseLayout.astro";
const services = [
  { title: "Acknowledgments", desc: "Standard notarial acknowledgment for deeds, contracts, powers of attorney, and other legal documents requiring signature verification." },
  { title: "Jurats", desc: "Administering oaths and affirmations for affidavits, depositions, sworn statements, and other verified documents." },
  { title: "Copy Certifications", desc: "Certified true copies of passports, diplomas, licenses, and other original documents where certified copies are required." },
  { title: "Loan Signings", desc: "Mortgage and refinance document signing services with experienced loan signing agent. Weekend appointments available." },
  { title: "Estate Documents", desc: "Wills, trusts, living wills, and advance directive notarization. We can travel to your home or care facility for estate planning signings." },
  { title: "Mobile & Travel", desc: "We come to you — your home, office, hospital, or care facility. No extra charge for travel within the Portland metro area." },
];
const seals = ["Commissioned in Oregon", "$15 per signature (OR max)", "Mobile service included", "Weekend & evening hours", "Notary bond insured", "Member NNA"];
const reviews = [
  { text: "I needed three documents notarized on a Sunday. She met me at a coffee shop, was professional and efficient, and explained every form before I signed. Will absolutely use again.", name: "Hannah W." },
  { text: "We used Pacific Notary for our mortgage signing. She arrived early, walked through every page, and the whole process took 25 minutes. Flawless.", name: "Rebecca & Jason L." },
];
const fees = [
  { doc: "Acknowledgments", fee: "$15" },
  { doc: "Jurat / Oath", fee: "$15" },
  { doc: "Copy Certification", fee: "$15" },
  { doc: "Loan Signing", fee: "$125+" },
  { doc: "Mobile Visit", fee: "Included" },
  { doc: "Travel (per mile)", fee: "$0" },
];
---
<BaseLayout title="Pacific Notary Services | Portland Mobile Notary Public" description="Pacific Notary Services provides professional mobile notary services in Portland — acknowledgments, jurats, loan signings, and estate documents. Weekend appointments available." themeColor="#1B2A4A" bodyClass="notary" consent={{ bg: "#1B2A4A", fg: "#F5F0E0", accent: "#C9A96E", accentFg: "#1B2A4A", border: "rgba(245,240,224,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Source+Sans+3:wght@400;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Source+Sans+3:wght@400;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Source+Sans+3:wght@400;600;700&display=swap" /></noscript>
  </slot>
  <div class="document-bg"></div>
  <main class="doc-content">
    <section class="hero"><div class="container hero-inner"><div class="seal">✧</div><h1>Pacific Notary Services</h1><p class="hero-sub">Mobile notary public serving the Portland metro area. Commissioned, bonded, and insured. I come to you.</p><div class="hero-seals">{seals.map((s) => (<span class="seal-item">{s}</span>))}</div><a href="tel:+15550121" class="hero-btn">(555) 555-0121</a></div></section>
    <section class="services-section"><div class="container"><h2>Notarial Acts</h2><div class="svc-grid">{services.map((s) => (<div class="svc-card"><h3>{s.title}</h3><p>{s.desc}</p></div>))}</div></div></section>
    <section class="fees-section"><div class="container"><h2>Fees (OR maximums)</h2><div class="fee-table"><div class="fee-row fee-header"><span>Service</span><span>Fee</span></div>{fees.map((f) => (<div class="fee-row"><span>{f.doc}</span><span class="fee-amt">{f.fee}</span></div>))}</div></div></section>
    <section class="reviews"><div class="container"><div class="review-strip">{reviews.map((r) => (<div class="r-card"><p>"{r.text}"</p><strong>{r.name}</strong></div>))}</div></div></section>
    <section class="cta"><div class="container cta-inner"><p class="cta-seal">✧</p><h2>Available today.</h2><p class="cta-sub">Text or call for same-day appointments. Evening and weekend hours always available.</p><a href="sms:+15550121" class="cta-btn">Text (555) 555-0121</a></div></section>
  </main>
  <footer class="footer"><div class="container"><p>Pacific Notary Services &mdash; Portland, OR &middot; Commission #987654</p><nav><a href="/privacy">Privacy</a></nav></div></footer>
</BaseLayout>
<style>:global(.notary){--navy:#1B2A4A;--gold:#C9A96E;--cream:#F5F0E0;--font-h:'Lora',Georgia,serif;--font-b:'Source Sans 3',sans-serif;--font:'Source Sans 3',sans-serif}:global(.notary){font-family:var(--font);color:#333;background:var(--cream);line-height:1.6;position:relative}:global(.notary) :focus-visible{outline:3px solid var(--gold);outline-offset:2px}.container{max-width:900px;margin:0 auto;padding:0 28px}h1{font-family:var(--font-h);font-size:clamp(2rem,5vw,3.2rem);font-weight:700;color:var(--navy);line-height:1.15;margin-bottom:12px}h2{font-family:var(--font-h);font-size:clamp(1.3rem,3vw,1.8rem);font-weight:600;color:var(--navy);margin-bottom:28px;border-bottom:2px solid var(--gold);padding-bottom:8px;display:inline-block}.document-bg{position:fixed;inset:0;background-image:radial-gradient(circle at 20% 30%,rgba(201,169,110,.05) 0%,transparent 60%);pointer-events:none;z-index:0}.doc-content{position:relative;z-index:1}
  .hero{padding:80px 0 60px;text-align:center}.seal{font-size:4rem;color:var(--gold);line-height:1;margin-bottom:16px}.hero-sub{color:#888;font-size:1.05rem;max-width:500px;margin:0 auto 32px}.hero-seals{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:32px}.seal-item{background:rgba(201,169,110,.12);padding:6px 16px;font-size:.8rem;color:var(--navy);font-weight:600;border:1px solid rgba(201,169,110,.25)}.hero-btn{display:inline-block;font-family:var(--font-h);font-size:1.6rem;color:var(--gold);text-decoration:none;border-bottom:2px solid var(--gold);padding-bottom:4px}.hero-btn:hover{color:var(--navy);border-color:var(--navy)}
  .services-section{padding:60px 0}.svc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}.svc-card{padding:24px;background:#fff;border:1px solid rgba(27,42,74,.08)}.svc-card h3{font-family:var(--font-h);font-size:1rem;font-weight:600;color:var(--navy);margin-bottom:4px}.svc-card p{color:#888;font-size:.85rem;line-height:1.6}
  .fees-section{padding:60px 0;background:#fff}.fee-table{max-width:500px;margin:0 auto}.fee-row{display:flex;justify-content:space-between;padding:10px 16px;border-bottom:1px solid rgba(0,0,0,.06);font-size:.9rem}.fee-header{font-weight:700;color:var(--navy);border-bottom:2px solid var(--navy)}.fee-amt{font-weight:600;color:var(--gold)}
  .reviews{padding:60px 0}.review-strip{display:grid;grid-template-columns:1fr 1fr;gap:24px}.r-card{padding:24px;background:#fff;border-left:2px solid var(--gold)}.r-card p{font-style:italic;color:#666;font-size:.9rem;margin-bottom:8px}.r-card strong{font-size:.85rem;color:var(--navy)}
  .cta{padding:80px 0;background:var(--navy);text-align:center}.cta-seal{font-size:2.5rem;color:var(--gold);display:block;margin-bottom:8px}.cta h2{color:#fff;border-bottom:none;display:block}.cta-sub{color:rgba(255,255,255,.5);font-size:.95rem;margin-bottom:32px}.cta-btn{display:inline-block;padding:14px 36px;background:var(--gold);color:var(--navy);text-decoration:none;font-weight:700;font-size:1rem;transition:background .25s}.cta-btn:hover{background:#d4b87a}
  .footer{padding:40px 0;text-align:center;color:#bbb;font-size:.8rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:6px}.footer a{color:#bbb;text-decoration:underline}
  @media(max-width:800px){.svc-grid{grid-template-columns:1fr}.review-strip{grid-template-columns:1fr}}
</style>
