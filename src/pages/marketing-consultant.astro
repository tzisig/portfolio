---
import BaseLayout from "../layouts/BaseLayout.astro";
const metrics = [
  { val: "340%", label: "Average traffic increase" },
  { val: "8.2x", label: "Average ROI on ad spend" },
  { val: "120+", label: "Campaigns managed" },
  { val: "4.9", label: "Client satisfaction score" },
];
const services = [
  { title: "GO-TO-MARKET STRATEGY", desc: "Positioning, messaging, channel selection, and launch sequencing for new products, brands, and market expansions." },
  { title: "CONTENT & SEO", desc: "SEO-optimized content systems that build topical authority, drive organic traffic, and convert readers into leads." },
  { title: "PAID MEDIA", desc: "Meta, Google, LinkedIn, and programmatic campaigns managed with continuous A/B testing, creative refresh, and ROAS optimization." },
  { title: "BRAND STRATEGY", desc: "Brand architecture, visual identity, voice & tone, and narrative development for companies ready to stop blending in." },
];
const logos = ["Ventra", "Pinecone", "Luminate", "Atlas", "Northlight", "BridgePoint"];
---
<BaseLayout title="BrightBox Marketing — Portland Strategy, Content & Paid Media Agency" description="BrightBox Marketing helps B2B and DTC companies grow with data-driven strategy, content that ranks, and paid media that converts." themeColor="#6C3FB5" bodyClass="marketer" consent={{ bg: "#6C3FB5", fg: "#F5F0FF", accent: "#FF5A1F", accentFg: "#FFFFFF", border: "rgba(245,240,255,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <main>
    <section class="hero"><div class="container"><h1 class="hero-mega">GROW<br />FASTER.</h1><p class="hero-sub">BrightBox Marketing builds growth engines for B2B and DTC companies — with strategy, content, and paid media that actually produce numbers you can point to.</p>
      <div class="hero-metrics">{metrics.map((m) => (<div class="hero-metric"><span class="hero-val">{m.val}</span><span class="hero-label">{m.label}</span></div>))}</div>
      <a href="#contact" class="btn-primary">↳ Start a conversation</a></div></section>
    <section class="logos"><div class="container logos-inner"><p>Trusted by</p><div class="logo-strip">{logos.map((l) => (<span class="logo-item">{l}</span>))}</div></div></section>
    <section class="services" id="services"><div class="container"><h2>Services</h2><div class="srv-grid">{services.map((s,i) => (<div class="srv-card" style={`--idx:${i}`}><span class="srv-num">{String(i+1).padStart(2,'0')}</span><h3>{s.title}</h3><p>{s.desc}</p></div>))}</div></div></section>
    <section class="manifesto"><div class="container"><blockquote class="manifesto-quote">"Marketing isn't about being louder. It's about being clearer, braver, and more consistent than everyone else in the room."</blockquote></div></section>
    <section class="contact" id="contact"><div class="container contact-inner"><h2>Let's build something that works.</h2><p>Free 30-minute strategy call. No pitch, just ideas.</p><a href="mailto:grow@brightboxmarketing.com" class="contact-btn">grow@brightboxmarketing.com →</a></div></section>
  </main>
  <footer class="footer"><div class="container"><p>BrightBox Marketing &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a></nav></div></footer>
</BaseLayout>
<style>:global(.marketer){--purple:#6C3FB5;--orange:#FF5A1F;--white:#FFFFFF;--gray:#F8F7FC;--font:'Inter',sans-serif}:global(.marketer){font-family:var(--font);color:#222;background:var(--white);line-height:1.6}:global(.marketer) :focus-visible{outline:3px solid var(--orange);outline-offset:2px}.container{max-width:1100px;margin:0 auto;padding:0 24px}h2{font-size:clamp(1.5rem,3vw,2.2rem);font-weight:800;color:#222;margin-bottom:32px}
  .hero{padding:100px 0 60px;background:linear-gradient(135deg,var(--purple) 0%,#4A2780 100%);overflow:hidden;position:relative}.hero-mega{font-size:clamp(4rem,12vw,10rem);font-weight:900;color:#fff;line-height:.85;letter-spacing:-0.06em;margin-bottom:24px}.hero-sub{color:rgba(255,255,255,.7);font-size:1.1rem;max-width:560px;margin-bottom:48px}.hero-metrics{display:flex;gap:40px;margin-bottom:40px}.hero-metric{text-align:center}.hero-val{display:block;font-size:2.2rem;font-weight:900;color:var(--orange);line-height:1}.hero-label{font-size:.75rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:1px}.btn-primary{display:inline-block;padding:14px 32px;background:var(--orange);color:#fff;text-decoration:none;font-weight:700;font-size:.95rem;transition:background .25s}.btn-primary:hover{background:#e04a10}
  .logos{padding:40px 0;background:var(--gray)}.logos-inner{display:flex;align-items:center;gap:32px;flex-wrap:wrap}.logos-inner p{font-weight:700;color:#aaa;font-size:.85rem;text-transform:uppercase;letter-spacing:2px}.logo-strip{display:flex;gap:32px;flex-wrap:wrap}.logo-item{font-weight:800;color:#ccc;font-size:1.3rem;letter-spacing:-0.03em}
  .services{padding:80px 0}.srv-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:2px solid #222}.srv-card{padding:32px 28px;border-bottom:1px solid rgba(0,0,0,.08);border-right:1px solid rgba(0,0,0,.08);position:relative}.srv-card:nth-child(even){border-right:none}.srv-num{font-size:.75rem;font-weight:700;color:var(--orange);display:block;margin-bottom:6px}.srv-card h3{font-size:.85rem;font-weight:700;letter-spacing:2px;margin-bottom:8px}.srv-card p{color:#888;font-size:.85rem;line-height:1.65}
  .manifesto{padding:80px 0;background:var(--purple)}.manifesto-quote{font-size:clamp(1.4rem,3vw,2.2rem);font-weight:800;color:#fff;line-height:1.3;max-width:800px;margin:0 auto;text-align:center}
  .contact{padding:100px 0}.contact-inner{text-align:center}.contact h2{margin-bottom:12px}.contact p{color:#888;margin-bottom:32px}.contact-btn{display:inline-block;font-size:1.3rem;font-weight:700;color:var(--purple);text-decoration:none;border-bottom:2px solid var(--purple);padding-bottom:4px;transition:color .2s}.contact-btn:hover{color:var(--orange);border-color:var(--orange)}
  .footer{padding:40px 0;text-align:center;color:#aaa;font-size:.8rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:6px}.footer a{color:#aaa;text-decoration:underline}
  @media(max-width:800px){.hero-metrics{flex-wrap:wrap;gap:24px}.srv-grid{grid-template-columns:1fr}.srv-card:nth-child(even){border-right:none}.logos-inner{flex-direction:column;align-items:flex-start;gap:16px}}
</style>
