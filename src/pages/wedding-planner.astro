---
import BaseLayout from "../layouts/BaseLayout.astro";
const packages = [
  { name: "Day-Of Coordination", price: "$2,400", desc: "Timeline management, vendor check-in, on-site troubleshooting, and tear-down. Perfect for couples who've planned the details but want a pro running the day." },
  { name: "Partial Planning", price: "$4,800", desc: "Venue sourcing, vendor recommendations, budget tracking, design consultation, plus full day-of coordination. Starts 4 months out." },
  { name: "Full Planning", price: "$8,200", desc: "Every detail from concept to send-off. Venue scouting, contract negotiation, design & styling, rehearsal direction, full wedding weekend management." },
];
const gallery = [
  "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=600&q=80",
  "https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?auto=format&fit=crop&w=600&q=80",
  "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&w=600&q=80",
  "https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=600&q=80",
  "https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=600&q=80",
  "https://images.unsplash.com/photo-1464697565481-6262f3c0d50c?auto=format&fit=crop&w=600&q=80",
];
const slides = [
  "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1800&q=80",
  "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&w=1800&q=80",
  "https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?auto=format&fit=crop&w=1800&q=80",
];
---
<BaseLayout title="Bellwether Events | Portland Wedding Planning & Design" description="Bellwether Events plans and designs weddings that feel deeply personal, beautifully considered, and joyfully executed. Portland wedding planner." themeColor="#4A2C3A" bodyClass="wedding-planner" consent={{ bg: "#4A2C3A", fg: "#F5EDED", accent: "#C9A96E", accentFg: "#4A2C3A", border: "rgba(245,237,237,0.16)" }}>
  <slot name="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Karla:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Karla:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Karla:wght@400;500;600;700&display=swap" /></noscript>
  </slot>
  <div class="slideshow" id="slideshow">
    {slides.map((s,i) => (<div class="slide" style={`background-image:url(${s})`} data-index={i}></div>))}
    <div class="slideshow-overlay"></div>
    <div class="slideshow-content"><p class="slideshow-eyebrow">Bellwether Events</p><h1>Your day, perfectly orchestrated.</h1><p>Full-service wedding planning and design for couples who want every detail considered and every moment celebrated.</p><a href="#contact" class="btn-slide">Let's talk</a></div>
    <button class="slide-nav slide-nav--prev" id="slidePrev" aria-label="Previous">‹</button>
    <button class="slide-nav slide-nav--next" id="slideNext" aria-label="Next">›</button>
    <div class="slide-dots" id="slideDots">{slides.map((_,i) => (<span class="dot" data-index={i}></span>))}</div>
  </div>
  <nav class="float-nav" id="floatNav"><a href="#" class="float-logo">Bellwether</a>
    <ul><li><a href="#packages">Packages</a></li><li><a href="#gallery">Gallery</a></li><li><a href="#contact">Contact</a></li></ul>
  </nav>
  <main>
    <section class="intro"><div class="container"><h2>We believe a wedding should feel like the two of you &mdash; not a template.</h2><p>Whether it's an intimate elopement in the Columbia Gorge or a 200-guest celebration at a downtown Portland venue, we approach every wedding with the same care, creativity, and obsessive attention to detail. We take the stress so you can take the joy.</p></div></section>
    <section class="packages" id="packages"><div class="container"><h2>Packages</h2><div class="pkg-grid">{packages.map((p) => (<div class="pkg-card"><h3>{p.name}</h3><span class="pkg-price">{p.price}</span><p>{p.desc}</p></div>))}</div></div></section>
    <section class="gallery-section" id="gallery"><div class="container"><h2>Moments we've helped create.</h2></div>
      <div class="gallery-masonry">{gallery.map((g) => (<img src={g} alt="" loading="lazy" decoding="async" />))}</div>
    </section>
    <section class="contact-section" id="contact"><div class="container contact-inner"><h2>Ready to begin?</h2><p>Let's grab coffee (or tea) and talk about your vision. No obligation, just a conversation about what matters to you.</p><a href="mailto:hello@bellwetterevents.com" class="contact-link">hello@bellwetterevents.com</a></div></section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Bellwether Events &mdash; Portland Wedding Planning &amp; Design</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a></nav></div></footer>
</BaseLayout>
<style>:global(.wedding-planner){--plum:#4A2C3A;--blush:#E8C4C4;--gold:#C9A96E;--cream:#FDF8F4;--font-h:'Cormorant Garamond',Georgia,serif;--font-b:'Karla',sans-serif}:global(.wedding-planner){font-family:var(--font-b);color:#333;background:var(--cream);line-height:1.6}:global(.wedding-planner) :focus-visible{outline:3px solid var(--gold);outline-offset:2px}.container{max-width:1100px;margin:0 auto;padding:0 24px}h2{font-family:var(--font-h);font-size:clamp(2rem,4.5vw,3rem);font-weight:600;color:var(--plum);margin-bottom:24px;line-height:1.2}
  .slideshow{position:relative;height:100vh;overflow:hidden}.slide{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 1.2s ease}.slide.active{opacity:1}.slideshow-overlay{position:absolute;inset:0;background:linear-gradient(rgba(74,44,58,.6),rgba(74,44,58,.3))}.slideshow-content{position:absolute;bottom:15%;left:50%;transform:translateX(-50%);text-align:center;z-index:2;width:90%;max-width:650px}.slideshow-eyebrow{font-size:.8rem;text-transform:uppercase;letter-spacing:5px;color:var(--gold);margin-bottom:16px}.slideshow-content h1{font-family:var(--font-h);font-size:clamp(2.5rem,6vw,4rem);color:#fff;font-weight:600;line-height:1.1;margin-bottom:16px}.slideshow-content p{color:rgba(255,255,255,.8);font-size:1.05rem;margin-bottom:32px}.btn-slide{display:inline-block;padding:14px 40px;background:var(--gold);color:var(--plum);text-decoration:none;font-weight:700;font-size:.9rem;text-transform:uppercase;letter-spacing:2px;transition:background .25s}.btn-slide:hover{background:#d4b87a}.slide-nav{position:absolute;top:50%;transform:translateY(-50%);z-index:3;background:rgba(255,255,255,.15);border:none;color:#fff;font-size:2rem;padding:12px 16px;cursor:pointer;backdrop-filter:blur(4px);transition:background .25s}.slide-nav:hover{background:rgba(255,255,255,.3)}.slide-nav--prev{left:16px}.slide-nav--next{right:16px}.slide-dots{position:absolute;bottom:5%;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:10px}.dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.4);cursor:pointer;transition:background .3s}.dot.active{background:var(--gold)}
  .float-nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:16px 28px;background:rgba(253,248,244,.95);backdrop-filter:blur(8px);opacity:0;transition:opacity .4s;pointer-events:none}.float-nav.visible{opacity:1;pointer-events:all}.float-logo{font-family:var(--font-h);font-size:1.1rem;font-style:italic;color:var(--plum);text-decoration:none}.float-nav ul{display:flex;list-style:none;gap:24px}.float-nav a{text-decoration:none;font-size:.85rem;font-weight:500;color:#666}.float-nav a:hover{color:var(--plum)}
  .intro{padding:100px 0;text-align:center}.intro h2{font-style:italic;max-width:700px;margin:0 auto 24px}.intro p{color:#777;max-width:600px;margin:0 auto;font-size:1rem;line-height:1.75}
  .packages{padding:100px 0;background:var(--blush)}.pkg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}.pkg-card{background:var(--cream);padding:40px 32px;text-align:center}.pkg-card h3{font-family:var(--font-h);font-size:1.3rem;color:var(--plum);margin-bottom:8px}.pkg-price{display:block;font-family:var(--font-h);font-size:2rem;color:var(--gold);font-weight:700;margin-bottom:20px}.pkg-card p{color:#777;font-size:.9rem;line-height:1.7}
  .gallery-section{padding:100px 0}.gallery-masonry{column-count:3;column-gap:16px;padding:0 24px;max-width:1100px;margin:0 auto}.gallery-masonry img{width:100%;display:block;margin-bottom:16px;break-inside:avoid}
  .contact-section{padding:100px 0;background:var(--plum)}.contact-inner{text-align:center}.contact-section h2{color:var(--cream)}.contact-section p{color:rgba(255,255,255,.6);margin-bottom:32px;font-size:1.05rem}.contact-link{font-family:var(--font-h);font-size:1.6rem;color:var(--gold);text-decoration:none;border-bottom:1px solid var(--gold);padding-bottom:4px}.contact-link:hover{color:#fff;border-color:#fff}
  .footer{padding:40px 0;text-align:center;color:#999;font-size:.85rem}.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:8px}.footer a{color:#999;text-decoration:underline}
  @media(max-width:800px){.pkg-grid{grid-template-columns:1fr}.gallery-masonry{column-count:2}.slide-nav{font-size:1.5rem;padding:8px 12px}}
  @media(max-width:500px){.gallery-masonry{column-count:1}}
</style>
<script>(function(){var s=document.getElementById('slideshow');if(!s)return;var slides=s.querySelectorAll('.slide'),dots=s.querySelectorAll('.dot'),prev=document.getElementById('slidePrev'),next=document.getElementById('slideNext'),i=0;function go(n){slides.forEach(function(el){el.classList.remove('active')});dots.forEach(function(el){el.classList.remove('active')});i=(n+slides.length)%slides.length;slides[i].classList.add('active');dots[i].classList.add('active')}go(0);setInterval(function(){go(i+1)},5000);if(prev)prev.addEventListener('click',function(e){e.preventDefault();go(i-1)});if(next)next.addEventListener('click',function(e){e.preventDefault();go(i+1)});dots.forEach(function(d){d.addEventListener('click',function(){go(parseInt(this.dataset.index))})});var fn=document.getElementById('floatNav');if(fn){window.addEventListener('scroll',function(){fn.classList.toggle('visible',window.scrollY>window.innerHeight-100)},{passive:true})}})();</script>
