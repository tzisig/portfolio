---
import BaseLayout from "../layouts/BaseLayout.astro";

const today = ["Sourdough boule", "Morning buns", "Pistachio croissant", "Rye levain", "Brown butter cookies", "Seeded batard"];

const menu = [
  { cat: "Bread", items: [
    { n: "Country Sourdough", d: "72-hour ferment, crackling crust", p: "$9" },
    { n: "Seeded Rye", d: "Caraway, flax, sunflower", p: "$10" },
    { n: "Milk Bread Loaf", d: "Soft, slightly sweet, tangzhong method", p: "$8" },
  ]},
  { cat: "Pastry", items: [
    { n: "Butter Croissant", d: "Laminated 27 times, baked fresh each morning", p: "$5.50" },
    { n: "Pistachio Croissant", d: "Almond-pistachio cream, toasted nuts", p: "$6.50" },
    { n: "Morning Bun", d: "Cinnamon-orange sugar, laminated dough", p: "$5.50" },
  ]},
];

const steps = [
  { n: "1", t: "Pick a date", d: "Custom cakes need 5 days notice minimum — 2 weeks for wedding cakes." },
  { n: "2", t: "Tasting box", d: "Choose 3 flavors, we send a tasting box before you commit." },
  { n: "3", t: "Design call", d: "15 minutes to talk size, servings, and finish." },
  { n: "4", t: "Pickup or delivery", d: "Local delivery available within 10 miles." },
];
---
<BaseLayout title="Hearth & Honey Bakery | Fresh Bread, Pastry & Custom Cakes" description="Hearth & Honey Bakery — naturally leavened bread, laminated pastry, and custom cakes baked daily from scratch." themeColor="#FBF3E7" bodyClass="bakery" consent={{ bg: "#6B4423", fg: "#FBF3E7", accent: "#C1447E", accentFg: "#fff", border: "rgba(251,243,231,0.2)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Mulish:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Mulish:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Mulish:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">Hearth &amp; Honey</a><ul class="nav-links"><li><a href="#menu">Menu</a></li><li><a href="#cakes">Custom Cakes</a></li><li><a href="#visit">Visit</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-eyebrow">Baked fresh, every morning from 4am</p>
        <h1>Bread that's<br />worth the line.</h1>
        <p class="hero-sub">Naturally leavened, slow-fermented, and baked in small batches — usually sold out by 11.</p>
        <div class="hero-actions"><a href="#menu" class="btn-primary">See the menu</a><a href="#cakes" class="btn-outline">Order a custom cake</a></div>
      </div>
      <div class="today-strip"><div class="container today-inner"><span class="today-label">Today's bake</span><div class="today-chips">{today.map((t) => (<span class="today-chip">{t}</span>))}</div></div></div>
    </section>

    <section class="menu" id="menu">
      <div class="container">
        {menu.map((m) => (
          <div class="menu-cat">
            <h2>{m.cat}</h2>
            <div class="menu-list">
              {m.items.map((i) => (
                <div class="menu-item">
                  <div class="menu-item-head"><h3>{i.n}</h3><span class="menu-price">{i.p}</span></div>
                  <p>{i.d}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="story">
      <div class="container story-inner">
        <div class="story-photo" aria-hidden="true"></div>
        <div>
          <p class="section-label">Our story</p>
          <h2>Started with one oven and a starter named Gerald.</h2>
          <p>Hearth &amp; Honey opened in 2018 out of a rented commercial kitchen, selling bread out of a cooler at the farmers market. Gerald — the sourdough starter — is still the base of every loaf we bake today.</p>
        </div>
      </div>
    </section>

    <section class="cakes" id="cakes">
      <div class="container">
        <p class="section-label">Custom cakes</p>
        <h2>From birthdays to weddings.</h2>
        <div class="step-grid">
          {steps.map((s) => (
            <div class="step"><span class="step-num">{s.n}</span><h3>{s.t}</h3><p>{s.d}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="visit" id="visit">
      <div class="container visit-inner">
        <div><h2>Visit us</h2><p>1420 NE Fremont St, Portland, OR</p><p>Tue–Sun, 7am–2pm (or until sold out)</p></div>
        <a href="tel:+15550188" class="visit-tel">(555) 555-0188</a>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Hearth &amp; Honey Bakery &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.bakery){--cream:#FBF3E7;--brown:#6B4423;--raspberry:#C1447E;--ink:#3A2A1C;--font-h:'Fraunces',serif;--font-b:'Mulish',sans-serif}
:global(.bakery){font-family:var(--font-b);color:var(--ink);background:var(--cream);line-height:1.65}
:global(.bakery) :focus-visible{outline:2px solid var(--raspberry);outline-offset:2px}
.container{max-width:1000px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--brown)}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--raspberry);font-weight:600;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2rem);font-weight:600;margin-bottom:30px}
.topnav{padding:20px 0;border-bottom:1px solid rgba(107,68,35,.1)}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);font-size:1.25rem;color:var(--brown);text-decoration:none;font-weight:600}
.nav-links{display:flex;gap:26px;list-style:none;font-size:.88rem}
.nav-links a{color:var(--ink);text-decoration:none}
.hero{padding:70px 0 0}
.hero-inner{text-align:center;max-width:600px;margin:0 auto}
.hero-eyebrow{font-size:.8rem;color:var(--raspberry);letter-spacing:.08em;text-transform:uppercase;margin-bottom:20px}
h1{font-size:clamp(2.6rem,6vw,4rem);font-weight:600;line-height:1.05;margin-bottom:20px}
.hero-sub{color:#7A6650;font-size:1.02rem;margin-bottom:30px}
.hero-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.btn-primary{background:var(--brown);color:var(--cream);padding:13px 28px;text-decoration:none;border-radius:30px;font-weight:600;font-size:.92rem}
.btn-outline{border:1.5px solid var(--brown);color:var(--brown);padding:13px 28px;text-decoration:none;border-radius:30px;font-weight:600;font-size:.92rem}
.today-strip{margin-top:56px;background:var(--brown);padding:16px 0}
.today-inner{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.today-label{color:var(--raspberry);font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;font-weight:700;flex-shrink:0}
.today-chips{display:flex;flex-wrap:wrap;gap:10px}
.today-chip{color:var(--cream);font-size:.82rem;opacity:.85}
.today-chip::after{content:"·";margin-left:10px;opacity:.4}
.today-chip:last-child::after{content:""}
.menu{padding:80px 0}
.menu-cat{margin-bottom:50px}
.menu-list{display:flex;flex-direction:column;gap:18px}
.menu-item{border-bottom:1px dashed rgba(107,68,35,.2);padding-bottom:14px}
.menu-item-head{display:flex;justify-content:space-between;align-items:baseline}
.menu-item-head h3{font-size:1.05rem;font-weight:600}
.menu-price{font-family:var(--font-h);color:var(--raspberry);font-weight:600}
.menu-item p{color:#7A6650;font-size:.88rem}
.story{padding:80px 0;background:#fff}
.story-inner{display:grid;grid-template-columns:280px 1fr;gap:44px;align-items:center}
.story-photo{width:100%;height:220px;background:linear-gradient(160deg,var(--raspberry),var(--brown));border-radius:6px}
.story-inner p{color:#7A6650;font-size:.95rem;max-width:460px}
.cakes{padding:80px 0}
.step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.step-num{font-family:var(--font-h);color:var(--raspberry);font-size:1.5rem;font-weight:600;display:block;margin-bottom:10px}
.step h3{font-size:1rem;margin-bottom:6px}
.step p{color:#7A6650;font-size:.85rem}
.visit{padding:80px 0;background:var(--brown);color:var(--cream)}
.visit-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:24px}
.visit h2{color:var(--cream);margin-bottom:8px}
.visit p{color:rgba(251,243,231,.7);font-size:.92rem}
.visit-tel{font-family:var(--font-h);font-size:2rem;font-weight:600;color:var(--raspberry);text-decoration:none}
.footer{padding:38px 0;text-align:center;color:#7A6650;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#7A6650;text-decoration:underline}
@media(max-width:800px){.story-inner{grid-template-columns:1fr}.step-grid{grid-template-columns:1fr 1fr}.hero-actions{flex-direction:column}}
</style>
