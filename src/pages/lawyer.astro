---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Sarah Bennett, Esq. | Personal Legal Counsel"
  description="Sarah Bennett, Esq. offers personal legal counsel in family law, contracts, civil litigation, wills and estates. Transparent, clear, and direct. Book a consultation."
  themeColor="#1B2740"
  bodyClass="lawyer"
  consent={{ bg: "#1B2740", fg: "#EDE7D9", accent: "#9C7A3C", accentFg: "#1B2740", border: "rgba(237,231,217,0.16)" }}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head">
  <link href="https://fonts.googleapis.com/css2?family=David+Libre:wght@400;500;700&family=Alef:wght@400;700&display=swap" rel="stylesheet" slot="head">

  <header class="hero">
    <nav class="nav">
      <div class="container nav-inner">
        <span class="brand">Sarah Bennett, Esq.</span>
        <a href="#booking" class="btn btn-outline">Book a Consultation</a>
      </div>
    </nav>

    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-tags">Family Law · Contracts · Civil Litigation</p>
        <h1 class="hero-title">Before you sign,<br>before you file —<br>know exactly what it means.</h1>
        <p class="hero-sub">Legal counsel that explains every step in plain language before it happens. Not after.</p>
        <div class="hero-actions">
          <a href="#booking" class="btn btn-primary">Book an initial consultation</a>
          <a href="#services" class="btn btn-outline-light">Practice areas</a>
        </div>
      </div>
      <div class="seal" aria-hidden="true">
        <svg width="140" height="140" viewBox="0 0 140 140">
          <circle cx="70" cy="70" r="66" fill="none" stroke="#9C7A3C" stroke-width="2"/>
          <circle cx="70" cy="70" r="56" fill="none" stroke="#9C7A3C" stroke-width="1"/>
          <text x="70" y="65" text-anchor="middle" fill="#9C7A3C" font-family="David Libre, serif" font-size="13" font-weight="700">ESQ.</text>
          <text x="70" y="85" text-anchor="middle" fill="#9C7A3C" font-family="David Libre, serif" font-size="13">Bennett</text>
        </svg>
      </div>
    </div>
  </header>

  <main id="main">
    <section class="principles">
      <div class="container">
        <p class="section-label text-amber">Why clients choose me</p>
        <h2 class="section-title">Three principles that guide every case</h2>
        <div class="clauses">
          <div class="clause">
            <span class="clause-num">Clause 1</span>
            <div class="clause-body">
              <h3 class="clause-title">Full fee transparency</h3>
              <p class="clause-desc">A clear price up front, no surprises on the invoice mid-case.</p>
            </div>
          </div>
          <div class="clause">
            <span class="clause-num">Clause 2</span>
            <div class="clause-body">
              <h3 class="clause-title">Explained before every decision</h3>
              <p class="clause-desc">Every document and step is explained before it happens, not just reported afterward.</p>
            </div>
          </div>
          <div class="clause">
            <span class="clause-num">Clause 3</span>
            <div class="clause-body">
              <h3 class="clause-title">Direct availability</h3>
              <p class="clause-desc">You reach me directly, not a secretary relaying messages.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="services">
      <div class="container">
        <p class="section-label text-paper">Practice areas</p>
        <h2 class="section-title text-paper">Support at the decisions that matter most</h2>
        <div class="services-grid">
          <div class="service-card">
            <h3 class="service-title">Family law and divorce</h3>
            <p class="service-desc">Divorce agreements, custody, support, and guardianship.</p>
          </div>
          <div class="service-card">
            <h3 class="service-title">Contracts and agreements</h3>
            <p class="service-desc">Drafting, review, and negotiation of business and personal agreements.</p>
          </div>
          <div class="service-card">
            <h3 class="service-title">Civil litigation</h3>
            <p class="service-desc">Representation in civil and commercial court proceedings.</p>
          </div>
          <div class="service-card">
            <h3 class="service-title">Wills and estates</h3>
            <p class="service-desc">Drafting wills, handling estates, and advising heirs.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="booking" class="booking">
      <div class="container booking-inner">
        <p class="section-label text-amber">First step</p>
        <h2 class="section-title">Book a consultation</h2>
        <p class="booking-sub">Leave your details, and the message is sent straight to the office WhatsApp. We'll get back to you within one business day.</p>
        <form id="leadForm" class="form">
          <div class="form-group">
            <label for="name">Full name</label>
            <input required id="name" name="name" type="text" placeholder="e.g. John Miller">
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <input required id="phone" name="phone" type="tel" placeholder="+1 555 123 4567">
          </div>
          <div class="form-group">
            <label for="reason">Area of inquiry</label>
            <select id="reason" name="reason">
              <option>Family law and divorce</option>
              <option>Contracts and agreements</option>
              <option>Civil litigation</option>
              <option>Wills and estates</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="time">When works for you?</label>
            <select id="time" name="time">
              <option>Morning</option>
              <option>Afternoon</option>
              <option>Evening</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-full">Send via WhatsApp</button>
          <p class="form-footnote">Clicking send will open a WhatsApp chat with your message ready to go.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p>Sarah Bennett, Esq. · [Office address] · [Phone] · [Office hours]</p>
      <p class="footer-note">Sample page only — does not represent an active attorney or firm.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  :global(.lawyer) {
    --ink: #1B2740;
    --paper: #EDE7D9;
    --brass: #9C7A3C;
    --charcoal: #2A2A26;
    --rule: #C9C0AA;
    --amber: #854D0E;
    --font-display: 'David Libre', serif;
    --font-body: 'Alef', 'Segoe UI', system-ui, sans-serif;
    font-family: var(--font-body);
    background: var(--paper);
    color: var(--charcoal);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  .container { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

  .btn { display: inline-block; font-weight: 700; font-size: 0.9rem; padding: 12px 28px; transition: all 0.2s; text-align: center; }
  .btn-primary { background: var(--brass); color: var(--ink); }
  .btn-primary:hover { background: var(--paper); color: var(--ink); }
  .btn-outline { border: 1px solid var(--brass); color: var(--brass); }
  .btn-outline:hover { background: var(--brass); color: var(--ink); }
  .btn-outline-light { border: 1px solid var(--paper); color: var(--paper); }
  .btn-outline-light:hover { background: rgba(255,255,255,0.1); }
  .btn-full { width: 100%; }

  .section-label { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem; }
  .section-title { font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; line-height: 1.25; margin-bottom: 3rem; max-width: 42rem; }
  .text-amber { color: var(--amber); }
  .text-paper { color: var(--paper); }

  .nav { background: var(--ink); color: var(--paper); border-bottom: 1px solid rgba(237,231,217,0.15); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; }

  .hero { background: var(--ink); color: var(--paper); }
  .hero-inner { display: grid; grid-template-columns: 1fr auto; gap: 2.5rem; align-items: start; padding-top: calc(3.5rem + 40px); padding-bottom: 5rem; }
  .hero-tags { font-weight: 700; letter-spacing: 0.1em; font-size: 0.875rem; margin-bottom: 1rem; }
  .hero-title { font-family: var(--font-display); font-size: 2.25rem; font-weight: 700; line-height: 1.25; max-width: 42rem; }
  .hero-sub { margin-top: 1.5rem; font-size: 1.125rem; color: rgba(237,231,217,0.75); max-width: 36rem; line-height: 1.625; }
  .hero-actions { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 1rem; }
  .seal { display: none; flex-shrink: 0; align-self: center; }

  .principles { padding: 5rem 0; }
  .clauses { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .clause { padding: 1.5rem 0; display: grid; grid-template-columns: 80px 1fr; gap: 1rem; align-items: baseline; }
  .clause + .clause { border-top: 1px solid var(--rule); }
  .clause-num { font-family: var(--font-display); color: var(--amber); font-size: 1.125rem; font-weight: 700; }
  .clause-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.25rem; }
  .clause-desc { color: rgba(42,42,38,0.7); line-height: 1.625; }

  .services { background: var(--ink); color: var(--paper); padding: 5rem 0; }
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: rgba(237,231,217,0.15); border: 1px solid transparent; }
  .service-card { background: var(--ink); padding: 1.5rem; }
  .service-title { font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; margin-bottom: 0.25rem; }
  .service-desc { font-size: 0.875rem; color: rgba(237,231,217,0.6); line-height: 1.625; }

  .booking { padding: 5rem 0; }
  .booking-inner { max-width: 42rem; }
  .booking-sub { color: rgba(42,42,38,0.7); margin-bottom: 2rem; }

  .form { border: 1px solid var(--rule); padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-group label { font-size: 0.875rem; font-weight: 700; margin-bottom: 0.25rem; }
  .form-group input, .form-group select { width: 100%; padding: 12px 16px; border: 1px solid var(--rule); background: var(--paper); font-family: var(--font-body); font-size: 1rem; }
  .form-group input:focus, .form-group select:focus { outline: 2px solid var(--brass); outline-offset: -2px; }
  .form-footnote { font-size: 0.75rem; color: rgba(42,42,38,0.5); text-align: center; }

  .footer { background: var(--ink); color: var(--paper); padding: 2rem 0; text-align: center; font-size: 0.875rem; border-top: 1px solid rgba(237,231,217,0.15); }
  .footer-inner { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-note { font-size: 0.75rem; opacity: 0.6; }

  @media (min-width: 768px) {
    .hero-inner { padding-top: calc(5rem + 40px); padding-bottom: 7rem; }
    .hero-title { font-size: 3.75rem; }
    .seal { display: block; }
    .section-title { font-size: 2.25rem; }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
    .clause { grid-template-columns: 1fr; gap: 0.25rem; }
  }
</style>

<script>
(function () {
  var form = document.getElementById('leadForm');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var name = document.getElementById('name').value.trim();
    var phone = document.getElementById('phone').value.trim();
    var reason = document.getElementById('reason').value;
    var time = document.getElementById('time').value;
    var msg = 'New inquiry from the website:\nName: ' + name + '\nPhone: ' + phone + '\nArea of inquiry: ' + reason + '\nPreferred time: ' + time;
    window.open('https://wa.me/972584433181?text=' + encodeURIComponent(msg), '_blank');
  });
})();
</script>
