---
import BaseLayout from "../layouts/BaseLayout.astro";

const stack = ["TypeScript", "React", "Node.js", "PostgreSQL", "Astro", "AWS", "Stripe", "GraphQL"];

const commits = [
  { hash: "a3f21c9", msg: "discovery call — scope, stack, timeline locked", day: "Week 1" },
  { hash: "e91b0d4", msg: "wireframes + component architecture reviewed", day: "Week 1" },
  { hash: "77c4a12", msg: "core build — auth, data layer, primary flows", day: "Week 2–4" },
  { hash: "b02e8f6", msg: "staging deploy, client QA round", day: "Week 5" },
  { hash: "f45d1a0", msg: "production launch + handoff docs", day: "Week 6" },
];

const projects = [
  { name: "Ledgerline", type: "Fintech dashboard", desc: "Rebuilt a legacy reporting tool into a real-time analytics dashboard. Query times dropped from 4s to 180ms.", stack: "React · PostgreSQL · Redis" },
  { name: "Fernwood Market", type: "E-commerce platform", desc: "Headless storefront on Astro with a custom inventory sync. Checkout conversion up 22% post-launch.", stack: "Astro · Stripe · Shopify API" },
  { name: "Basecamp Clinic", type: "Internal ops tool", desc: "Patient scheduling and intake system replacing three spreadsheets and a shared inbox.", stack: "Next.js · Node.js · Twilio" },
];

const tiers = [
  { name: "Sprint", price: "$4,200", unit: "one scope, one push", items: ["Single feature or fix", "1–2 week turnaround", "Async updates", "1 revision round"] },
  { name: "Build", price: "$14,500", unit: "most common", items: ["Full product build", "4–6 week timeline", "Weekly check-ins", "Staging environment", "2 revision rounds"], featured: true },
  { name: "Partner", price: "from $6k/mo", unit: "ongoing", items: ["Dedicated monthly hours", "Roadmap planning", "Priority response", "Infra & on-call"] },
];

const faqs = [
  { q: "Do you work with an existing codebase?", a: "Usually, yes. Most engagements start with a codebase audit before any new work is scoped." },
  { q: "What if the scope changes mid-build?", a: "Scope changes get logged as a new commit in the plan — re-estimated, never silently absorbed into the timeline." },
  { q: "Who owns the code?", a: "You do, fully, from day one. Repository access is granted at kickoff, not at final invoice." },
];
---
<BaseLayout title="Northbound Software | Web & Product Development Studio" description="Northbound Software builds and ships web applications — from MVP to production. TypeScript, React, and infrastructure done right." themeColor="#0D1117" bodyClass="webdev" consent={{ bg: "#0D1117", fg: "#C9D1D9", accent: "#3FB950", accentFg: "#0D1117", border: "rgba(201,209,217,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">north<span>bound</span>/</a><ul class="nav-links"><li><a href="#work">Work</a></li><li><a href="#process">Process</a></li><li><a href="#pricing">Pricing</a></li><li><a href="#contact" class="nav-cta">Start a project</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <img src="https://images.pexels.com/photos/6424589/pexels-photo-6424589.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80" alt="Laptop showing colorful code on screen in a dark room" width="1600" height="1067" class="hero-bg-img" loading="eager" fetchpriority="high" decoding="async" />
      <div class="hero-bg-overlay" aria-hidden="true"></div>
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">// available for Q3 engagements</p>
          <h1>We ship software that <span class="accent">doesn't</span> need a rewrite in a year.</h1>
          <p class="hero-sub">A small studio building web applications end-to-end — product thinking, engineering, and the infrastructure to keep it running.</p>
          <div class="hero-actions"><a href="#contact" class="btn-primary">Start a project</a><a href="#work" class="btn-ghost">See the work →</a></div>
        </div>
        <div class="terminal" aria-hidden="true">
          <div class="term-bar"><span></span><span></span><span></span><span class="term-title">northbound — zsh</span></div>
          <div class="term-body">
            <p><span class="prompt">$</span> npx create-project client-app</p>
            <p class="dim">✓ scaffolding TypeScript + React</p>
            <p class="dim">✓ configuring CI/CD pipeline</p>
            <p class="dim">✓ provisioning staging environment</p>
            <p><span class="prompt">$</span> git push origin main</p>
            <p class="ok">✓ deployed in 41s</p>
          </div>
        </div>
      </div>
      <div class="stack-row"><div class="container stack-inner">{stack.map((s) => (<span class="stack-chip">{s}</span>))}</div></div>
    </section>

    <section class="process" id="process">
      <div class="container">
        <p class="section-label">// process</p>
        <h2>Six weeks, five commits, one launch.</h2>
        <div class="commit-log">
          {commits.map((c) => (
            <div class="commit">
              <span class="commit-hash">{c.hash}</span>
              <span class="commit-msg">{c.msg}</span>
              <span class="commit-day">{c.day}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="work" id="work">
      <div class="container">
        <p class="section-label">// selected work</p>
        <h2>Recent builds.</h2>
        <div class="project-list">
          {projects.map((p) => (
            <div class="project">
              <div class="project-head"><h3>{p.name}</h3><span class="project-type">{p.type}</span></div>
              <p>{p.desc}</p>
              <span class="project-stack">{p.stack}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pricing" id="pricing">
      <div class="container">
        <p class="section-label">// pricing</p>
        <h2>Scoped, not hourly.</h2>
        <div class="tier-grid">
          {tiers.map((t) => (
            <div class={`tier ${t.featured ? "tier-featured" : ""}`}>
              {t.featured && <span class="tier-badge">Most common</span>}
              <h3>{t.name}</h3>
              <p class="tier-price">{t.price}</p>
              <p class="tier-unit">{t.unit}</p>
              <ul>{t.items.map((i) => (<li>{i}</li>))}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="faq">
      <div class="container">
        <p class="section-label">// faq</p>
        <h2>Questions, answered.</h2>
        <div class="faq-list">
          {faqs.map((f) => (
            <div class="faq-item"><h3>{f.q}</h3><p>{f.a}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="container contact-inner">
        <p class="section-label">// contact</p>
        <h2>Tell us what you're building.</h2>
        <p class="contact-sub">A short call, no deck required. We'll tell you honestly if we're the right fit.</p>
        <a href="mailto:hello@northboundsoftware.dev" class="contact-mail">hello@northboundsoftware.dev</a>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Northbound Software — remote-first, U.S. hours</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.webdev){--bg:#0D1117;--panel:#161B22;--fg:#C9D1D9;--white:#F0F6FC;--green:#3FB950;--purple:#A78BFA;--border:rgba(201,209,217,.14);--font-h:'JetBrains Mono',monospace;--font-b:'Inter',sans-serif}
:global(.webdev){font-family:var(--font-b);color:var(--fg);background:var(--bg);line-height:1.65}
:global(.webdev) :focus-visible{outline:2px solid var(--green);outline-offset:2px}
.container{max-width:1080px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--white)}
.accent{color:var(--green)}
.section-label{font-family:var(--font-h);font-size:.78rem;color:var(--green);margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2.1rem);font-weight:700;margin-bottom:32px}
.topnav{position:sticky;top:0;background:rgba(13,17,23,.92);backdrop-filter:blur(6px);border-bottom:1px solid var(--border);z-index:100;padding:14px 0}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);color:var(--white);text-decoration:none;font-weight:700}.brand span{color:var(--green)}
.nav-links{display:flex;gap:26px;list-style:none;align-items:center;font-size:.85rem}
.nav-links a{color:var(--fg);text-decoration:none}.nav-links a:hover{color:var(--white)}
.nav-cta{background:var(--green);color:var(--bg)!important;padding:7px 16px;border-radius:4px;font-weight:600}
.hero{padding:70px 0 0;position:relative;overflow:hidden}
.hero-bg-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.22}
.hero-bg-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(13,17,23,.4),var(--bg) 88%)}
.hero-grid{position:relative;z-index:1}
.stack-row{position:relative;z-index:1}
.hero-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:50px;align-items:center;padding-bottom:60px}
.eyebrow{font-family:var(--font-h);color:var(--purple);font-size:.8rem;margin-bottom:16px}
h1{font-size:clamp(2.1rem,4.4vw,3.1rem);line-height:1.2;font-weight:700;margin-bottom:20px}
.hero-sub{color:#8B949E;font-size:1.02rem;max-width:440px;margin-bottom:30px}
.hero-actions{display:flex;gap:16px}
.btn-primary{background:var(--green);color:var(--bg);padding:12px 26px;border-radius:4px;text-decoration:none;font-weight:700}
.btn-ghost{color:var(--fg);padding:12px 6px;text-decoration:none;border-bottom:1px solid var(--border)}
.terminal{background:var(--panel);border:1px solid var(--border);border-radius:8px;overflow:hidden;font-family:var(--font-h);font-size:.8rem}
.term-bar{display:flex;align-items:center;gap:6px;padding:10px 14px;background:#0D1117;border-bottom:1px solid var(--border)}
.term-bar span{width:10px;height:10px;border-radius:50%;background:#484F58}
.term-title{margin-left:10px;color:#8B949E;font-size:.75rem}
.term-body{padding:18px}
.term-body p{margin-bottom:8px;color:var(--fg)}
.prompt{color:var(--green);margin-right:6px}
.dim{color:#8B949E}.ok{color:var(--green)}
.stack-row{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:20px 0;background:var(--panel)}
.stack-inner{display:flex;flex-wrap:wrap;gap:10px}
.stack-chip{font-family:var(--font-h);font-size:.78rem;color:#8B949E;border:1px solid var(--border);padding:6px 12px;border-radius:20px}
.process{padding:80px 0}
.commit-log{border-left:2px solid var(--border);padding-left:24px;display:flex;flex-direction:column;gap:20px}
.commit{display:grid;grid-template-columns:110px 1fr 100px;gap:16px;align-items:center;position:relative}
.commit::before{content:"";position:absolute;left:-29px;top:6px;width:10px;height:10px;border-radius:50%;background:var(--green)}
.commit-hash{font-family:var(--font-h);color:var(--purple);font-size:.82rem}
.commit-msg{color:var(--fg);font-size:.92rem}
.commit-day{color:#8B949E;font-size:.78rem;text-align:right}
.work{padding:80px 0;background:var(--panel)}
.project-list{display:flex;flex-direction:column;gap:1px;background:var(--border)}
.project{background:var(--bg);padding:26px 28px}
.project-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px}
.project-head h3{font-size:1.1rem}
.project-type{color:var(--green);font-size:.78rem;font-family:var(--font-h)}
.project p{color:#8B949E;font-size:.92rem;margin-bottom:12px;max-width:640px}
.project-stack{font-family:var(--font-h);font-size:.75rem;color:#8B949E}
.pricing{padding:80px 0}
.tier-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.tier{border:1px solid var(--border);border-radius:8px;padding:28px 24px;position:relative}
.tier-featured{border-color:var(--green);background:var(--panel)}
.tier-badge{position:absolute;top:-11px;left:24px;background:var(--green);color:var(--bg);font-size:.68rem;font-weight:700;padding:3px 10px;border-radius:12px;font-family:var(--font-h)}
.tier h3{font-size:1rem;margin-bottom:10px}
.tier-price{font-size:1.7rem;font-weight:700;color:var(--white);font-family:var(--font-h)}
.tier-unit{color:#8B949E;font-size:.78rem;margin-bottom:18px}
.tier ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:8px}
.tier li{font-size:.85rem;color:var(--fg);padding-left:16px;position:relative}
.tier li::before{content:"→";position:absolute;left:0;color:var(--green)}
.faq{padding:80px 0;background:var(--panel)}
.faq-list{display:flex;flex-direction:column;gap:22px;max-width:700px}
.faq-item h3{font-size:.95rem;margin-bottom:6px;font-family:var(--font-b);font-weight:600;color:var(--white)}
.faq-item p{color:#8B949E;font-size:.88rem}
.contact{padding:90px 0;text-align:center}
.contact-sub{color:#8B949E;margin-bottom:24px}
.contact-mail{font-family:var(--font-h);font-size:1.3rem;color:var(--green);text-decoration:none}
.footer{padding:36px 0;border-top:1px solid var(--border);text-align:center;color:#8B949E;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#8B949E;text-decoration:underline}
@media(max-width:800px){.hero-grid{grid-template-columns:1fr}.tier-grid{grid-template-columns:1fr}.commit{grid-template-columns:1fr}.nav-links{gap:14px;font-size:.78rem}}
</style>
