---
import BaseLayout from "../layouts/BaseLayout.astro";
const pests = [
  { problem: "Ants", solution: "Baiting system + perimeter barrier spray + exclusion sealing", icon: "🐜" },
  { problem: "Rodents", solution: "Trapping, exclusion, sanitation guidance, and preventative monitoring", icon: "🐀" },
  { problem: "Spiders", solution: "Web removal, residual treatment, and habitat modification", icon: "🕷" },
  { problem: "Termites", solution: "Liquid termiticide barrier, bait stations, and wood treatment", icon: "🪳" },
  { problem: "Bed Bugs", solution: "Heat treatment, steam, and targeted insecticide application", icon: "🛌" },
  { problem: "Wasps & Hornets", solution: "Nest removal, aerosol treatment, and preventative eaves treatment", icon: "🐝" },
];
const guarantees = ["Same-day service available", "Pet-safe treatments", "12-month warranty on all work", "Licensed & insured", "Free re-treatment if pests return", "No contracts required"];
const reviews = [
  { text: "Had ants in the kitchen every spring for years. Cascade Pest came once and we haven't seen a single ant in 18 months. Worth every penny.", name: "Michelle R." },
  { text: "Found a wasp nest in our eaves on a Saturday. They were here in 3 hours and the guy was professional, quick, and the price was fair.", name: "Alex T." },
];
---
<BaseLayout title="Cascade Pest Control | Portland Exterminator & Pest Removal" description="Cascade Pest Control provides fast, effective pest removal and prevention for ants, rodents, termites, bed bugs, and more in the Portland metro area." themeColor="#8B1A1A" bodyClass="pest" consent={{ bg: "#8B1A1A", fg: "#FFF5F5", accent: "#EAB308", accentFg: "#1F1F1F", border: "rgba(255,245,245,0.16)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" /></noscript>
  </slot>
  <div class="alert-bar"><span>⚠ Same-day service available &mdash; Call now</span><a href="tel:+15550120">(555) 555-0120</a></div>
  <section class="hero"><div class="container hero-inner"><div class="hero-icon">🛡</div><h1>Pests don't wait. Neither do we.</h1><p class="hero-p">Fast, effective pest control for homes and businesses in the Portland area. Same-day service, pet-safe treatments, and a 12-month guarantee.</p><div class="hero-actions"><a href="#pests" class="btn-primary">See How We Treat</a><a href="tel:+15550120" class="btn-urgent">Call for Emergency</a></div></div></section>
  <section class="problem-section" id="pests"><div class="container"><h2>Problem → Solution</h2><div class="pest-grid">{pests.map((p) => (<div class="pest-card"><span class="pest-icon">{p.icon}</span><div><h3>{p.problem}</h3><p>{p.solution}</p></div></div>))}</div></div></section>
  <section class="guarantee"><div class="container"><h2>Why choose Cascade?</h2><div class="guarantee-grid">{guarantees.map((g) => (<div class="guarantee-item"><span class="g-check">✓</span>{g}</div>))}</div></div></section>
  <section class="reviews"><div class="container"><div class="review-grid">{reviews.map((r) => (<div class="r-card"><p>"{r.text}"</p><strong>{r.name}</strong></div>))}</div></div></section>
  <section class="cta-section"><div class="container cta-inner"><h2>Get pest-free today.</h2><a href="tel:+15550120" class="cta-tel">(555) 555-0120</a><span class="cta-small">Free estimate &middot; Same-day service available</span></div></section>
  <footer class="footer"><div class="container"><p>Cascade Pest Control &mdash; Portland, OR &middot; Licensed &amp; Insured</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a></nav></div></footer>
</BaseLayout>
<style>:global(.pest){--red:#8B1A1A;--dark:#1F1F1F;--yellow:#EAB308;--cream:#FFF5F5;--font-h:'Oswald',sans-serif;--font-b:'Inter',sans-serif}:global(.pest){font-family:var(--font-b);color:#333;background:#fff;line-height:1.6}:global(.pest) :focus-visible{outline:3px solid var(--yellow);outline-offset:2px}.container{max-width:1100px;margin:0 auto;padding:0 24px}h1{font-family:var(--font-h);font-size:clamp(2.5rem,6vw,4rem);font-weight:700;color:#fff;line-height:1;text-transform:uppercase;letter-spacing:-0.02em}h2{font-family:var(--font-h);font-size:clamp(1.5rem,3.5vw,2.2rem);font-weight:600;color:var(--dark);text-transform:uppercase;margin-bottom:32px}
  .alert-bar{background:var(--red);color:#fff;text-align:center;padding:10px;font-weight:600;font-size:.9rem;display:flex;justify-content:center;gap:16px;align-items:center}.alert-bar a{color:var(--yellow);text-decoration:none;font-weight:700}.alert-bar a:hover{color:#fff}
  .hero{background:linear-gradient(135deg,var(--dark) 0%,#3A1A1A 100%);padding:80px 0 100px}.hero-inner{text-align:center;max-width:650px;margin:0 auto}.hero-icon{font-size:3rem;margin-bottom:16px}.hero-p{color:rgba(255,255,255,.6);font-size:1.05rem;margin:24px auto 32px;max-width:500px}.hero-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}.btn-primary{display:inline-block;padding:14px 32px;background:var(--yellow);color:var(--dark);text-decoration:none;font-weight:700;font-size:.9rem;text-transform:uppercase;letter-spacing:1px;transition:background .25s}.btn-primary:hover{background:#f5c542}.btn-urgent{display:inline-block;padding:14px 32px;border:2px solid rgba(255,255,255,.3);color:#fff;text-decoration:none;font-weight:600;font-size:.9rem;transition:all .25s}.btn-urgent:hover{background:rgba(255,255,255,.1);border-color:#fff}
  .problem-section{padding:80px 0}.pest-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}.pest-card{display:flex;gap:16px;align-items:flex-start;background:#fafafa;padding:20px;border-left:3px solid var(--red)}.pest-icon{font-size:1.8rem;flex-shrink:0}.pest-card h3{font-family:var(--font-h);font-size:1rem;font-weight:600;color:var(--dark);text-transform:uppercase;margin-bottom:2px}.pest-card p{color:#888;font-size:.85rem;line-height:1.6}
  .guarantee{padding:60px 0;background:var(--dark)}.guarantee h2{color:#fff}.guarantee-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.guarantee-item{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.7);font-size:.9rem}.g-check{color:var(--yellow);font-weight:700}
  .reviews{padding:60px 0}.review-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}.r-card{padding:24px;background:#fafafa;border-left:3px solid var(--yellow)}.r-card p{font-style:italic;color:#666;font-size:.9rem;margin-bottom:8px}.r-card strong{font-size:.85rem;color:var(--dark)}
  .cta-section{padding:80px 0;background:var(--red)}.cta-inner{text-align:center}.cta-section h2{color:#fff}.cta-tel{font-family:var(--font-h);font-size:2.5rem;font-weight:700;color:#fff;text-decoration:none;display:block;margin-bottom:8px}.cta-tel:hover{color:var(--yellow)}.cta-small{color:rgba(255,255,255,.5);font-size:.85rem}
  .footer{padding:40px 0;text-align:center;color:#bbb;font-size:.8rem}.footer nav{display:flex;justify-content:center;gap:20px;margin-top:6px}.footer a{color:#bbb;text-decoration:underline}
  @media(max-width:800px){.pest-grid{grid-template-columns:1fr}.guarantee-grid{grid-template-columns:1fr}.review-grid{grid-template-columns:1fr}}
</style>
