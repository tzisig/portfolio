---
import BaseLayout from "../layouts/BaseLayout.astro";

const menu = [
  { n: "Classic Cut", p: "$32", t: "30 min" },
  { n: "Skin Fade", p: "$38", t: "40 min" },
  { n: "Cut + Beard", p: "$52", t: "50 min" },
  { n: "Hot Towel Shave", p: "$35", t: "35 min" },
  { n: "Kids Cut (12 & under)", p: "$24", t: "25 min" },
  { n: "Line-up", p: "$16", t: "15 min" },
];

const barbers = [
  { name: "Tony Marchetti", chair: "Chair 1", years: "22 years cutting" },
  { name: "Kwame Osei", chair: "Chair 2", years: "9 years cutting" },
  { name: "Rico Alvarez", chair: "Chair 3", years: "6 years cutting" },
];

const hours = [
  { d: "Mon–Fri", h: "9am – 7pm" },
  { d: "Saturday", h: "8am – 5pm" },
  { d: "Sunday", h: "Closed" },
];
---
<BaseLayout title="Marchetti's Barbershop | Cuts, Fades & Hot Towel Shaves" description="Marchetti's Barbershop — walk-ins welcome, three chairs, classic and modern cuts since 2003." themeColor="#16232D" bodyClass="barber" consent={{ bg: "#16232D", fg: "#EFE9DD", accent: "#B9975B", accentFg: "#16232D", border: "rgba(239,233,221,0.18)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Source+Sans+3:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Source+Sans+3:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Source+Sans+3:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand"><span class="pole" aria-hidden="true"></span>Marchetti's</a><ul class="nav-links"><li><a href="#menu">Services</a></li><li><a href="#barbers">Barbers</a></li><li><a href="#hours">Hours</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-eyebrow">Est. 2003 &middot; Three chairs &middot; Walk-ins welcome</p>
        <h1>Cuts done right,<br />no appointment needed.</h1>
        <p class="hero-sub">A real barbershop — clippers, straight razors, and three guys who've been doing this a long time.</p>
        <a href="tel:+15550142" class="btn-primary">Call (555) 555-0142</a>
      </div>
    </section>

    <section class="menu" id="menu">
      <div class="container">
        <p class="section-label">Service menu</p>
        <div class="menu-list">
          {menu.map((m) => (
            <div class="menu-row"><span class="menu-name">{m.n}</span><span class="menu-dots"></span><span class="menu-time">{m.t}</span><span class="menu-price">{m.p}</span></div>
          ))}
        </div>
      </div>
    </section>

    <section class="barbers" id="barbers">
      <div class="container">
        <p class="section-label">The chairs</p>
        <div class="barber-grid">
          {barbers.map((b) => (
            <div class="barber-card"><div class="barber-photo" aria-hidden="true"></div><h3>{b.name}</h3><span>{b.chair} &middot; {b.years}</span></div>
          ))}
        </div>
      </div>
    </section>

    <section class="club">
      <div class="container club-inner">
        <div>
          <p class="section-label">Regulars Club</p>
          <h2>Cut every 3 weeks, priced accordingly.</h2>
          <p>$99/month gets you a standing cut every three weeks, priority booking, and a free beard trim add-on each visit.</p>
        </div>
        <a href="#hours" class="btn-outline">Ask about the club</a>
      </div>
    </section>

    <section class="hours" id="hours">
      <div class="container hours-inner">
        <div>
          <p class="section-label">Hours</p>
          <div class="hours-table">{hours.map((h) => (<div class="hours-row"><span>{h.d}</span><span>{h.h}</span></div>))}</div>
        </div>
        <div class="address-block">
          <p class="section-label">Find us</p>
          <p>2210 N Williams Ave<br />Portland, OR 97227</p>
          <p class="walk-in-note">Walk-ins always welcome. Wait times posted on the door.</p>
        </div>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Marchetti's Barbershop &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.barber){--navy:#16232D;--brass:#B9975B;--cream:#EFE9DD;--panel:#1E2E3A;--font-h:'Oswald',sans-serif;--font-b:'Source Sans 3',sans-serif}
:global(.barber){font-family:var(--font-b);color:var(--cream);background:var(--navy);line-height:1.65}
:global(.barber) :focus-visible{outline:2px solid var(--brass);outline-offset:2px}
.container{max-width:980px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:#fff;text-transform:uppercase}
.section-label{font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--brass);font-weight:600;margin-bottom:10px}
h2{font-size:clamp(1.4rem,2.8vw,1.9rem);margin-bottom:14px}
.topnav{padding:18px 0;border-bottom:1px solid rgba(239,233,221,.12)}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{display:flex;align-items:center;gap:10px;font-family:var(--font-h);color:#fff;text-decoration:none;font-weight:700;letter-spacing:.03em}
.pole{width:8px;height:20px;border-radius:4px;background:repeating-linear-gradient(45deg,#B91C1C 0 4px,#fff 4px 8px,#1E3A5F 8px 12px)}
.nav-links{display:flex;gap:24px;list-style:none;font-size:.85rem}
.nav-links a{color:var(--cream);text-decoration:none;text-transform:uppercase;letter-spacing:.04em}
.hero{padding:90px 0}
.hero-inner{max-width:600px}
.hero-eyebrow{font-size:.8rem;color:var(--brass);letter-spacing:.1em;text-transform:uppercase;margin-bottom:22px}
h1{font-size:clamp(2.4rem,5.4vw,3.6rem);line-height:1.05;margin-bottom:22px}
.hero-sub{color:rgba(239,233,221,.7);font-size:1.02rem;margin-bottom:30px}
.btn-primary{display:inline-block;background:var(--brass);color:var(--navy);padding:14px 30px;text-decoration:none;font-family:var(--font-h);text-transform:uppercase;letter-spacing:.06em;font-weight:700}
.btn-outline{display:inline-block;border:1.5px solid var(--brass);color:var(--brass);padding:12px 26px;text-decoration:none;font-family:var(--font-h);text-transform:uppercase;letter-spacing:.06em;font-weight:600;white-space:nowrap}
.menu{padding:70px 0;background:var(--panel)}
.menu-list{display:flex;flex-direction:column;gap:16px}
.menu-row{display:flex;align-items:baseline;gap:10px}
.menu-name{font-weight:600;white-space:nowrap}
.menu-dots{flex:1;border-bottom:1px dotted rgba(239,233,221,.3);margin-bottom:5px}
.menu-time{color:rgba(239,233,221,.5);font-size:.8rem;white-space:nowrap}
.menu-price{font-family:var(--font-h);color:var(--brass);font-weight:600;white-space:nowrap}
.barbers{padding:80px 0}
.barber-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.barber-photo{width:100%;height:160px;background:linear-gradient(160deg,var(--brass),var(--navy));margin-bottom:16px;border-radius:2px}
.barber-card h3{font-size:1rem;margin-bottom:4px}
.barber-card span{color:rgba(239,233,221,.55);font-size:.82rem}
.club{padding:70px 0;background:var(--brass);color:var(--navy)}
.club-inner{display:flex;justify-content:space-between;align-items:center;gap:30px;flex-wrap:wrap}
.club h2{color:var(--navy)}
.club p{max-width:440px;font-size:.92rem}
.club .btn-outline{border-color:var(--navy);color:var(--navy)}
.hours{padding:80px 0}
.hours-inner{display:grid;grid-template-columns:1fr 1fr;gap:50px}
.hours-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(239,233,221,.12);font-size:.95rem}
.address-block p{color:rgba(239,233,221,.75);font-size:.92rem;margin-bottom:14px}
.walk-in-note{color:var(--brass)!important;font-size:.85rem!important}
.footer{padding:38px 0;text-align:center;color:rgba(239,233,221,.5);font-size:.8rem;border-top:1px solid rgba(239,233,221,.1)}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:rgba(239,233,221,.5);text-decoration:underline}
@media(max-width:800px){.barber-grid{grid-template-columns:1fr}.hours-inner{grid-template-columns:1fr}.club-inner{flex-direction:column;align-items:flex-start}}
</style>
