---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Electrician Portland | VoltSafe Electrical Services | Residential &amp; Commercial"
  description="Need an electrician? VoltSafe Electrical Services handles repairs, lighting installation, fuse box upgrades, and emergency electrical work. Licensed and insured in Portland."
  themeColor="#2d2d2d"
  bodyClass="electrician"
  consent={{ bg: "#2d2d2d", fg: "#e5e7eb", accent: "#eab308", accentFg: "#2d2d2d", border: "rgba(255,255,255,0.16)" }}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" slot="head">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" media="print" onload="this.media='all'" slot="head">

  <div class="page-wrapper">
    <nav class="nav" id="mainNav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="nav-logo-icon"><i class="fas fa-bolt"></i></span>
          VoltSafe Electrical
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
          <li><a href="#services">Services</a></li>
          <li><a href="#safety">Safety</a></li>
          <li><a href="#process">Process</a></li>
          <li><a href="#contact">Contact</a></li>
          <li><a href="#form" class="nav-cta">Request an Electrician</a></li>
        </ul>
      </div>
    </nav>

    <main id="main">
      <section class="hero">
        <div class="hero-content">
          <div class="hero-badge">Licensed &amp; Insured in Oregon</div>
          <h1>Safe, Reliable Electrical Work for Your Home or Business.</h1>
          <p>From a flickering light to a full commercial build-out, VoltSafe delivers professional electrical services you can trust. Every job is inspected, tested, and done right.</p>
          <div class="hero-actions">
            <a href="#form" class="btn btn-primary">Request an Electrician</a>
            <a href="tel:+15550193" class="btn btn-warning"><i class="fas fa-phone-alt"></i> Call for Urgent Help</a>
          </div>
        </div>
        <div class="hero-bg">
          <div class="hero-pattern"></div>
        </div>
      </section>

      <section class="section services" id="services">
        <div class="container">
          <div class="section-header">
            <span class="section-label">What We Do</span>
            <h2>Electrical Services</h2>
          </div>

          <div class="service-toggle" id="serviceToggle">
            <button class="toggle-btn active" data-type="residential">
              <i class="fas fa-home"></i> Residential
            </button>
            <button class="toggle-btn" data-type="commercial">
              <i class="fas fa-building"></i> Commercial
            </button>
          </div>

          <div class="services-grid" id="servicesGrid">
            <div class="service-card" data-type="residential">
              <div class="service-icon"><i class="fas fa-tools"></i></div>
              <h3>Repairs</h3>
              <p>Faulty outlets, broken switches, flickering lights, and power outages. We diagnose and repair electrical issues quickly and safely.</p>
            </div>
            <div class="service-card" data-type="residential">
              <div class="service-icon"><i class="fas fa-lightbulb"></i></div>
              <h3>Lighting Installation</h3>
              <p>Interior and exterior lighting installation, dimmer switches, motion sensors, and landscape lighting. We match fixture specifications precisely.</p>
            </div>
            <div class="service-card" data-type="residential">
              <div class="service-icon"><i class="fas fa-solar-panel"></i></div>
              <h3>Fuse Box Upgrades</h3>
              <p>Replace outdated fuse panels with modern circuit breaker systems. Increase capacity for new appliances and meet current code.</p>
            </div>
            <div class="service-card" data-type="residential">
              <div class="service-icon"><i class="fas fa-plug"></i></div>
              <h3>Outlet Installation</h3>
              <p>Add or relocate outlets, install USB-charging outlets, GFCI protection for kitchens and bathrooms, and 240-volt outlets for appliances.</p>
            </div>
            <div class="service-card" data-type="residential">
              <div class="service-icon"><i class="fas fa-project-diagram"></i></div>
              <h3>Wiring</h3>
              <p>New construction wiring, home additions, knob-and-tube replacement, and rewiring for older homes needing modern electrical capacity.</p>
            </div>
            <div class="service-card" data-type="residential">
              <div class="service-icon"><i class="fas fa-fan"></i></div>
              <h3>Ceiling Fans</h3>
              <p>Ceiling fan installation and replacement, including remote controls and lighting kits. We ensure secure mounting and correct wiring.</p>
            </div>

            <div class="service-card" data-type="commercial">
              <div class="service-icon"><i class="fas fa-industry"></i></div>
              <h3>Commercial Wiring</h3>
              <p>Complete electrical wiring for offices, retail spaces, warehouses, and restaurants. Conduit, cable trays, and panel work.</p>
            </div>
            <div class="service-card" data-type="commercial">
              <div class="service-icon"><i class="fas fa-charging-station"></i></div>
              <h3>Panel Upgrades</h3>
              <p>Upgrade commercial electrical panels to handle increased load demands. Three-phase power installations and transformers.</p>
            </div>
            <div class="service-card" data-type="commercial">
              <div class="service-icon"><i class="fas fa-lightbulb"></i></div>
              <h3>Lighting Design</h3>
              <p>Commercial lighting layouts, LED retrofits, emergency lighting systems, and occupancy sensor installations for energy efficiency.</p>
            </div>
            <div class="service-card" data-type="commercial">
              <div class="service-icon"><i class="fas fa-clipboard-check"></i></div>
              <h3>Safety Inspections</h3>
              <p>Thorough electrical safety inspections for property transactions, code compliance, insurance requirements, and preventative maintenance.</p>
            </div>
            <div class="service-card" data-type="commercial">
              <div class="service-icon"><i class="fas fa-network-wired"></i></div>
              <h3>Data Cabling</h3>
              <p>Structured cabling for voice, data, and video. Cat6, fiber optic, and patch panel installation for commercial networks.</p>
            </div>
            <div class="service-card" data-type="commercial">
              <div class="service-icon"><i class="fas fa-exclamation-triangle"></i></div>
              <h3>Emergency Repairs</h3>
              <p>24/7 emergency response for power outages, exposed wires, electrical fires, and hazardous conditions. We arrive within the hour for urgent calls.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="section safety" id="safety">
        <div class="container">
          <div class="section-header">
            <span class="section-label">Our Commitment</span>
            <h2>How We Work Safely</h2>
          </div>
          <div class="safety-steps">
            <div class="safety-step">
              <div class="safety-number">01</div>
              <div class="safety-content">
                <h3>Assessment</h3>
                <p>We begin every job with a full assessment of the existing electrical system. We identify potential hazards, load requirements, and code compliance before any work begins.</p>
              </div>
            </div>
            <div class="safety-step">
              <div class="safety-number">02</div>
              <div class="safety-content">
                <h3>Planning</h3>
                <p>We create a detailed work plan that includes circuit mapping, material specifications, shutdown procedures if needed, and a timeline that minimizes disruption.</p>
              </div>
            </div>
            <div class="safety-step">
              <div class="safety-number">03</div>
              <div class="safety-content">
                <h3>Licensed Work</h3>
                <p>Every electrician on our team holds a valid Oregon license. All work follows the National Electrical Code and local amendments. Permits are pulled for every job that requires them.</p>
              </div>
            </div>
            <div class="safety-step">
              <div class="safety-number">04</div>
              <div class="safety-content">
                <h3>Testing &amp; Verification</h3>
                <p>After completing the work, we test every circuit, outlet, and connection. We verify ground fault protection and provide a written summary of all work performed.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section certifications" id="certifications">
        <div class="container">
          <div class="certs-grid">
            <div class="cert-item">
              <i class="fas fa-id-card"></i>
              <h3>Licensed</h3>
              <p>All electricians carry current Oregon electrical licenses. We maintain continuing education to stay current with code changes.</p>
            </div>
            <div class="cert-item">
              <i class="fas fa-shield-alt"></i>
              <h3>Insured</h3>
              <p>We carry general liability and workers compensation insurance for your protection and ours.</p>
            </div>
            <div class="cert-item">
              <i class="fas fa-book"></i>
              <h3>NEC Compliant</h3>
              <p>All work follows the latest National Electrical Code standards and local amendments.</p>
            </div>
            <div class="cert-item">
              <i class="fas fa-check-double"></i>
              <h3>Permitted</h3>
              <p>We pull all required permits and schedule inspections so your work is recorded and verified.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="section area" id="area">
        <div class="container">
          <div class="area-content">
            <span class="section-label">Service Area</span>
            <h2>Serving the Portland Metro</h2>
            <p>We provide electrical services throughout the Portland metropolitan area, including downtown Portland, Beaverton, Hillsboro, Gresham, Lake Oswego, Tigard, Tualatin, Vancouver, and surrounding communities.</p>
          </div>
        </div>
      </section>

      <section class="section testimonials" id="testimonials">
        <div class="container">
          <div class="section-header">
            <span class="section-label">Real Reviews</span>
            <h2>What Our Customers Say</h2>
          </div>
          <div class="testimonials-grid">
            <div class="testimonial-card">
              <div class="testimonial-stars">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
              </div>
              <p>"I called VoltSafe at 10 PM when my breaker panel started smoking. They were at my house in 40 minutes, identified the problem, and had it fixed by midnight. Professional, knowledgeable, and fair pricing."</p>
              <div class="testimonial-author">
                <strong>David M.</strong>
                <span>Portland, OR</span>
              </div>
            </div>
            <div class="testimonial-card">
              <div class="testimonial-stars">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
              </div>
              <p>"We used VoltSafe for a full rewiring of our 1920s home. They were careful with the old plaster walls, communicated clearly throughout the project, and left every room spotless. Highly recommend."</p>
              <div class="testimonial-author">
                <strong>Sarah K.</strong>
                <span>Beaverton, OR</span>
              </div>
            </div>
            <div class="testimonial-card">
              <div class="testimonial-stars">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
              </div>
              <p>"VoltSafe handles all the electrical work for our retail chain. They are reliable, consistent, and their commercial team understands the urgency of keeping a business operational. Five stars."</p>
              <div class="testimonial-author">
                <strong>James L.</strong>
                <span>Property Manager, Portland</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section faq" id="faq">
        <div class="container">
          <div class="section-header">
            <span class="section-label">Common Questions</span>
            <h2>Frequently Asked Questions</h2>
          </div>
          <div class="faq-list">
            <div class="faq-item">
              <button class="faq-question">
                Do you offer emergency service?
                <i class="fas fa-chevron-down"></i>
              </button>
              <div class="faq-answer">
                <p>Yes. We provide 24/7 emergency electrical service. If you have a power outage, exposed wires, smoke from an outlet, or any other urgent issue, call our emergency line and we will respond within the hour.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question">
                Are you licensed and insured?
                <i class="fas fa-chevron-down"></i>
              </button>
              <div class="faq-answer">
                <p>Yes. Every VoltSafe electrician holds a valid Oregon electrical license. We carry full general liability insurance and workers compensation. Proof of insurance is available upon request.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question">
                How much does rewiring cost?
                <i class="fas fa-chevron-down"></i>
              </button>
              <div class="faq-answer">
                <p>Rewiring costs depend on the size of your home, the existing wiring condition, and accessibility. We provide free estimates after an on-site inspection. Typical whole-home rewiring ranges from $8,000 to $18,000 for a standard single-family home.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question">
                Can you install ceiling fans?
                <i class="fas fa-chevron-down"></i>
              </button>
              <div class="faq-answer">
                <p>Yes. We install ceiling fans of all types, including fans with lights and remote controls. We ensure the ceiling box is properly rated to support the fan weight and that all wiring meets code.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question">
                Do you do commercial work?
                <i class="fas fa-chevron-down"></i>
              </button>
              <div class="faq-answer">
                <p>Absolutely. We handle commercial electrical projects of all sizes, from small office repairs to full build-outs. Our commercial team has experience with retail spaces, restaurants, warehouses, and office buildings.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section form-section" id="form">
        <div class="container">
          <div class="section-header">
            <span class="section-label">Get in Touch</span>
            <h2>Request an Electrician</h2>
            <p>Fill out the form below and we will contact you within 4 hours during business hours. For emergencies, please call us directly.</p>
          </div>
          <form class="form" id="requestForm">
            <div class="form-row">
              <div class="form-group">
                <label for="formName">Name *</label>
                <input type="text" id="formName" required placeholder="Your full name">
              </div>
              <div class="form-group">
                <label for="formEmail">Email *</label>
                <input type="email" id="formEmail" required placeholder="you@example.com">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="formPhone">Phone *</label>
                <input type="tel" id="formPhone" required placeholder="(555) 123-4567">
              </div>
              <div class="form-group">
                <label for="formService">Service Type</label>
                <select id="formService">
                  <option value="">Select a service</option>
                  <option value="repairs">Repairs</option>
                  <option value="lighting">Lighting Installation</option>
                  <option value="panel">Panel / Fuse Box Upgrade</option>
                  <option value="wiring">Rewiring</option>
                  <option value="outlets">Outlet Installation</option>
                  <option value="fans">Ceiling Fan Installation</option>
                  <option value="commercial-wiring">Commercial Wiring</option>
                  <option value="inspection">Safety Inspection</option>
                  <option value="emergency">Emergency Service</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="formProperty">Property Type</label>
                <select id="formProperty">
                  <option value="residential">Residential</option>
                  <option value="commercial">Commercial</option>
                </select>
              </div>
              <div class="form-group">
                <label for="formDate">Preferred Date / Time</label>
                <input type="text" id="formDate" placeholder="e.g. Tuesday morning, or a specific date">
              </div>
            </div>
            <div class="form-group">
              <label for="formDescription">Description of Issue *</label>
              <textarea id="formDescription" rows="5" required placeholder="Describe the electrical issue you are experiencing, including how long it has been happening and any relevant details."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Submit Request</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <h3><i class="fas fa-bolt"></i> VoltSafe Electrical</h3>
            <p>Licensed and insured electricians serving Portland with reliable, safe, and professional electrical services.</p>
          </div>
          <div class="footer-contact">
            <h4>Contact</h4>
            <p>800 Industrial Drive<br>Portland, OR 97201</p>
            <p><a href="tel:+15550193">555-0193</a></p>
            <p><a href="mailto:info@voltsafeelectric.com">info@voltsafeelectric.com</a></p>
          </div>
          <div class="footer-hours">
            <h4>Hours</h4>
            <p>Mon - Sat: 7:00 AM - 9:00 PM</p>
            <p><strong>Emergency: 24/7</strong></p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 VoltSafe Electrical Services. All rights reserved. Licensed &amp; Insured in Oregon.</p>
        </div>
      </div>
    </footer>

    <div class="mobile-sticky" id="mobileSticky">
      <a href="tel:+15550193" class="btn btn-warning"><i class="fas fa-phone-alt"></i> Call 555-0193</a>
    </div>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Electrician"],
    "name": "VoltSafe Electrical Services",
    "description": "Licensed and insured electricians in Portland. Residential and commercial electrical services including repairs, lighting installation, fuse box upgrades, and emergency work.",
    "url": "https://www.voltsafeelectric.com",
    "telephone": "+1-555-0193",
    "email": "info@voltsafeelectric.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "800 Industrial Drive",
      "addressLocality": "Portland",
      "addressRegion": "OR",
      "postalCode": "97201",
      "addressCountry": "US"
    },
    "priceRange": "$$",
    "openingHours": "Mo-Sa 07:00-21:00",
    "areaServed": { "@type": "City", "name": "Portland" },
    "image": "https://picsum.photos/1200/630?random=electric"
  }
  </script>
</BaseLayout>

<style>
  :global(.electrician) {
    --dark: #2d2d2d;
    --dark-light: #3d3d3d;
    --yellow: #eab308;
    --yellow-dark: #c59b08;
    --yellow-light: #fef4cc;
    --white: #ffffff;
    --gray: #f4f4f4;
    --gray-text: #6b7280;
    --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --transition: 0.25s ease;
    --shadow: 0 4px 16px rgba(45, 45, 45, 0.08);
    font-family: var(--font);
    color: var(--dark);
    background: var(--white);
    line-height: 1.6;
    font-size: 1rem;
    -webkit-font-smoothing: antialiased;
  }

  .page-wrapper { overflow-x: hidden; }
  .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
  h1, h2, h3, h4 { font-weight: 700; line-height: 1.25; color: var(--dark); }
  h1 { font-size: 2.8rem; }
  h2 { font-size: 2rem; margin-bottom: 12px; }
  h3 { font-size: 1.25rem; }
  h4 { font-size: 1rem; }
  a { color: inherit; text-decoration: none; }

  .section-header { text-align: center; margin-bottom: 48px; }
  .section-label { display: inline-block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2.5px; color: #7a5f05; font-weight: 600; margin-bottom: 8px; }
  .section { padding: 80px 0; }

  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; font-family: var(--font); font-size: 0.95rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: all var(--transition); text-transform: none; }
  .btn-primary { background: var(--yellow); color: var(--dark); }
  .btn-primary:hover { background: var(--yellow-dark); }
  .btn-warning { background: transparent; color: var(--white); border: 2px solid var(--yellow); }
  .btn-warning:hover { background: var(--yellow); color: var(--dark); }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: var(--dark); padding: 16px 0; border-bottom: 2px solid rgba(234, 179, 8, 0.15); }
  .nav-inner { max-width: 1160px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-size: 1.15rem; font-weight: 700; color: var(--white); text-decoration: none; display: flex; align-items: center; gap: 10px; letter-spacing: -0.3px; }
  .nav-logo-icon { color: var(--yellow); font-size: 1.3rem; }
  .nav-links { display: flex; list-style: none; gap: 28px; align-items: center; }
  .nav-links a { font-size: 0.9rem; font-weight: 500; color: rgba(255, 255, 255, 0.8); text-decoration: none; transition: color var(--transition); }
  .nav-links a:hover { color: var(--yellow); }
  .nav-cta { padding: 8px 20px; background: var(--yellow); color: var(--dark) !important; font-weight: 600 !important; border-radius: 0; }
  .nav-cta:hover { background: var(--yellow-dark) !important; color: var(--dark) !important; }
  .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 4px; }
  .nav-toggle span { display: block; width: 24px; height: 2px; background: var(--white); margin: 5px 0; transition: all var(--transition); }

  .hero { position: relative; min-height: 92vh; background: var(--dark); display: flex; align-items: center; justify-content: center; padding: 140px 24px 80px; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; opacity: 0.08; }
  .hero-pattern { width: 100%; height: 100%; background: repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(234, 179, 8, 0.3) 40px, rgba(234, 179, 8, 0.3) 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(234, 179, 8, 0.3) 40px, rgba(234, 179, 8, 0.3) 41px); }
  .hero-content { position: relative; z-index: 2; text-align: center; max-width: 720px; }
  .hero-badge { display: inline-block; background: rgba(234, 179, 8, 0.12); color: var(--yellow); padding: 6px 18px; font-size: 0.75rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 24px; border: 1px solid rgba(234, 179, 8, 0.25); }
  .hero-content h1 { color: var(--white); margin-bottom: 20px; }
  .hero-content p { color: rgba(255, 255, 255, 0.7); font-size: 1.1rem; margin-bottom: 36px; line-height: 1.7; }
  .hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  .services { background: var(--white); }

  .service-toggle { display: flex; justify-content: center; gap: 0; margin-bottom: 48px; border: 2px solid var(--dark); display: inline-flex; margin-left: auto; margin-right: auto; width: auto; }
  .toggle-btn { padding: 14px 36px; font-family: var(--font); font-size: 0.9rem; font-weight: 600; background: var(--white); color: var(--dark); border: none; cursor: pointer; transition: all var(--transition); display: flex; align-items: center; gap: 8px; }
  .toggle-btn:first-child { border-right: 1px solid var(--dark); }
  .toggle-btn.active { background: var(--dark); color: var(--yellow); }
  .toggle-btn:hover:not(.active) { background: var(--gray); }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .service-card { background: var(--white); padding: 32px 28px; border: 1px solid rgba(45, 45, 45, 0.06); transition: all var(--transition); }
  .service-card:hover { border-color: var(--yellow); box-shadow: var(--shadow); }
  .service-card[data-type="commercial"] { display: none; }
  .service-card.show { display: block; }
