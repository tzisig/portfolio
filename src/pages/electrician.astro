  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .testimonial-card { background: var(--white); padding: 32px 28px; border: 1px solid rgba(45, 45, 45, 0.06); }
  .testimonial-stars { color: var(--yellow); margin-bottom: 16px; font-size: 0.85rem; }
  .testimonial-card p { color: var(--gray-text); font-size: 0.9rem; line-height: 1.7; margin-bottom: 20px; }
