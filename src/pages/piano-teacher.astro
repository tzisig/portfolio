---
import BaseLayout from "../layouts/BaseLayout.astro";

const programs = [
  { name: "Young Beginners", age: "Ages 5–8", desc: "Playful, game-based introduction to the keyboard and reading music." },
  { name: "Youth", age: "Ages 9–14", desc: "Structured technique and repertoire, prepares students for exams if desired." },
  { name: "Teen & Adult", age: "Ages 15+", desc: "Flexible repertoire — classical, jazz, or pop, at your own pace." },
  { name: "Exam Prep", age: "RCM & ABRSM", desc: "Focused preparation for formal conservatory exams." },
];

const testimonials = [
  { text: "My daughter went from dreading practice to asking for extra time at the piano. That's the whole ballgame.", name: "Priya R., parent" },
  { text: "I started as an adult beginner at 34 and now play for my own enjoyment most evenings. No judgment, just steady progress.", name: "Owen T., adult student" },
];
---
<BaseLayout title="Aldergrove Piano Studio | Private Piano Lessons" description="Aldergrove Piano Studio offers private piano lessons for beginners through advanced students, ages 5 and up." themeColor="#F7F4EE" bodyClass="piano" consent={{ bg: "#5C2A2A", fg: "#F7F4EE", accent: "#C9A25D", accentFg: "#3A1919", border: "rgba(247,244,238,0.2)" }}>
  <slot name="head"><link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,500;1,500;0,600&family=Libre+Franklin:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,500;1,500;0,600&family=Libre+Franklin:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,500;1,500;0,600&family=Libre+Franklin:wght@400;500;600&display=swap" /></noscript>
  </slot>
  <nav class="topnav"><div class="container nav-inner"><a href="#" class="brand">Aldergrove Piano</a><ul class="nav-links"><li><a href="#programs">Programs</a></li><li><a href="#teacher">Teacher</a></li><li><a href="#pricing">Pricing</a></li></ul></div></nav>
  <main>
    <section class="hero">
      <div class="container hero-inner">
        <div>
          <p class="hero-eyebrow">Private lessons &middot; In-home studio</p>
          <h1>Piano lessons that stick past the first month.</h1>
          <p class="hero-sub">Twenty years teaching beginners through conservatory-track students — the same patient, structured approach for every age.</p>
          <a href="#pricing" class="btn-primary">Book a trial lesson</a>
        </div>
        <div class="staff-lines" aria-hidden="true">
          <div class="staff"></div><div class="staff"></div><div class="staff"></div><div class="staff"></div><div class="staff"></div>
        </div>
      </div>
    </section>

    <section class="programs" id="programs">
      <div class="container">
        <p class="section-label">Programs</p>
        <h2>A track for every stage.</h2>
        <div class="program-grid">
          {programs.map((p) => (<div class="program-card"><span class="program-age">{p.age}</span><h3>{p.name}</h3><p>{p.desc}</p></div>))}
        </div>
      </div>
    </section>

    <section class="teacher" id="teacher">
      <div class="container teacher-inner">
        <div class="teacher-photo" aria-hidden="true"></div>
        <div>
          <p class="section-label">Your teacher</p>
          <h2>Eleanor Vance</h2>
          <p>Master's in piano performance, University of Washington. Former section pianist with the Portland Chamber Orchestra, teaching privately since 2005. Studio located in a dedicated, sound-treated room — not a corner of the living room.</p>
        </div>
      </div>
    </section>

    <section class="showcase">
      <div class="container">
        <p class="section-label">From the studio</p>
        <div class="testimonial-grid">
          {testimonials.map((t) => (<div class="testimonial"><p>&ldquo;{t.text}&rdquo;</p><span>— {t.name}</span></div>))}
        </div>
      </div>
    </section>

    <section class="pricing" id="pricing">
      <div class="container pricing-inner">
        <div>
          <p class="section-label">Pricing</p>
          <h2>$68 per 45-minute lesson.</h2>
          <p>Weekly, in-studio. Ten-lesson packages available at a discount. No long-term contract required.</p>
        </div>
        <a href="mailto:eleanor@aldergrovepiano.com" class="pricing-link">eleanor@aldergrovepiano.com</a>
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-inner"><p>Aldergrove Piano Studio &mdash; Portland, OR</p><nav><a href="/privacy">Privacy</a><a href="/cookies">Cookies</a><a href="/accessibility">Accessibility</a></nav></div></footer>
</BaseLayout>
<style>
:global(.piano){--ivory:#F7F4EE;--burgundy:#5C2A2A;--gold:#C9A25D;--ink:#3A1919;--font-h:'Newsreader',serif;--font-b:'Libre Franklin',sans-serif}
:global(.piano){font-family:var(--font-b);color:var(--ink);background:var(--ivory);line-height:1.7}
:global(.piano) :focus-visible{outline:2px solid var(--gold);outline-offset:2px}
.container{max-width:1020px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:var(--font-h);color:var(--burgundy);font-weight:600}
.section-label{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);font-weight:700;margin-bottom:10px}
h2{font-size:clamp(1.5rem,3vw,2rem);margin-bottom:16px}
.topnav{padding:22px 0}
.nav-inner{display:flex;justify-content:space-between;align-items:center}
.brand{font-family:var(--font-h);font-size:1.25rem;color:var(--burgundy);text-decoration:none;font-weight:600}
.nav-links{display:flex;gap:26px;list-style:none;font-size:.9rem}
.nav-links a{color:var(--ink);text-decoration:none}
.hero{padding:50px 0 90px}
.hero-inner{display:grid;grid-template-columns:1.1fr 1fr;gap:50px;align-items:center}
.hero-eyebrow{font-size:.82rem;color:var(--gold);letter-spacing:.08em;text-transform:uppercase;margin-bottom:20px}
h1{font-size:clamp(2.2rem,4.6vw,3.2rem);font-weight:600;line-height:1.15;margin-bottom:22px}
.hero-sub{color:#6B5555;font-size:1rem;max-width:440px;margin-bottom:30px}
.btn-primary{display:inline-block;background:var(--burgundy);color:var(--ivory);padding:13px 30px;text-decoration:none;border-radius:2px;font-weight:600}
.staff-lines{display:flex;flex-direction:column;gap:14px;opacity:.5}
.staff{height:2px;background:var(--burgundy);width:100%}
.staff:nth-child(odd){width:80%}
.programs{padding:80px 0;background:#fff}
.program-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.program-card{padding:24px 20px;border:1px solid rgba(92,42,42,.1)}
.program-age{font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:var(--gold);font-weight:700;display:block;margin-bottom:10px}
.program-card h3{font-size:1.05rem;margin-bottom:8px}
.program-card p{font-size:.85rem;color:#6B5555}
.teacher{padding:88px 0}
.teacher-inner{display:grid;grid-template-columns:220px 1fr;gap:46px;align-items:center}
.teacher-photo{width:220px;height:260px;background:linear-gradient(160deg,var(--gold),var(--burgundy));border-radius:2px}
.teacher-inner p{color:#6B5555;font-size:.95rem;max-width:480px}
.showcase{padding:80px 0;background:var(--burgundy)}
.showcase .section-label{color:var(--gold)}
.testimonial-grid{display:grid;grid-template-columns:1fr 1fr;gap:30px}
.testimonial p{font-family:var(--font-h);font-style:italic;color:var(--ivory);font-size:1.1rem;line-height:1.5;margin-bottom:14px}
.testimonial span{color:rgba(247,244,238,.6);font-size:.85rem}
.pricing{padding:90px 0;background:#fff}
.pricing-inner{display:flex;justify-content:space-between;align-items:center;gap:30px;flex-wrap:wrap}
.pricing-inner p{color:#6B5555;font-size:.92rem;max-width:420px}
.pricing-link{font-family:var(--font-h);font-size:1.15rem;color:var(--gold);text-decoration:none;white-space:nowrap}
.footer{padding:38px 0;text-align:center;color:#8A7A7A;font-size:.8rem}
.footer-inner nav{display:flex;justify-content:center;gap:20px;margin-top:6px}
.footer a{color:#8A7A7A;text-decoration:underline}
@media(max-width:800px){.hero-inner{grid-template-columns:1fr}.staff-lines{display:none}.program-grid{grid-template-columns:1fr 1fr}.teacher-inner{grid-template-columns:1fr;text-align:center}.teacher-photo{margin:0 auto}.testimonial-grid{grid-template-columns:1fr}.pricing-inner{flex-direction:column;align-items:flex-start}}
</style>
