---
// Theme the banner per-page by passing CSS custom properties as props,
// so every landing page can match its own palette without duplicating markup.
interface Props {
  bg?: string;
  fg?: string;
  accent?: string;
  accentFg?: string;
  border?: string;
}
const {
  bg = "#111111",
  fg = "#f5f5f5",
  accent = "#f5f5f5",
  accentFg = "#111111",
  border = "rgba(255,255,255,0.14)",
} = Astro.props;
---

<div
  id="cookie-consent"
  class="cookie-consent"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie preferences"
  aria-hidden="true"
  style={`--cc-bg:${bg}; --cc-fg:${fg}; --cc-accent:${accent}; --cc-accent-fg:${accentFg}; --cc-border:${border};`}
>
  <div class="cookie-consent__inner">
    <p class="cookie-consent__text">
      This site uses only strictly-necessary cookies to run correctly. With
      your permission we'd also like to use optional cookies to understand
      site usage. Read the <a href="/cookies">Cookie Policy</a> for details.
    </p>
    <div class="cookie-consent__actions">
      <button type="button" id="cookie-reject" class="cookie-consent__btn cookie-consent__btn--ghost">
        Reject optional
      </button>
      <button type="button" id="cookie-accept" class="cookie-consent__btn cookie-consent__btn--solid">
        Accept all
      </button>
    </div>
  </div>
</div>

<style>
  .cookie-consent {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 2000;
    background: var(--cc-bg);
    color: var(--cc-fg);
    border-top: 1px solid var(--cc-border);
    padding: 1.1rem 1.25rem;
    transform: translateY(110%);
    transition: transform 0.35s ease;
  }
  .cookie-consent[data-visible="true"] {
    transform: translateY(0);
  }
  .cookie-consent__inner {
    max-width: 68rem;
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.5rem;
  }
  .cookie-consent__text {
    flex: 1 1 24rem;
    font-size: 0.875rem;
    line-height: 1.55;
    opacity: 0.92;
  }
  .cookie-consent__text a {
    color: var(--cc-fg);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie-consent__actions {
    display: flex;
    gap: 0.65rem;
    flex-shrink: 0;
  }
  .cookie-consent__btn {
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 0.4rem;
    padding: 0.6rem 1.05rem;
    border: 1px solid var(--cc-border);
    white-space: nowrap;
  }
  .cookie-consent__btn--ghost {
    background: transparent;
    color: var(--cc-fg);
  }
  .cookie-consent__btn--solid {
    background: var(--cc-accent);
    color: var(--cc-accent-fg);
    border-color: transparent;
  }

  @media (max-width: 40rem) {
    .cookie-consent__inner { flex-direction: column; align-items: stretch; }
    .cookie-consent__actions { justify-content: stretch; }
    .cookie-consent__btn { flex: 1; }
  }
</style>

<script>
  const KEY = "cookie-consent-v1";
  const el = document.getElementById("cookie-consent");

  function show() {
    if (!el) return;
    el.dataset.visible = "true";
    el.setAttribute("aria-hidden", "false");
  }
  function hide() {
    if (!el) return;
    el.dataset.visible = "false";
    el.setAttribute("aria-hidden", "true");
  }

  const saved = localStorage.getItem(KEY);
  if (!saved) {
    // Slight delay so it never competes with first paint / LCP.
    window.setTimeout(show, 700);
  }

  document.getElementById("cookie-accept")?.addEventListener("click", () => {
    localStorage.setItem(KEY, JSON.stringify({ optional: true, ts: Date.now() }));
    hide();
  });
  document.getElementById("cookie-reject")?.addEventListener("click", () => {
    localStorage.setItem(KEY, JSON.stringify({ optional: false, ts: Date.now() }));
    hide();
  });
</script>
